<%- include('../partials/header', { title: title, user: user }) %>

<div class="page admin-page">
  <!-- Mobile-First Header -->
  <header class="page-header">
    <a href="/admin" class="btn-back" title="Back to Admin">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </a>
    <h1>Assets</h1>
    <% if (user && user.role === 'admin') { %>
    <div class="header-actions">
      <button class="btn-icon btn-secondary" id="qr-batch-btn" onclick="window.location.href='/mobile/qr-labels/batch'" title="Generate QR Labels">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </button>
      <button class="btn-icon btn-primary" id="add-btn" onclick="openModal()" title="Add Asset">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    </div>
    <% } %>
  </header>

  <!-- Quick Stats -->
  <div class="quick-stats" id="quick-stats">
    <div class="stat-pill">
      <span class="stat-value" id="total-count">-</span>
      <span class="stat-label">Total</span>
    </div>
    <div class="stat-pill operational">
      <span class="stat-value" id="operational-count">-</span>
      <span class="stat-label">Operational</span>
    </div>
    <div class="stat-pill maintenance">
      <span class="stat-value" id="maintenance-count">-</span>
      <span class="stat-label">Maintenance</span>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="filter-bar">
    <button class="filter-btn" id="filter-toggle" onclick="toggleFilters()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="21" x2="4" y2="14"/>
        <line x1="4" y1="10" x2="4" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="12"/>
        <line x1="12" y1="8" x2="12" y2="3"/>
        <line x1="20" y1="21" x2="20" y2="16"/>
        <line x1="20" y1="12" x2="20" y2="3"/>
        <line x1="1" y1="14" x2="7" y2="14"/>
        <line x1="9" y1="8" x2="15" y2="8"/>
        <line x1="17" y1="16" x2="23" y2="16"/>
      </svg>
      Filters
    </button>
    
    <!-- Search -->
    <div class="search-bar compact">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <path d="M21 21l-4.35-4.35"/>
      </svg>
      <input type="text" id="search-input" placeholder="Search assets...">
    </div>
  </div>

  <!-- Expandable Filters -->
  <div class="filters-panel hidden" id="filters-panel">
    <div class="filter-row">
      <div class="filter-group">
        <label>Category</label>
        <select id="filter-category" onchange="onCategoryFilterChange()">
          <option value="">All Categories</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Class</label>
        <select id="filter-class" onchange="onClassFilterChange()" disabled>
          <option value="">All Classes</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Type</label>
        <select id="filter-type" onchange="applyFilters()" disabled>
          <option value="">All Types</option>
        </select>
      </div>
    </div>
    <div class="filter-row">
      <div class="filter-group">
        <label>Facility</label>
        <select id="filter-facility" onchange="applyFilters()">
          <option value="">All Facilities</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Status</label>
        <select id="filter-status" onchange="applyFilters()">
          <option value="">All Status</option>
          <option value="operational">Operational</option>
          <option value="maintenance">Maintenance</option>
          <option value="out_of_order">Out of Order</option>
          <option value="decommissioned">Decommissioned</option>
        </select>
      </div>
    </div>
    <button class="btn btn-text" onclick="clearFilters()">Clear All Filters</button>
  </div>

  <!-- Active Filters Tags -->
  <div class="active-filters" id="active-filters"></div>

  <!-- Equipment List -->
  <div class="equipment-list" id="equipment-list">
    <div class="loading-skeleton">
      <div class="skeleton-item"></div>
      <div class="skeleton-item"></div>
      <div class="skeleton-item"></div>
    </div>
  </div>
</div>

<!-- Add/Edit Equipment Modal -->
<div class="modal hidden" id="equipment-modal">
  <div class="modal-overlay" onclick="closeModal()"></div>
  <div class="modal-content modal-lg">
    <div class="modal-header">
      <h2 id="modal-title">Add Asset</h2>
      <button class="btn-close" onclick="closeModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <form id="equipment-form" class="modal-body">
      <input type="hidden" id="equipment-id" name="id">
      
      <!-- Basic Info -->
      <div class="form-section">
        <h3 class="section-title">Basic Information</h3>
        <div class="form-row">
          <div class="form-group">
            <label for="name">Asset Name *</label>
            <input type="text" id="name" name="name" required placeholder="e.g., Main Process Pump A">
          </div>
          <div class="form-group">
            <label for="code">Asset Code *</label>
            <input type="text" id="code" name="code" required placeholder="e.g., PMP-001">
          </div>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label for="facility_id">Facility *</label>
            <select id="facility_id" name="facility_id" required>
              <option value="">Select Facility...</option>
            </select>
          </div>
          <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" placeholder="e.g., Building A, Floor 2">
          </div>
        </div>
      </div>
      
      <!-- ISO 14224 Classification -->
      <div class="form-section">
        <h3 class="section-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px; vertical-align: middle; margin-right: 6px;">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          </svg>
          ISO 14224 Classification
        </h3>
        <div class="iso-classification">
          <div class="form-row">
            <div class="form-group">
              <label for="equipment_category_id">Equipment Category *</label>
              <select id="equipment_category_id" name="equipment_category_id" required onchange="onCategoryChange()">
                <option value="">Select Category...</option>
              </select>
            </div>
            <div class="form-group">
              <label for="equipment_class_id">Equipment Class *</label>
              <select id="equipment_class_id" name="equipment_class_id" required onchange="onClassChange()" disabled>
                <option value="">Select Class...</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group full-width">
              <label for="equipment_type_id">Equipment Type *</label>
              <select id="equipment_type_id" name="equipment_type_id" required disabled>
                <option value="">Select Type...</option>
              </select>
              <small class="form-hint">This determines available maintenance templates</small>
            </div>
          </div>
          <div class="iso-preview hidden" id="iso-preview">
            <div class="iso-path" id="iso-path"></div>
          </div>
        </div>
      </div>
      
      <!-- Technical Details -->
      <div class="form-section">
        <h3 class="section-title">Technical Details</h3>
        <div class="form-row">
          <div class="form-group">
            <label for="manufacturer">Manufacturer</label>
            <input type="text" id="manufacturer" name="manufacturer" placeholder="e.g., Grundfos">
          </div>
          <div class="form-group">
            <label for="model">Model</label>
            <input type="text" id="model" name="model" placeholder="e.g., CR 32-2">
          </div>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label for="serial_number">Serial Number</label>
            <input type="text" id="serial_number" name="serial_number" placeholder="Serial number">
          </div>
          <div class="form-group">
            <label for="install_date">Installation Date</label>
            <input type="date" id="install_date" name="install_date">
          </div>
        </div>
      </div>
      
      <!-- Status & Criticality -->
      <div class="form-section">
        <h3 class="section-title">Status & Criticality</h3>
        <div class="form-row">
          <div class="form-group">
            <label for="status">Status</label>
            <select id="status" name="status">
              <option value="operational">Operational</option>
              <option value="maintenance">Under Maintenance</option>
              <option value="out_of_order">Out of Order</option>
              <option value="decommissioned">Decommissioned</option>
            </select>
          </div>
          <div class="form-group">
            <label for="criticality">Criticality</label>
            <select id="criticality" name="criticality">
              <option value="low">Low</option>
              <option value="medium" selected>Medium</option>
              <option value="high">High</option>
              <option value="critical">Critical</option>
            </select>
          </div>
        </div>
      </div>
      
      <!-- Description -->
      <div class="form-section">
        <h3 class="section-title">Description</h3>
        <div class="form-group">
          <textarea id="description" name="description" rows="3" placeholder="Asset description, specifications, notes..."></textarea>
        </div>
      </div>
      
      <div class="form-actions sticky">
        <button type="button" class="btn btn-secondary btn-lg" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary btn-lg">Save Asset</button>
      </div>
    </form>
  </div>
</div>

<!-- Asset Detail Modal -->
<div class="modal hidden" id="asset-detail-modal">
  <div class="modal-overlay" onclick="closeDetailModal()"></div>
  <div class="modal-content">
    <div class="modal-header">
      <h2>Asset Details</h2>
      <button class="btn-close" onclick="closeDetailModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body" id="asset-detail-content">
      <!-- Content loaded dynamically -->
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary btn-lg btn-block" onclick="startInspection()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px; vertical-align: middle; margin-right: 8px;">
          <path d="M9 11l3 3L22 4"/>
          <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
        </svg>
        Start Inspection
      </button>
      <button class="btn btn-secondary btn-lg btn-block" onclick="createWorkOrder()" style="margin-top: 8px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px; vertical-align: middle; margin-right: 8px;">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Create Work Order
      </button>
    </div>
  </div>
</div>

<script>
// State management
let equipmentData = [];
let filteredData = [];
let facilities = [];
let isoData = {
  categories: [],
  classes: [],
  types: []
};
let editingId = null;
let currentAssetId = null;
let isAdminUser = <%= user && user.role === 'admin' ? 'true' : 'false' %>;

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  checkAuth();
  initEventListeners();
  loadAllData();
});

function initEventListeners() {
  // Search with debounce
  const searchInput = document.getElementById('search-input');
  searchInput.addEventListener('input', debounce((e) => {
    applyFilters();
  }, 300));

  // Form submission
  document.getElementById('equipment-form').addEventListener('submit', handleFormSubmit);
}

async function loadAllData() {
  await Promise.all([
    loadFacilities(),
    loadIsoData(),
    loadEquipment()
  ]);
}

async function loadFacilities() {
  try {
    const response = await fetch('/api/facilities', {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    if (data.success) {
      facilities = data.data.facilities;
      populateFacilitySelects();
    }
  } catch (error) {
    console.error('Error loading facilities:', error);
  }
}

async function loadIsoData() {
  try {
    // Load categories
    const catResponse = await fetch('/api/iso-equipment/categories', {
      headers: getAuthHeaders()
    });
    const catData = await catResponse.json();
    if (catData.success) {
      isoData.categories = catData.data.categories;
      populateCategorySelects();
    }
  } catch (error) {
    console.error('Error loading ISO data:', error);
  }
}

async function loadClassesByCategory(categoryId) {
  try {
    const response = await fetch(`/api/iso-equipment/categories/${categoryId}/classes`, {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    if (data.success) {
      return data.data.classes;
    }
  } catch (error) {
    console.error('Error loading classes:', error);
  }
  return [];
}

async function loadTypesByClass(classId) {
  try {
    const response = await fetch(`/api/iso-equipment/classes/${classId}/types`, {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    if (data.success) {
      return data.data.types;
    }
  } catch (error) {
    console.error('Error loading types:', error);
  }
  return [];
}

function populateFacilitySelects() {
  const facilitySelects = ['facility_id', 'filter-facility'];
  facilitySelects.forEach(id => {
    const select = document.getElementById(id);
    if (select) {
      const currentValue = select.value;
      const prefix = id === 'facility_id' ? '<option value="">Select Facility...</option>' : '<option value="">All Facilities</option>';
      select.innerHTML = prefix + facilities.map(f => `<option value="${f.id}">${f.name}</option>`).join('');
      select.value = currentValue;
    }
  });
}

function populateCategorySelects() {
  // Form category select
  const categorySelect = document.getElementById('equipment_category_id');
  categorySelect.innerHTML = '<option value="">Select Category...</option>' + 
    isoData.categories.map(c => `<option value="${c.id}">${c.category_name}</option>`).join('');
  
  // Filter category select
  const filterCategory = document.getElementById('filter-category');
  filterCategory.innerHTML = '<option value="">All Categories</option>' + 
    isoData.categories.map(c => `<option value="${c.id}">${c.category_name}</option>`).join('');
}

// Cascading dropdown handlers
async function onCategoryChange() {
  const categoryId = document.getElementById('equipment_category_id').value;
  const classSelect = document.getElementById('equipment_class_id');
  const typeSelect = document.getElementById('equipment_type_id');
  
  // Reset downstream selects
  classSelect.innerHTML = '<option value="">Select Class...</option>';
  typeSelect.innerHTML = '<option value="">Select Type...</option>';
  classSelect.disabled = !categoryId;
  typeSelect.disabled = true;
  
  if (categoryId) {
    const classes = await loadClassesByCategory(categoryId);
    isoData.classes = classes;
    classSelect.innerHTML = '<option value="">Select Class...</option>' + 
      classes.map(c => `<option value="${c.id}">${c.class_name}</option>`).join('');
  }
  
  updateIsoPreview();
}

async function onClassChange() {
  const classId = document.getElementById('equipment_class_id').value;
  const typeSelect = document.getElementById('equipment_type_id');
  
  // Reset type select
  typeSelect.innerHTML = '<option value="">Select Type...</option>';
  typeSelect.disabled = !classId;
  
  if (classId) {
    const types = await loadTypesByClass(classId);
    isoData.types = types;
    typeSelect.innerHTML = '<option value="">Select Type...</option>' + 
      types.map(t => `<option value="${t.id}">${t.type_name}</option>`).join('');
  }
  
  updateIsoPreview();
}

function updateIsoPreview() {
  const categoryId = document.getElementById('equipment_category_id').value;
  const classId = document.getElementById('equipment_class_id').value;
  const typeId = document.getElementById('equipment_type_id').value;
  const preview = document.getElementById('iso-preview');
  const path = document.getElementById('iso-path');
  
  if (categoryId) {
    const category = isoData.categories.find(c => c.id == categoryId);
    const classObj = classId ? isoData.classes.find(c => c.id == classId) : null;
    const type = typeId ? isoData.types.find(t => t.id == typeId) : null;
    
    let pathText = category.category_name;
    if (classObj) pathText += ` > ${classObj.class_name}`;
    if (type) pathText += ` > ${type.type_name}`;
    
    path.textContent = pathText;
    preview.classList.remove('hidden');
  } else {
    preview.classList.add('hidden');
  }
}

// Filter handlers
async function onCategoryFilterChange() {
  const categoryId = document.getElementById('filter-category').value;
  const classSelect = document.getElementById('filter-class');
  const typeSelect = document.getElementById('filter-type');
  
  classSelect.innerHTML = '<option value="">All Classes</option>';
  typeSelect.innerHTML = '<option value="">All Types</option>';
  classSelect.disabled = !categoryId;
  typeSelect.disabled = true;
  
  if (categoryId) {
    const classes = await loadClassesByCategory(categoryId);
    classSelect.innerHTML = '<option value="">All Classes</option>' + 
      classes.map(c => `<option value="${c.id}">${c.class_name}</option>`).join('');
  }
  
  applyFilters();
}

async function onClassFilterChange() {
  const classId = document.getElementById('filter-class').value;
  const typeSelect = document.getElementById('filter-type');
  
  typeSelect.innerHTML = '<option value="">All Types</option>';
  typeSelect.disabled = !classId;
  
  if (classId) {
    const types = await loadTypesByClass(classId);
    typeSelect.innerHTML = '<option value="">All Types</option>' + 
      types.map(t => `<option value="${t.id}">${t.type_name}</option>`).join('');
  }
  
  applyFilters();
}

function toggleFilters() {
  const panel = document.getElementById('filters-panel');
  panel.classList.toggle('hidden');
}

function applyFilters() {
  const searchTerm = document.getElementById('search-input').value.toLowerCase();
  const categoryId = document.getElementById('filter-category').value;
  const classId = document.getElementById('filter-class').value;
  const typeId = document.getElementById('filter-type').value;
  const facilityId = document.getElementById('filter-facility').value;
  const status = document.getElementById('filter-status').value;
  
  filteredData = equipmentData.filter(eq => {
    if (searchTerm && !eq.name.toLowerCase().includes(searchTerm) && 
        !eq.code.toLowerCase().includes(searchTerm)) return false;
    if (categoryId && eq.equipment_category_id != categoryId) return false;
    if (classId && eq.equipment_class_id != classId) return false;
    if (typeId && eq.equipment_type_id != typeId) return false;
    if (facilityId && eq.facility_id != facilityId) return false;
    if (status && eq.status !== status) return false;
    return true;
  });
  
  renderEquipment(filteredData);
  updateActiveFilterTags();
}

function clearFilters() {
  document.getElementById('search-input').value = '';
  document.getElementById('filter-category').value = '';
  document.getElementById('filter-class').value = '';
  document.getElementById('filter-class').disabled = true;
  document.getElementById('filter-type').value = '';
  document.getElementById('filter-type').disabled = true;
  document.getElementById('filter-facility').value = '';
  document.getElementById('filter-status').value = '';
  applyFilters();
}

function updateActiveFilterTags() {
  const container = document.getElementById('active-filters');
  const tags = [];
  
  const categoryId = document.getElementById('filter-category').value;
  const classId = document.getElementById('filter-class').value;
  const typeId = document.getElementById('filter-type').value;
  const facilityId = document.getElementById('filter-facility').value;
  const status = document.getElementById('filter-status').value;
  
  if (categoryId) {
    const cat = isoData.categories.find(c => c.id == categoryId);
    if (cat) tags.push({ label: cat.category_name, clear: () => { document.getElementById('filter-category').value = ''; onCategoryFilterChange(); } });
  }
  if (classId) {
    const cls = isoData.classes.find(c => c.id == classId);
    if (cls) tags.push({ label: cls.class_name, clear: () => { document.getElementById('filter-class').value = ''; onClassFilterChange(); } });
  }
  if (facilityId) {
    const fac = facilities.find(f => f.id == facilityId);
    if (fac) tags.push({ label: fac.name, clear: () => { document.getElementById('filter-facility').value = ''; applyFilters(); } });
  }
  if (status) tags.push({ label: status.replace(/_/g, ' '), clear: () => { document.getElementById('filter-status').value = ''; applyFilters(); } });
  
  container.innerHTML = tags.map(t => `
    <span class="filter-tag">
      ${t.label}
      <button onclick="(${t.clear.toString()})()">×</button>
    </span>
  `).join('');
}

// Data loading
async function loadEquipment() {
  try {
    const response = await fetch('/api/equipment', {
      headers: getAuthHeaders()
    });
    
    if (response.status === 401) {
      handleAuthError();
      return;
    }
    
    const data = await response.json();
    
    if (data.success) {
      equipmentData = data.data?.equipment || [];
      filteredData = equipmentData;
      renderEquipment(filteredData);
      updateStats();
    } else {
      showErrorState('Failed to load assets');
    }
  } catch (error) {
    console.error('Error loading assets:', error);
    showErrorState('Failed to load assets');
  }
}

function updateStats() {
  const total = equipmentData.length;
  const operational = equipmentData.filter(e => e.status === 'operational').length;
  const maintenance = equipmentData.filter(e => e.status === 'maintenance').length;
  
  document.getElementById('total-count').textContent = total;
  document.getElementById('operational-count').textContent = operational;
  document.getElementById('maintenance-count').textContent = maintenance;
}

// Rendering
function renderEquipment(equipment) {
  const container = document.getElementById('equipment-list');
  
  if (!equipment || equipment.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        <p>No assets found</p>
        <p class="empty-hint">Try adjusting filters or add a new asset</p>
      </div>
    `;
    return;
  }
  
  container.innerHTML = equipment.map(eq => `
    <div class="asset-card" onclick="viewAssetDetail(${eq.id})">
      <div class="asset-header">
        <div class="asset-code-status">
          <span class="asset-code">${eq.code || 'N/A'}</span>
          <span class="asset-status ${eq.status}">${formatStatus(eq.status)}</span>
        </div>
        ${eq.criticality === 'critical' || eq.criticality === 'high' ? `
          <span class="criticality-badge ${eq.criticality}">${eq.criticality}</span>
        ` : ''}
      </div>
      <h3 class="asset-name">${escapeHtml(eq.name)}</h3>
      <div class="asset-iso-classification">
        ${eq.category_name ? `
          <span class="iso-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            ${eq.category_name}${eq.class_name ? ` > ${eq.class_name}` : ''}${eq.type_name ? ` > ${eq.type_name}` : ''}
          </span>
        ` : `
          <span class="iso-badge unassigned">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            Type not assigned
          </span>
        `}
      </div>
      <div class="asset-meta">
        <span class="asset-facility">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          ${eq.facility_name || 'Unknown Location'}
        </span>
      </div>
      ${isAdminUser ? `
      <div class="asset-actions" onclick="event.stopPropagation()">
        <button class="btn-icon" onclick="window.open('/api/assets/${eq.id}/qr-label.pdf', '_blank')" title="Print QR Label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </button>
        <button class="btn-icon" onclick="editEquipment(${eq.id})" title="Edit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
        <button class="btn-icon btn-danger" onclick="deleteEquipment(${eq.id})" title="Delete">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          </svg>
        </button>
      </div>
      ` : ''}
    </div>
  `).join('');
}

function showErrorState(message) {
  const container = document.getElementById('equipment-list');
  container.innerHTML = `
    <div class="error-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>${message}</p>
      <button class="btn btn-secondary btn-sm" onclick="loadEquipment()" style="margin-top: 12px;">
        Try Again
      </button>
    </div>
  `;
}

// Form handling
async function handleFormSubmit(e) {
  e.preventDefault();
  
  const formData = {
    name: document.getElementById('name').value,
    code: document.getElementById('code').value,
    facility_id: parseInt(document.getElementById('facility_id').value),
    location: document.getElementById('location').value,
    equipment_category_id: parseInt(document.getElementById('equipment_category_id').value) || null,
    equipment_class_id: parseInt(document.getElementById('equipment_class_id').value) || null,
    equipment_type_id: parseInt(document.getElementById('equipment_type_id').value) || null,
    manufacturer: document.getElementById('manufacturer').value,
    model: document.getElementById('model').value,
    serial_number: document.getElementById('serial_number').value,
    install_date: document.getElementById('install_date').value || null,
    status: document.getElementById('status').value,
    criticality: document.getElementById('criticality').value,
    description: document.getElementById('description').value
  };
  
  try {
    const url = editingId ? `/api/equipment/${editingId}` : '/api/equipment';
    const method = editingId ? 'PUT' : 'POST';
    
    const response = await fetch(url, {
      method: method,
      headers: getAuthHeaders(),
      body: JSON.stringify(formData)
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast(editingId ? 'Asset updated' : 'Asset created', 'success');
      closeModal();
      loadEquipment();
    } else {
      showToast(data.message || 'Failed to save', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error saving asset', 'error');
  }
}

// Modal functions
function openModal() {
  editingId = null;
  document.getElementById('modal-title').textContent = 'Add Asset';
  document.getElementById('equipment-form').reset();
  document.getElementById('equipment-id').value = '';
  document.getElementById('equipment_class_id').disabled = true;
  document.getElementById('equipment_type_id').disabled = true;
  document.getElementById('iso-preview').classList.add('hidden');
  document.getElementById('equipment-modal').classList.remove('hidden');
}

async function editEquipment(id) {
  try {
    const response = await fetch(`/api/equipment/${id}`, {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    
    if (data.success && data.data.equipment) {
      const eq = data.data.equipment;
      editingId = id;
      currentAssetId = id;
      
      document.getElementById('modal-title').textContent = 'Edit Asset';
      document.getElementById('equipment-id').value = id;
      document.getElementById('name').value = eq.name;
      document.getElementById('code').value = eq.code;
      document.getElementById('facility_id').value = eq.facility_id;
      document.getElementById('location').value = eq.location || '';
      document.getElementById('manufacturer').value = eq.manufacturer || '';
      document.getElementById('model').value = eq.model || '';
      document.getElementById('serial_number').value = eq.serial_number || '';
      document.getElementById('install_date').value = eq.install_date || '';
      document.getElementById('status').value = eq.status;
      document.getElementById('criticality').value = eq.criticality;
      document.getElementById('description').value = eq.description || '';
      
      // Load ISO classification
      if (eq.equipment_category_id) {
        document.getElementById('equipment_category_id').value = eq.equipment_category_id;
        await onCategoryChange();
        
        if (eq.equipment_class_id) {
          document.getElementById('equipment_class_id').value = eq.equipment_class_id;
          await onClassChange();
          
          if (eq.equipment_type_id) {
            document.getElementById('equipment_type_id').value = eq.equipment_type_id;
            updateIsoPreview();
          }
        }
      }
      
      document.getElementById('equipment-modal').classList.remove('hidden');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error loading asset', 'error');
  }
}

function closeModal() {
  document.getElementById('equipment-modal').classList.add('hidden');
  editingId = null;
}

// Asset detail modal
async function viewAssetDetail(id) {
  currentAssetId = id;
  
  try {
    const response = await fetch(`/api/equipment/${id}`, {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    
    if (data.success && data.data.equipment) {
      const eq = data.data.equipment;
      const content = document.getElementById('asset-detail-content');
      
      content.innerHTML = `
        <div class="asset-detail-header">
          <span class="asset-detail-code">${eq.code}</span>
          <span class="asset-status ${eq.status}">${formatStatus(eq.status)}</span>
        </div>
        <h2 class="asset-detail-name">${escapeHtml(eq.name)}</h2>
        <p class="asset-detail-facility">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          ${eq.facility_name || 'Unknown Location'}
          ${eq.location ? `• ${eq.location}` : ''}
        </p>
        
        <div class="detail-section">
          <h4>ISO 14224 Classification</h4>
          ${eq.category_name ? `
            <div class="iso-detail-path">
              <div class="iso-level">
                <span class="iso-label">Category</span>
                <span class="iso-value">${eq.category_name}</span>
              </div>
              <div class="iso-arrow">→</div>
              <div class="iso-level">
                <span class="iso-label">Class</span>
                <span class="iso-value">${eq.class_name || 'Not assigned'}</span>
              </div>
              <div class="iso-arrow">→</div>
              <div class="iso-level">
                <span class="iso-label">Type</span>
                <span class="iso-value">${eq.type_name || 'Not assigned'}</span>
              </div>
            </div>
          ` : `
            <div class="iso-unassigned">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <p>Equipment type not assigned</p>
              <button class="btn btn-sm btn-primary" onclick="closeDetailModal(); editEquipment(${eq.id});">Assign Type</button>
            </div>
          `}
        </div>
        
        ${eq.manufacturer || eq.model ? `
          <div class="detail-section">
            <h4>Technical Details</h4>
            <div class="detail-grid">
              ${eq.manufacturer ? `<div class="detail-item"><span>Manufacturer:</span> ${eq.manufacturer}</div>` : ''}
              ${eq.model ? `<div class="detail-item"><span>Model:</span> ${eq.model}</div>` : ''}
              ${eq.serial_number ? `<div class="detail-item"><span>Serial:</span> ${eq.serial_number}</div>` : ''}
            </div>
          </div>
        ` : ''}
      `;
      
      document.getElementById('asset-detail-modal').classList.remove('hidden');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error loading asset details', 'error');
  }
}

function closeDetailModal() {
  document.getElementById('asset-detail-modal').classList.add('hidden');
  currentAssetId = null;
}

function startInspection() {
  if (currentAssetId) {
    window.location.href = `/inspection?equipment_id=${currentAssetId}`;
  }
}

function createWorkOrder() {
  if (currentAssetId) {
    window.location.href = `/work-orders?create=${currentAssetId}`;
  }
}

async function deleteEquipment(id) {
  if (!confirm('Are you sure you want to delete this asset?')) return;
  
  try {
    const response = await fetch(`/api/equipment/${id}`, {
      method: 'DELETE',
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast('Asset deleted', 'success');
      loadEquipment();
    } else {
      showToast(data.message || 'Failed to delete', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error deleting asset', 'error');
  }
}

// Utilities
function formatStatus(status) {
  if (!status) return 'Unknown';
  return status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function debounce(func, wait) {
  let timeout;
  return function executedFunction(...args) {
    const later = () => {
      clearTimeout(timeout);
      func(...args);
    };
    clearTimeout(timeout);
    timeout = setTimeout(later, wait);
  };
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function handleAuthError() {
  localStorage.clear();
  window.location.href = '/login';
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}
</script>

