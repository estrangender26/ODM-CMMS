<%- include('../partials/header', { title: title, user: user }) %>

<div class="page admin-page">
  <!-- Header -->
  <header class="page-header">
    <a href="/admin" class="btn-back" title="Back to Admin">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </a>
    <h1>Reports & Analytics</h1>
    <div class="header-actions">
      <% if (user && user.role !== 'admin') { %>
      <span class="facility-badge" style="background: #e0f2fe; color: #0369a1; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 500;">
        <%= user.facility_name || 'Your Facility' %>
      </span>
      <% } %>
      <button class="btn-icon" id="refresh-btn" onclick="refreshAllReports()" title="Refresh All">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 4v6h-6M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
      </button>
    </div>
  </header>
  
  <% if (user && user.role !== 'admin') { %>
  <div class="info-banner">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px; flex-shrink: 0;">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <div>
      <strong>Filtered View:</strong> You are viewing data for <strong><%= user.facility_name || 'your assigned facility' %></strong> only. 
      <% if (!user.facility_id) { %>
      <span style="color: var(--danger);">⚠️ You are not assigned to a facility. Please contact an administrator.</span>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- Date Range Filter -->
  <div class="filter-bar">
    <div class="filter-group">
      <label>From</label>
      <input type="date" id="date-from" value="<%= new Date(Date.now() - 30*24*60*60*1000).toISOString().split('T')[0] %>">
    </div>
    <div class="filter-group">
      <label>To</label>
      <input type="date" id="date-to" value="<%= new Date().toISOString().split('T')[0] %>">
    </div>
    <button class="btn btn-primary btn-sm" onclick="applyDateFilter()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      Apply
    </button>
    <button class="btn btn-secondary btn-sm" onclick="resetDateFilter()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;">
        <path d="M3 12a9 9 0 109-9 9.75 9.75 0 00-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
      </svg>
      Reset
    </button>
  </div>
  
  <!-- Debug Output -->
  <div id="debug-output" style="display:none; background:#1e293b; color:#22c55e; padding:12px; margin:0 16px 16px; border-radius:8px; font-family:monospace; font-size:12px; max-height:200px; overflow-y:auto;"></div>

  <!-- Reports Grid -->
  <div class="reports-grid">
    <!-- Work Order Summary -->
    <div class="report-card" onclick="showReport('work-orders')">
      <div class="report-header">
        <div class="report-icon blue">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 11l3 3L22 4"/>
            <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
          </svg>
        </div>
        <% if (user && user.role !== 'operator') { %>>
        <div class="report-actions">
          <button class="btn-icon btn-sm" onclick="event.stopPropagation(); exportReport('work-orders')" title="Export CSV">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          </button>
        </div>
        <% } %>
      </div>
      <h3>Work Order Summary</h3>
      <p>Status, priority, and completion metrics</p>
      <div class="report-preview" id="wo-preview">
        <span class="loading-dots">Loading...</span>
      </div>
    </div>

    <!-- Equipment Report -->
    <div class="report-card" onclick="showReport('equipment')">
      <div class="report-header">
        <div class="report-icon green">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <% if (user && user.role !== 'operator') { %>
        <div class="report-actions">
          <button class="btn-icon btn-sm" onclick="event.stopPropagation(); exportReport('equipment')" title="Export CSV">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          </button>
        </div>
        <% } %>
      </div>
      <h3>Equipment Status</h3>
      <p>Maintenance history by equipment</p>
      <div class="report-preview" id="equipment-preview">
        <span class="loading-dots">Loading...</span>
      </div>
    </div>

    <!-- Schedule Compliance -->
    <div class="report-card" onclick="showReport('compliance')">
      <div class="report-header">
        <div class="report-icon orange">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <span class="badge urgent" id="overdue-badge" style="display:none">0</span>
      </div>
      <h3>Schedule Compliance</h3>
      <p>Overdue and upcoming maintenance</p>
      <div class="report-preview" id="compliance-preview">
        <span class="loading-dots">Loading...</span>
      </div>
    </div>

    <!-- Technician Performance -->
    <div class="report-card" onclick="showReport('technicians')">
      <div class="report-header">
        <div class="report-icon purple">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <% if (user && user.role !== 'operator') { %>
        <div class="report-actions">
          <button class="btn-icon btn-sm" onclick="event.stopPropagation(); exportReport('technicians')" title="Export CSV">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          </button>
        </div>
        <% } %>
      </div>
      <h3>Technician Performance</h3>
      <p>Work completion by operator</p>
      <div class="report-preview" id="tech-preview">
        <span class="loading-dots">Loading...</span>
      </div>
    </div>

    <!-- Trends Analysis -->
    <div class="report-card" onclick="showReport('trends')">
      <div class="report-header">
        <div class="report-icon teal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
        </div>
      </div>
      <h3>Trends Analysis</h3>
      <p>Work orders over time</p>
      <div class="report-preview" id="trends-preview">
        <span class="loading-dots">Loading...</span>
      </div>
    </div>

    <!-- Priority Breakdown -->
    <div class="report-card" onclick="showReport('priority')">
      <div class="report-header">
        <div class="report-icon red">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
      </div>
      <h3>Priority Analysis</h3>
      <p>Urgent vs normal work distribution</p>
      <div class="report-preview" id="priority-preview">
        <span class="loading-dots">Loading...</span>
      </div>
    </div>
  </div>

  <!-- Report Detail Modal -->
  <div class="modal hidden" id="report-modal">
    <div class="modal-overlay" onclick="closeReport()"></div>
    <div class="modal-content report-modal-content">
      <div class="modal-header">
        <h2 id="report-title">Report</h2>
        <div class="modal-actions">
          <% if (user && user.role !== 'operator') { %>
          <button class="btn btn-secondary btn-sm" onclick="exportCurrentReport()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Export CSV
          </button>
          <% } %>
          <button class="btn-close" onclick="closeReport()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="modal-body report-body" id="report-content">
        <div class="loading-state">
          <div class="spinner"></div>
          <p>Loading report...</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Global state
let currentReportType = null;
let currentReportData = null;
let dateFrom = document.getElementById('date-from').value;
let dateTo = document.getElementById('date-to').value;

// Load all previews on page load
document.addEventListener('DOMContentLoaded', () => {
  console.log('[Reports] Page loaded, initializing...');
  loadAllPreviews().catch(err => {
    console.error('[Reports] Failed to load previews:', err);
    showToast('Some reports failed to load. Check console.', 'error');
  });
});

function applyDateFilter() {
  dateFrom = document.getElementById('date-from').value;
  dateTo = document.getElementById('date-to').value;
  loadAllPreviews();
}

function resetDateFilter() {
  const today = new Date();
  const thirtyDaysAgo = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000);
  
  document.getElementById('date-to').value = today.toISOString().split('T')[0];
  document.getElementById('date-from').value = thirtyDaysAgo.toISOString().split('T')[0];
  
  applyDateFilter();
}

function refreshAllReports() {
  const btn = document.getElementById('refresh-btn');
  btn.style.animation = 'spin 1s linear';
  loadAllPreviews().then(() => {
    setTimeout(() => btn.style.animation = '', 1000);
  });
}

async function loadAllPreviews() {
  await Promise.all([
    loadWorkOrderPreview(),
    loadEquipmentPreview(),
    loadCompliancePreview(),
    loadTechnicianPreview(),
    loadTrendsPreview(),
    loadPriorityPreview()
  ]);
}

// ==================== PREVIEW LOADERS ====================

async function loadWorkOrderPreview() {
  const container = document.getElementById('wo-preview');
  try {
    console.log('[Reports] Loading work order preview...');
    const params = new URLSearchParams({ start_date: dateFrom, end_date: dateTo });
    const response = await fetch(`/api/reports/work-orders/summary?${params}`, {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    console.log('[Reports] Response status:', response.status);
    const result = await response.json();
    console.log('[Reports] Response:', result);
    
    if (!response.ok || !result.success) {
      throw new Error(result.message || `HTTP ${response.status}`);
    }
    
    const data = result.data;
    const total = data.metrics?.total || 0;
    const completed = data.metrics?.completed || 0;
    const rate = total > 0 ? Math.round((completed / total) * 100) : 0;
    
    container.innerHTML = `
      <div class="preview-stats">
        <div class="preview-stat">
          <span class="value">${total}</span>
          <span class="label">Total</span>
        </div>
        <div class="preview-stat">
          <span class="value">${completed}</span>
          <span class="label">Done</span>
        </div>
        <div class="preview-stat">
          <span class="value">${rate}%</span>
          <span class="label">Rate</span>
        </div>
      </div>
    `;
  } catch (error) {
    console.error('[Reports] Work order preview error:', error);
    container.innerHTML = `<span class="error-text" onclick="alert('Error: ${error.message.replace(/'/g, "\\'")}')">Failed to load (click for details)</span>`;
  }
}

async function loadEquipmentPreview() {
  const container = document.getElementById('equipment-preview');
  try {
    console.log('[Reports] Loading equipment preview...');
    const response = await fetch('/api/reports/equipment', {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const { data } = await response.json();
    console.log('[Reports] Equipment data:', data);
    
    const total = data.equipment?.length || 0;
    const withWorkOrders = data.equipment?.filter(e => e.total_work_orders > 0).length || 0;
    
    container.innerHTML = `
      <div class="preview-stats">
        <div class="preview-stat">
          <span class="value">${total}</span>
          <span class="label">Equipment</span>
        </div>
        <div class="preview-stat">
          <span class="value">${withWorkOrders}</span>
          <span class="label">Active</span>
        </div>
      </div>
    `;
  } catch (error) {
    console.error('[Reports] Equipment preview error:', error);
    container.innerHTML = `<span class="error-text">Failed to load</span>`;
  }
}

async function loadCompliancePreview() {
  const container = document.getElementById('compliance-preview');
  try {
    console.log('[Reports] Loading compliance preview...');
    const response = await fetch('/api/reports/schedule-compliance', {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const { data } = await response.json();
    console.log('[Reports] Compliance data:', data);
    
    const overdue = data.summary?.overdue_count || 0;
    const dueThisWeek = data.summary?.due_this_week || 0;
    
    // Update badge
    const badge = document.getElementById('overdue-badge');
    if (badge && overdue > 0) {
      badge.textContent = overdue;
      badge.style.display = 'inline-block';
    }
    
    container.innerHTML = `
      <div class="preview-stats">
        <div class="preview-stat ${overdue > 0 ? 'urgent' : ''}">
          <span class="value">${overdue}</span>
          <span class="label">Overdue</span>
        </div>
        <div class="preview-stat">
          <span class="value">${dueThisWeek}</span>
          <span class="label">This Week</span>
        </div>
      </div>
    `;
  } catch (error) {
    container.innerHTML = `<span class="error-text">Failed to load</span>`;
  }
}

async function loadTechnicianPreview() {
  const container = document.getElementById('tech-preview');
  try {
    console.log('[Reports] Loading technician preview...');
    const params = new URLSearchParams({ start_date: dateFrom, end_date: dateTo });
    const response = await fetch(`/api/reports/technicians?${params}`, {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const { data } = await response.json();
    console.log('[Reports] Technician data:', data);
    
    const topPerformer = data?.sort((a, b) => (b.completed || 0) - (a.completed || 0))[0];
    
    container.innerHTML = `
      <div class="preview-stats">
        <div class="preview-stat">
          <span class="value">${data?.length || 0}</span>
          <span class="label">Staff</span>
        </div>
        <div class="preview-stat">
          <span class="value">${topPerformer?.completed || 0}</span>
          <span class="label">Top Performer</span>
        </div>
      </div>
      ${topPerformer ? `<small style="color: #64748b; display: block; margin-top: 8px;">${topPerformer.full_name}</small>` : ''}
    `;
  } catch (error) {
    container.innerHTML = `<span class="error-text">Failed to load</span>`;
  }
}

async function loadTrendsPreview() {
  const container = document.getElementById('trends-preview');
  try {
    console.log('[Reports] Loading trends preview...');
    const response = await fetch('/api/reports/trends?months=6', {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const { data } = await response.json();
    console.log('[Reports] Trends data:', data);
    
    const recent = data?.slice(-3) || [];
    const total = recent.reduce((sum, r) => sum + (r.total_created || 0), 0);
    const avg = recent.length > 0 ? Math.round(total / recent.length) : 0;
    
    // Simple bar chart
    const max = Math.max(...recent.map(r => r.total_created || 0), 1);
    const bars = recent.map(r => {
      const height = ((r.total_created || 0) / max) * 30;
      return `<div class="mini-bar" style="height: ${height}px;" title="${r.period}: ${r.total_created}"></div>`;
    }).join('');
    
    container.innerHTML = `
      <div class="mini-chart">${bars}</div>
      <small style="color: #64748b;">Avg: ${avg}/month</small>
    `;
  } catch (error) {
    container.innerHTML = `<span class="error-text">Failed to load</span>`;
  }
}

async function loadPriorityPreview() {
  const container = document.getElementById('priority-preview');
  try {
    console.log('[Reports] Loading priority preview...');
    const params = new URLSearchParams({ start_date: dateFrom, end_date: dateTo });
    const response = await fetch(`/api/reports/work-orders/summary?${params}`, {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    const result = await response.json();
    if (!response.ok || !result.success) {
      throw new Error(result.message || `HTTP ${response.status}`);
    }
    
    const data = result.data;
    const urgent = data.priority_breakdown?.find(p => p.priority === 'urgent')?.count || 0;
    const high = data.priority_breakdown?.find(p => p.priority === 'high')?.count || 0;
    const total = data.metrics?.total || 1;
    
    const urgentPercent = Math.round((urgent / total) * 100);
    
    container.innerHTML = `
      <div class="priority-bars">
        <div class="priority-bar urgent" style="width: ${urgentPercent}%"></div>
      </div>
      <div class="preview-stats">
        <div class="preview-stat">
          <span class="value urgent">${urgent}</span>
          <span class="label">Urgent</span>
        </div>
        <div class="preview-stat">
          <span class="value">${high}</span>
          <span class="label">High</span>
        </div>
      </div>
    `;
  } catch (error) {
    console.error('[Reports] Priority preview error:', error);
    container.innerHTML = `<span class="error-text" onclick="alert('Error: ${error.message.replace(/'/g, "\\'")}')">Failed to load</span>`;
  }
}

// ==================== FULL REPORT MODAL ====================

async function showReport(type) {
  currentReportType = type;
  const modal = document.getElementById('report-modal');
  const title = document.getElementById('report-title');
  const content = document.getElementById('report-content');
  
  modal.classList.remove('hidden');
  content.innerHTML = '<div class="loading-state"><div class="spinner"></div><p>Loading report...</p></div>';
  
  switch(type) {
    case 'work-orders':
      title.textContent = 'Work Order Summary';
      await loadWorkOrderReport(content);
      break;
    case 'equipment':
      title.textContent = 'Equipment Status Report';
      await loadEquipmentReport(content);
      break;
    case 'compliance':
      title.textContent = 'Schedule Compliance';
      await loadComplianceReport(content);
      break;
    case 'technicians':
      title.textContent = 'Technician Performance';
      await loadTechnicianReport(content);
      break;
    case 'trends':
      title.textContent = 'Trends Analysis';
      await loadTrendsReport(content);
      break;
    case 'priority':
      title.textContent = 'Priority Analysis';
      await loadPriorityReport(content);
      break;
  }
}

function closeReport() {
  document.getElementById('report-modal').classList.add('hidden');
  currentReportType = null;
  currentReportData = null;
}

// ==================== FULL REPORT LOADERS ====================

async function loadWorkOrderReport(container) {
  try {
    const params = new URLSearchParams({ start_date: dateFrom, end_date: dateTo });
    const response = await fetch(`/api/reports/work-orders/summary?${params}`, {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    if (!response.ok) throw new Error('Failed to load');
    const { data } = await response.json();
    currentReportData = data;
    
    const total = data.metrics?.total || 0;
    const completed = data.metrics?.completed || 0;
    const cancelled = data.metrics?.cancelled || 0;
    const avgHours = Math.round(data.metrics?.avg_actual_hours || 0);
    
    container.innerHTML = `
      <div class="report-section">
        <h3>Key Metrics</h3>
        <div class="metrics-grid">
          <div class="metric">
            <span class="metric-value">${total}</span>
            <span class="metric-label">Total Orders</span>
          </div>
          <div class="metric">
            <span class="metric-value">${completed}</span>
            <span class="metric-label">Completed</span>
          </div>
          <div class="metric">
            <span class="metric-value">${Math.round((completed / total * 100) || 0)}%</span>
            <span class="metric-label">Completion Rate</span>
          </div>
          <div class="metric">
            <span class="metric-value">${avgHours}h</span>
            <span class="metric-label">Avg Hours</span>
          </div>
        </div>
      </div>
      
      <div class="report-columns">
        <div class="report-section">
          <h3>By Status</h3>
          <div class="simple-list">
            ${data.status_breakdown?.map(item => `
              <div class="list-item">
                <span class="status-badge ${item.status}">${item.status.replace(/_/g, ' ')}</span>
                <span class="count">${item.count}</span>
              </div>
            `).join('') || '<p>No data</p>'}
          </div>
        </div>
        
        <div class="report-section">
          <h3>By Priority</h3>
          <div class="simple-list">
            ${data.priority_breakdown?.map(item => `
              <div class="list-item">
                <span class="priority-badge ${item.priority}">${item.priority}</span>
                <span class="count">${item.count}</span>
              </div>
            `).join('') || '<p>No data</p>'}
          </div>
        </div>
        
        <div class="report-section">
          <h3>By Type</h3>
          <div class="simple-list">
            ${data.type_breakdown?.map(item => `
              <div class="list-item">
                <span>${item.wo_type || 'Unknown'}</span>
