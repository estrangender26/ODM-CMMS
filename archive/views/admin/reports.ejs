// ==================== EXPORT FUNCTIONS ====================

function exportReport(type) {
  let data, filename;
  
  switch(type) {
    case 'work-orders':
      filename = 'work-order-summary.csv';
      break;
    case 'equipment':
      filename = 'equipment-report.csv';
      break;
    case 'technicians':
      filename = 'technician-performance.csv';
      break;
    default:
      filename = 'report.csv';
  }
  
  // Trigger download after data is loaded
  showReport(type);
  setTimeout(() => exportCurrentReport(filename), 500);
}

function exportCurrentReport(filename) {
  if (!currentReportData) {
    showToast('No data to export', 'error');
    return;
  }
  
  let csv = '';
  
  // Convert data to CSV based on report type
  if (currentReportType === 'work-orders') {
    csv = 'Status,Count\n';
    csv += currentReportData.status_breakdown?.map(r => `${r.status},${r.count}`).join('\n') || '';
    csv += '\n\nPriority,Count\n';
    csv += currentReportData.priority_breakdown?.map(r => `${r.priority},${r.count}`).join('\n') || '';
  } else if (currentReportType === 'equipment') {
    csv = 'Code,Name,Facility,Total WO,Completed,Pending\n';
    csv += currentReportData.equipment?.map(e => 
      `${e.code},"${e.name}",${e.facility_name},${e.total_work_orders},${e.completed_work_orders},${e.pending_work_orders}`
    ).join('\n') || '';
  } else if (currentReportType === 'technicians') {
    csv = 'Name,Role,Assigned,Completed,Pending,Avg Hours\n';
    csv += currentReportData?.map(t => 
      `"${t.full_name}",${t.role},${t.total_assigned},${t.completed},${t.pending},${Math.round(t.avg_hours_per_job || 0)}`
    ).join('\n') || '';
  } else if (currentReportType === 'trends') {
    csv = 'Period,Created,Completed,Urgent\n';
    csv += currentReportData?.map(t => 
      `${t.period},${t.total_created},${t.completed},${t.urgent_count}`
    ).join('\n') || '';
  }
  
  // Download
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = window.URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename || `${currentReportType}-report.csv`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  window.URL.revokeObjectURL(url);
  
  showToast('Report exported', 'success');
}

function getAuthHeaders() {
  return {
    'Authorization': `Bearer ${localStorage.getItem('token')}`,
    'Content-Type': 'application/json'
  };
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}

// Debug logging
function debugLog(msg) {
  console.log(msg);
  const debugDiv = document.getElementById('debug-output');
  if (debugDiv) {
    debugDiv.style.display = 'block';
    debugDiv.innerHTML += msg + '<br>';
  }
}

// Test API connectivity
async function testAPI() {
  debugLog('Testing API...');
  try {
    const response = await fetch('/api/reports/work-orders/summary', {
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    debugLog(`Response status: ${response.status}`);
    
    if (response.ok) {
      const data = await response.json();
      debugLog(`SUCCESS: ${JSON.stringify(data).substring(0, 200)}...`);
    } else {
      const text = await response.text();
      debugLog(`ERROR: ${text.substring(0, 200)}`);
    }
  } catch (err) {
    debugLog(`EXCEPTION: ${err.message}`);
  }
}
