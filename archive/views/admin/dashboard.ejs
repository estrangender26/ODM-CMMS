    <!-- Quick Stats -->
    <section class="section">
      <h2>System Overview</h2>
      <div class="overview-grid" id="overview-grid">
        <div class="overview-card">
          <span class="overview-value loading" id="total-equipment">-</span>
          <span class="overview-label">Equipment</span>
        </div>
        <div class="overview-card">
          <span class="overview-value loading" id="pending-wo">-</span>
          <span class="overview-label">Pending WO</span>
        </div>
        <div class="overview-card">
          <span class="overview-value loading" id="overdue-schedules">-</span>
          <span class="overview-label">Overdue</span>
        </div>
      </div>
    </section>
  </div>
</div>

<script>
// ============================================
// ADMIN DASHBOARD
// ============================================
document.addEventListener('DOMContentLoaded', () => {
  checkAuth();
  loadOverviewData();
});

async function loadOverviewData() {
  setStatsLoading(true);
  
  try {
    console.log('[Admin] Loading overview data...');
    
    // Equipment stats
    const eqRes = await fetch('/api/equipment/stats', {
      headers: getAuthHeaders()
    });
    
    if (eqRes.status === 401) {
      handleAuthError();
      return;
    }
    
    const eqData = await eqRes.json();
    console.log('[Admin] Equipment stats:', eqData);
    
    if (eqData.success && eqData.data?.stats) {
      const totalEquipment = parseInt(eqData.data.stats.total) || 0;
      updateStatElement('total-equipment', totalEquipment);
    } else {
      showStatError('total-equipment');
    }
    
    // Work order stats
    const woRes = await fetch('/api/work-orders/stats', {
      headers: getAuthHeaders()
    });
    
    const woData = await woRes.json();
    console.log('[Admin] Work order stats:', woData);
    
    if (woData.success && woData.data?.stats) {
      const stats = woData.data.stats;
      const pending = (parseInt(stats.assigned) || 0) + (parseInt(stats.in_progress) || 0);
      updateStatElement('pending-wo', pending);
    } else {
      showStatError('pending-wo');
    }
    
    // Overdue schedules
    const schRes = await fetch('/api/schedules/overdue', {
      headers: getAuthHeaders()
    });
    
    const schData = await schRes.json();
    console.log('[Admin] Overdue schedules:', schData);
    
    if (schData.success && schData.data?.schedules) {
      const overdueCount = schData.data.schedules.length || 0;
      updateStatElement('overdue-schedules', overdueCount);
    } else {
      showStatError('overdue-schedules');
    }
    
  } catch (error) {
    console.error('[Admin] Error loading overview:', error);
    showStatError('total-equipment');
    showStatError('pending-wo');
    showStatError('overdue-schedules');
    showToast('Failed to load some data', 'error');
  } finally {
    setStatsLoading(false);
  }
}

function updateStatElement(id, value) {
  const el = document.getElementById(id);
  if (el) {
    el.textContent = value;
    el.classList.remove('loading');
    el.style.color = '';
  }
}

function showStatError(id) {
  const el = document.getElementById(id);
  if (el) {
    el.textContent = '!';
    el.classList.remove('loading');
    el.style.color = 'var(--danger)';
  }
}

function setStatsLoading(loading) {
  document.querySelectorAll('.overview-value').forEach(el => {
    if (loading) {
      el.classList.add('loading');
    } else {
      el.classList.remove('loading');
    }
  });
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function handleAuthError() {
  localStorage.clear();
  window.location.href = '/login';
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  if (!container) return;
  
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  
  setTimeout(() => {
    toast.classList.add('fade-out');
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}
</script>

<%- include('../partials/footer') %>
