<%- include('partials/header', { title: title, user: user }) %>

<div class="page dashboard-page">
  <header class="page-header">
    <button class="btn-back" onclick="history.back()" title="Go Back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </button>
    <h1>Dashboard</h1>
    <div class="header-actions">
      <button class="btn-icon" id="refresh-btn" title="Refresh">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 4v6h-6M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
      </button>
    </div>
  </header>

  <div class="dashboard-content">
    <!-- System Overview Section - Different views for Admin vs Others -->
    <% const isAdminOrSupervisor = user && (user.role === 'admin' || user.role === 'supervisor'); %>
    <% const isSystemAdmin = user && user.username === 'admin'; %>
    
    <% if (isSystemAdmin) { %>
    <!-- System Administrator Dashboard -->
    <section class="section admin-dashboard-section">
      <div class="section-header">
        <h2>System Overview</h2>
        <a href="/work-orders?filter=all" class="view-all">View All Tasks</a>
      </div>
      
      <!-- Admin Stats Grid -->
      <div class="admin-stats-grid" id="admin-stats-grid">
        <div class="admin-stat-card">
          <div class="admin-stat-icon users">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <div class="admin-stat-info">
            <span class="admin-stat-value loading" id="admin-user-count">-</span>
            <span class="admin-stat-label">Total Users</span>
          </div>
        </div>
        
        <div class="admin-stat-card">
          <div class="admin-stat-icon equipment">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div class="admin-stat-info">
            <span class="admin-stat-value loading" id="admin-equipment-count">-</span>
            <span class="admin-stat-label">Equipment</span>
          </div>
        </div>
        
        <div class="admin-stat-card">
          <div class="admin-stat-icon unassigned">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div class="admin-stat-info">
            <span class="admin-stat-value loading" id="admin-unassigned-count">-</span>
            <span class="admin-stat-label">Unassigned Tasks</span>
          </div>
        </div>
        
        <div class="admin-stat-card">
          <div class="admin-stat-icon facilities">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div class="admin-stat-info">
            <span class="admin-stat-value loading" id="admin-facility-count">-</span>
            <span class="admin-stat-label">Facilities</span>
          </div>
        </div>
      </div>
      
      <!-- Recent Activity -->
      <div class="admin-activity-section" style="margin-top: var(--space-5);">
        <h3 style="font-size: var(--text-sm); color: var(--gray-500); margin-bottom: var(--space-3);">Recent System Activity</h3>
        <div class="admin-activity-list" id="admin-activity-list">
          <div class="loading-skeleton">
            <div class="skeleton-item"></div>
            <div class="skeleton-item"></div>
            <div class="skeleton-item"></div>
          </div>
        </div>
      </div>
      
      <!-- Admin Quick Actions -->
      <div class="admin-quick-actions" style="margin-top: var(--space-5);">
        <h3 style="font-size: var(--text-sm); color: var(--gray-500); margin-bottom: var(--space-3);">Management</h3>
        <div class="admin-action-grid">
          <a href="/admin/users" class="admin-action-card">
            <div class="admin-action-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
              </svg>
            </div>
            <span>User Management</span>
          </a>
          
          <a href="/admin" class="admin-action-card">
            <div class="admin-action-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <span>Admin Panel</span>
          </a>
          
          <a href="/work-orders?filter=all" class="admin-action-card">
            <div class="admin-action-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
              </svg>
            </div>
            <span>All Work Orders</span>
          </a>
          
          <a href="/equipment" class="admin-action-card">
            <div class="admin-action-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <span>Equipment</span>
          </a>
        </div>
      </div>
    </section>
    <% } else { %>
    <!-- Regular User Dashboard -->
    <section class="section">
      <div class="section-header">
        <h2>My Tasks</h2>
        <% if (isAdminOrSupervisor) { %>
        <a href="/work-orders?filter=all" class="view-all">View All System Tasks</a>
        <% } %>
      </div>
      <div class="work-order-list" id="today-wo-list">
        <div class="loading-skeleton">
          <div class="skeleton-item"></div>
          <div class="skeleton-item"></div>
          <div class="skeleton-item"></div>
        </div>
      </div>
    </section>
    <% } %>

    <!-- Quick Actions - Only for non-system-admin users -->
    <% if (!isSystemAdmin) { %>
    <section class="section">
      <h2>Quick Actions</h2>
      <div class="quick-actions">
        <div class="action-card" onclick="navigateTo('/work-orders?filter=my')">
          <div class="action-icon blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 11l3 3L22 4"/>
              <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
          </div>
          <span>My Tasks</span>
        </div>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor')) { %>
        <div class="action-card" onclick="navigateTo('/work-orders?filter=all')">
          <div class="action-icon teal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <span>All Tasks</span>
        </div>
        <% } %>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor')) { %>
        <div class="action-card" onclick="navigateTo('/admin/schedules')">
          <div class="action-icon orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </div>
          <span>New Schedule</span>
        </div>
        <% } %>
        
        <div class="action-card" onclick="navigateTo('/equipment')">
          <div class="action-icon green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <span>Equipment</span>
        </div>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor' || user.role === 'operator')) { %>
        <div class="action-card" onclick="navigateTo('/admin/reports')">
          <div class="action-icon red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 3v18h18"/>
              <path d="M18 17V9"/>
              <path d="M13 17V5"/>
              <path d="M8 17v-3"/>
            </svg>
          </div>
          <span>Reports</span>
        </div>
        <% } %>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor')) { %>
        <div class="action-card" onclick="navigateTo('/admin')">
          <div class="action-icon purple">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <span>Admin</span>
        </div>
        <% } %>
      </div>
    </section>
    <% } %>
  </div>
</div>

<script>
// ============================================
// DASHBOARD STATE
// ============================================
const dashboardState = {
  isLoading: false,
  stats: null,
  workOrders: [],
  filteredWorkOrders: [],
  activeFilter: 'all'
};

// ============================================
// INITIALIZATION
// ============================================
document.addEventListener('DOMContentLoaded', () => {
  checkAuth();
  initEventListeners();
  
  // Check if user is System Admin and load appropriate view
  const user = JSON.parse(localStorage.getItem('user') || '{}');
  if (user.username === 'admin') {
    loadAdminDashboardData();
  } else {
    loadDashboardData();
  }
});

function initEventListeners() {
  // Refresh button with loading state
  const refreshBtn = document.getElementById('refresh-btn');
  console.log('[Dashboard] Refresh button found:', !!refreshBtn);
  
  if (refreshBtn) {
    refreshBtn.addEventListener('click', async () => {
      console.log('[Dashboard] Refresh clicked, isLoading:', dashboardState.isLoading);
      
      // Force reset loading state if stuck
      if (dashboardState.isLoading) {
        console.log('[Dashboard] Resetting stuck loading state');
        dashboardState.isLoading = false;
      }
      
      // Add spinning animation
      refreshBtn.style.animation = 'spin 1s linear infinite';
      
      // Clear current stats to show loading
      setStatsLoading(true);
      
      console.log('[Dashboard] Calling loadDashboardData...');
      try {
        await loadDashboardData();
      } catch (e) {
        console.error('[Dashboard] Refresh failed:', e);
      } finally {
        refreshBtn.style.animation = '';
        console.log('[Dashboard] Refresh complete');
      }
    });
  }
}

// ============================================
// DATA LOADING
// ============================================
async function loadDashboardData() {
  if (dashboardState.isLoading) {
    console.log('[Dashboard] Already loading, skipping');
    return;
  }
  
  const user = JSON.parse(localStorage.getItem('user') || '{}');
  const isSystemAdmin = user.username === 'admin';
  
  console.log('[Dashboard] Starting load...');
  dashboardState.isLoading = true;
  
  // Only show loading state for non-admin users (admin has different UI)
  if (!isSystemAdmin) {
    setStatsLoading(true);
  }
  
  // Clear current data to force visual update
  dashboardState.stats = null;
  dashboardState.workOrders = [];
  
  try {
    console.log('[Dashboard] Loading dashboard data...');
    
    // System Admin uses different data loading (loadAdminDashboardData)
    if (isSystemAdmin) {
      await loadAdminDashboardData();
      return;
    }
    
    // Load stats (with cache-busting)
    const statsRes = await fetch('/api/work-orders/stats?_=' + Date.now(), {
      headers: getAuthHeaders()
    });
    
    if (statsRes.status === 401) {
      handleAuthError();
      return;
    }
    
    const statsData = await statsRes.json();
    console.log('[Dashboard] Stats API response:', statsData);
    
    if (statsData.success && statsData.data?.stats) {
      const stats = statsData.data.stats;
      dashboardState.stats = stats;
      
      // For admin/supervisor: use system-wide stats
      // For operator: stats will be calculated from their work orders in loadTodayWorkOrders
      if (user.role === 'admin' || user.role === 'supervisor') {
        // Update stats display (convert strings to numbers, handle NULL)
        const totalCount = parseInt(stats.total) || 0;
        const cancelledCount = parseInt(stats.cancelled) || 0;
        const pendingCount = (parseInt(stats.assigned) || 0) + (parseInt(stats.in_progress) || 0);
        const completedCount = (parseInt(stats.completed) || 0) + (parseInt(stats.closed) || 0);
        
        updateStatElement('total-count', totalCount);
        updateStatElement('cancelled-count', cancelledCount);
        updateStatElement('pending-count', pendingCount);
        updateStatElement('completed-count', completedCount);
        
        console.log('[Dashboard] System stats updated:', { totalCount, cancelledCount, pendingCount, completedCount });
      } else {
        console.log('[Dashboard] Operator user - stats will be calculated from work orders');
      }
    } else {
      console.error('[Dashboard] Stats API returned unsuccessful response:', statsData);
      showStatsError();
    }
    
    // Load today's work orders
    await loadTodayWorkOrders();
    
  } catch (error) {
    console.error('[Dashboard] Error loading dashboard:', error);
    showStatsError();
    showWorkOrdersError();
    showToast('Failed to load dashboard data', 'error');
  } finally {
    dashboardState.isLoading = false;
    setStatsLoading(false);
  }
}

async function loadTodayWorkOrders() {
  try {
    console.log('[Dashboard] Loading my work orders...');
    
    const woRes = await fetch('/api/work-orders/my-work-orders?limit=5&status=&priority=&_=' + Date.now(), {
      headers: getAuthHeaders()
    });
    
    if (woRes.status === 401) {
      handleAuthError();
      return;
    }
    
    const woData = await woRes.json();
    console.log('[Dashboard] Work orders API response:', woData);
    
    if (woData.success) {
      const workOrders = woData.data?.work_orders || [];
      dashboardState.workOrders = workOrders;
      dashboardState.filteredWorkOrders = workOrders;
      console.log('[Dashboard] Work orders loaded:', workOrders.length);
      console.log('[Dashboard] First work order:', workOrders[0]?.title || 'none');
      
      // Calculate stats from actual work orders for operators
      calculateAndUpdateStats(workOrders);
      
      // Re-apply active filter if any
      if (dashboardState.activeFilter !== 'all') {
        filterWorkOrders(dashboardState.activeFilter);
      } else {
        renderWorkOrders(workOrders);
      }
    } else {
      console.error('[Dashboard] Work orders API failed:', woData);
      renderWorkOrders([]);
    }
  } catch (error) {
    console.error('[Dashboard] Error loading work orders:', error);
    showWorkOrdersError();
  }
}

function calculateAndUpdateStats(workOrders) {
  // Calculate stats from the actual work orders list
  const totalCount = workOrders.length;
  let cancelledCount = 0;
  let pendingCount = 0;
  let completedCount = 0;
  
  workOrders.forEach(wo => {
    // Cancelled = cancelled status
    if (wo.status === 'cancelled') {
      cancelledCount++;
    }
    
    // Pending = assigned or in_progress
    if (wo.status === 'assigned' || wo.status === 'in_progress') {
      pendingCount++;
    }
    
    // Completed = completed or closed
    if (wo.status === 'completed' || wo.status === 'closed') {
      completedCount++;
    }
  });
  
  updateStatElement('total-count', totalCount);
  updateStatElement('cancelled-count', cancelledCount);
  updateStatElement('pending-count', pendingCount);
  updateStatElement('completed-count', completedCount);
  
  // Store counts for filter display
  dashboardState.stats = { total: totalCount, cancelled: cancelledCount, pending: pendingCount, completed: completedCount };
  
  console.log('[Dashboard] Stats calculated from work orders:', { totalCount, cancelledCount, pendingCount, completedCount });
}

// ============================================
// RENDERING
// ============================================
function updateStatElement(id, value) {
  const el = document.getElementById(id);
  if (el) {
    el.textContent = value;
    el.classList.remove('loading');
  }
}

function setStatsLoading(loading) {
  const statValues = document.querySelectorAll('.stat-value');
  statValues.forEach(el => {
    if (loading) {
      el.classList.add('loading');
    } else {
      el.classList.remove('loading');
    }
  });
}

function showStatsError() {
  const statIds = ['cancelled-count', 'pending-count', 'completed-count'];
  statIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.textContent = '!';
      el.classList.remove('loading');
      el.style.color = 'var(--danger)';
    }
  });
}

function renderWorkOrders(workOrders) {
  const container = document.getElementById('today-wo-list');
  
  if (!workOrders || workOrders.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p>No work orders assigned</p>
        <p class="empty-hint">You're all caught up!</p>
      </div>
    `;
    return;
  }
  
  try {
    container.innerHTML = workOrders.map(wo => `
      <div class="wo-card ${wo.status === 'cancelled' ? 'cancelled' : wo.priority}" onclick="window.location.href='/work-orders/${wo.id}'">
        <div class="wo-header">
          <span class="wo-number">${wo.wo_number || 'N/A'}</span>
          <span class="wo-status ${wo.status}">${formatStatus(wo.status)}</span>
        </div>
        <h3 class="wo-title">${escapeHtml(wo.title)}</h3>
        <div class="wo-meta">
          <span class="wo-equipment">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
            </svg>
            ${wo.equipment_code || 'N/A'}
          </span>
          <span class="wo-time">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            ${wo.estimated_hours || '-'}h
          </span>
        </div>
      </div>
    `).join('');
  } catch (err) {
    console.error('[Dashboard] Error rendering work orders:', err);
    showWorkOrdersError();
  }
}

function showWorkOrdersError() {
  const container = document.getElementById('today-wo-list');
  container.innerHTML = `
    <div class="error-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>Failed to load work orders</p>
      <button class="btn btn-secondary btn-sm" onclick="loadTodayWorkOrders()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 4v6h-6M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
        Try Again
      </button>
    </div>
  `;
}

// ============================================
// UTILITIES
// ============================================
function formatStatus(status) {
  if (!status) return 'Unknown';
  return status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function handleAuthError() {
  localStorage.clear();
  window.location.href = '/login';
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  if (!container) return;
  
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  
  setTimeout(() => {
    toast.classList.add('fade-out');
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}

function navigateTo(url) {
  window.location.href = url;
}

// ============================================
// FILTER FUNCTIONS
// ============================================
function filterWorkOrders(filterType) {
  dashboardState.activeFilter = filterType;
  
  // Update active filter UI
  document.querySelectorAll('.stat-filter').forEach(card => {
    card.classList.remove('active');
  });
  document.querySelector(`[data-filter="${filterType}"]`).classList.add('active');
  
  // Filter work orders
  let filtered = dashboardState.workOrders;
  
  switch (filterType) {
    case 'cancelled':
      filtered = dashboardState.workOrders.filter(wo => wo.status === 'cancelled');
      break;
    case 'pending':
      filtered = dashboardState.workOrders.filter(wo => wo.status === 'assigned' || wo.status === 'in_progress');
      break;
    case 'completed':
      filtered = dashboardState.workOrders.filter(wo => wo.status === 'completed' || wo.status === 'closed');
      break;
    case 'all':
    default:
      filtered = dashboardState.workOrders;
      break;
  }
  
  dashboardState.filteredWorkOrders = filtered;
  
  // Show active filter bar
  const filterBar = document.getElementById('active-filter-bar');
  const filterText = document.getElementById('active-filter-text');
  filterBar.classList.remove('hidden');
  filterBar.style.display = 'flex';
  
  const filterLabels = {
    'all': 'All Tasks',
    'cancelled': 'Cancelled Tasks',
    'pending': 'Pending Tasks',
    'completed': 'Completed Tasks'
  };
  filterText.textContent = `Showing: ${filterLabels[filterType]} (${filtered.length})`;
  
  // Re-render with filtered data
  renderWorkOrders(filtered);
  
  console.log('[Dashboard] Filter applied:', filterType, 'Results:', filtered.length);
}

function clearFilter() {
  dashboardState.activeFilter = 'all';
  dashboardState.filteredWorkOrders = dashboardState.workOrders;
  
  // Remove active states
  document.querySelectorAll('.stat-filter').forEach(card => {
    card.classList.remove('active');
  });
  
  // Hide filter bar
  const filterBar = document.getElementById('active-filter-bar');
  filterBar.classList.add('hidden');
  filterBar.style.display = 'none';
  
  // Re-render all
  renderWorkOrders(dashboardState.workOrders);
  
  console.log('[Dashboard] Filter cleared');
}

// ============================================
// ADMIN DASHBOARD FUNCTIONS
// ============================================
async function loadAdminDashboardData() {
  console.log('[Admin Dashboard] Loading admin data...');
  
  try {
    // Load system stats
    const [statsRes, usersRes, equipmentRes, facilitiesRes] = await Promise.all([
      fetch('/api/work-orders/stats?_=' + Date.now(), { headers: getAuthHeaders() }),
      fetch('/api/users?active=true&_=' + Date.now(), { headers: getAuthHeaders() }),
      fetch('/api/equipment?_=' + Date.now(), { headers: getAuthHeaders() }),
      fetch('/api/facilities?_=' + Date.now(), { headers: getAuthHeaders() })
    ]);
    
    if (statsRes.status === 401 || usersRes.status === 401) {
      handleAuthError();
      return;
    }
    
    const statsData = await statsRes.json();
    const usersData = await usersRes.json();
    const equipmentData = await equipmentRes.json();
    const facilitiesData = await facilitiesRes.json();
    
    // Update admin stats
    const userCount = usersData.data?.users?.length || 0;
    const equipmentCount = equipmentData.data?.equipment?.length || 0;
    const facilityCount = facilitiesData.data?.facilities?.length || 0;
    
    // Calculate unassigned work orders
    let unassignedCount = 0;
    if (statsData.data?.stats) {
      const stats = statsData.data.stats;
      const total = parseInt(stats.total) || 0;
      const assigned = parseInt(stats.assigned) || 0;
      const inProgress = parseInt(stats.in_progress) || 0;
      const completed = parseInt(stats.completed) || 0;
      const closed = parseInt(stats.closed) || 0;
      const cancelled = parseInt(stats.cancelled) || 0;
      unassignedCount = total - assigned - inProgress - completed - closed - cancelled;
      if (unassignedCount < 0) unassignedCount = 0;
    }
    
    updateStatElement('admin-user-count', userCount);
    updateStatElement('admin-equipment-count', equipmentCount);
    updateStatElement('admin-unassigned-count', unassignedCount);
    updateStatElement('admin-facility-count', facilityCount);
    
    // Render admin activity
    renderAdminActivity(usersData.data?.users || [], statsData.data?.stats);
    
    console.log('[Admin Dashboard] Data loaded:', { userCount, equipmentCount, unassignedCount, facilityCount });
    
  } catch (error) {
    console.error('[Admin Dashboard] Error loading data:', error);
    showAdminStatsError();
  }
}

function renderAdminActivity(users, stats) {
  const container = document.getElementById('admin-activity-list');
  if (!container) return;
  
  // Create synthetic activity items based on system state
  const activities = [];
  
  // Recent users
  const recentUsers = users.slice(0, 3);
  recentUsers.forEach(user => {
    activities.push({
      icon: 'user',
      title: `${user.full_name || user.username} joined`,
      time: formatTimeAgo(user.created_at),
      color: 'primary'
    });
  });
  
  // System status
  if (stats) {
    const pendingCount = (parseInt(stats.assigned) || 0) + (parseInt(stats.in_progress) || 0);
    if (pendingCount > 0) {
      activities.push({
        icon: 'task',
        title: `${pendingCount} tasks pending assignment`,
        time: 'Now',
        color: 'warning'
      });
    }
  }
  
  if (activities.length === 0) {
    container.innerHTML = `
      <div class="admin-activity-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p>No recent activity</p>
      </div>
    `;
    return;
  }
  
  container.innerHTML = activities.map(act => `
    <div class="admin-activity-item">
      <div class="admin-activity-icon" style="background: var(--${act.color}-50); color: var(--${act.color});">
        ${getActivityIcon(act.icon)}
      </div>
      <div class="admin-activity-content">
        <div class="admin-activity-title">${escapeHtml(act.title)}</div>
        <div class="admin-activity-time">${act.time}</div>
      </div>
    </div>
  `).join('');
}

function getActivityIcon(type) {
  const icons = {
    user: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>`,
    task: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
    equipment: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/></svg>`,
    system: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>`
  };
  return icons[type] || icons.system;
}

function formatTimeAgo(dateString) {
  if (!dateString) return 'Unknown';
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now - date;
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);
  
  if (diffMins < 1) return 'Just now';
  if (diffMins < 60) return `${diffMins}m ago`;
  if (diffHours < 24) return `${diffHours}h ago`;
  if (diffDays < 7) return `${diffDays}d ago`;
  return date.toLocaleDateString();
}

function showAdminStatsError() {
  ['admin-user-count', 'admin-equipment-count', 'admin-unassigned-count', 'admin-facility-count'].forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.textContent = '!';
      el.classList.remove('loading');
      el.style.color = 'var(--danger)';
    }
  });
}
</script>

