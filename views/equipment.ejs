<%- include('partials/header', { title: title, user: user }) %>

<div class="page equipment-page">
  <header class="page-header">
    <button class="btn-back" onclick="history.back()" title="Go Back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </button>
    <h1>Equipment</h1>
  </header>

  <!-- Search Bar -->
  <div class="search-bar">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/>
      <path d="M21 21l-4.35-4.35"/>
    </svg>
    <input type="text" id="search-input" placeholder="Search equipment...">
  </div>

  <!-- Equipment List -->
  <div class="equipment-list" id="equipment-list">
    <div class="loading-skeleton">
      <div class="skeleton-item"></div>
      <div class="skeleton-item"></div>
      <div class="skeleton-item"></div>
      <div class="skeleton-item"></div>
    </div>
  </div>
</div>

<script>
// ============================================
// EQUIPMENT PAGE
// ============================================
let equipmentData = [];

// ============================================
// INITIALIZATION
// ============================================
document.addEventListener('DOMContentLoaded', () => {
  checkAuth();
  initEventListeners();
  loadEquipment();
});

function initEventListeners() {
  // Search with debounce
  const searchInput = document.getElementById('search-input');
  searchInput.addEventListener('input', debounce((e) => {
    const searchTerm = e.target.value.trim();
    if (searchTerm.length > 2) {
      searchEquipment(searchTerm);
    } else if (searchTerm.length === 0) {
      renderEquipment(equipmentData);
    }
  }, 300));
}

// ============================================
// DATA LOADING
// ============================================
async function loadEquipment() {
  try {
    const response = await fetch('/api/equipment', {
      headers: getAuthHeaders()
    });
    
    if (response.status === 401) {
      handleAuthError();
      return;
    }
    
    const data = await response.json();
    
    if (data.success) {
      equipmentData = data.data?.equipment || [];
      renderEquipment(equipmentData);
    } else {
      showErrorState('Failed to load equipment');
    }
  } catch (error) {
    console.error('[Equipment] Error loading:', error);
    showErrorState('Failed to load equipment');
  }
}

async function searchEquipment(searchTerm) {
  const container = document.getElementById('equipment-list');
  container.innerHTML = `
    <div class="loading-state">
      <div class="spinner"></div>
      <p>Searching...</p>
    </div>
  `;
  
  try {
    const response = await fetch(`/api/equipment/search?q=${encodeURIComponent(searchTerm)}`, {
      headers: getAuthHeaders()
    });
    
    if (response.status === 401) {
      handleAuthError();
      return;
    }
    
    const data = await response.json();
    
    if (data.success) {
      const results = data.data?.equipment || [];
      renderEquipment(results);
    } else {
      showErrorState('Search failed');
    }
  } catch (error) {
    console.error('[Equipment] Error searching:', error);
    showErrorState('Search failed');
  }
}

// ============================================
// RENDERING
// ============================================
function renderEquipment(equipment) {
  const container = document.getElementById('equipment-list');
  
  if (!equipment || equipment.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        <p>No equipment found</p>
        <p class="empty-hint">Try a different search term</p>
      </div>
    `;
    return;
  }
  
  try {
    container.innerHTML = equipment.map(eq => `
      <div class="equipment-card">
        <div class="equipment-header">
          <span class="equipment-code">${eq.code || 'N/A'}</span>
          <span class="equipment-status ${eq.status}">${formatStatus(eq.status)}</span>
        </div>
        <h3 class="equipment-name">${escapeHtml(eq.name)}</h3>
        <p class="equipment-facility">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          ${eq.facility_name || 'Unknown Location'}
        </p>
        <div class="equipment-meta">
          <span class="equipment-category">${eq.category || 'Uncategorized'}</span>
          <span class="equipment-criticality ${eq.criticality}">${eq.criticality || 'low'}</span>
        </div>
      </div>
    `).join('');
  } catch (err) {
    console.error('[Equipment] Render error:', err);
    showErrorState('Error displaying equipment');
  }
}

function showErrorState(message) {
  const container = document.getElementById('equipment-list');
  container.innerHTML = `
    <div class="error-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>${message}</p>
      <button class="btn btn-secondary btn-sm" onclick="loadEquipment()" style="margin-top: 12px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
          <path d="M23 4v6h-6M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
        Try Again
      </button>
    </div>
  `;
}

// ============================================
// UTILITIES
// ============================================
function formatStatus(status) {
  if (!status) return 'Unknown';
  return status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function debounce(func, wait) {
  let timeout;
  return function executedFunction(...args) {
    const later = () => {
      clearTimeout(timeout);
      func(...args);
    };
    clearTimeout(timeout);
    timeout = setTimeout(later, wait);
  };
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function handleAuthError() {
  localStorage.clear();
  window.location.href = '/login';
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  if (!container) return;
  
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  
  setTimeout(() => {
    toast.classList.add('fade-out');
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}
</script>

<%- include('partials/footer') %>
