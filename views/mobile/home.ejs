<% title = 'Home' %>
<% showBack = false %>
<% showNav = true %>
<% activeNav = 'home' %>
<% const isAdmin = typeof userRole !== 'undefined' && userRole === 'admin'; %>
<% const canInspect = !isAdmin; %>

<!-- Organization Card -->
<div id="orgCard" class="card" style="margin-bottom: 16px; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark, #1565c0) 100%); color: white; display: none;">
    <div style="display: flex; align-items: center; gap: 12px;">
        <div style="width: 48px; height: 48px; background: rgba(255,255,255,0.2); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px;">
            🏭
        </div>
        <div style="flex: 1; min-width: 0;">
            <div style="font-size: 12px; opacity: 0.8; margin-bottom: 2px;">Organization</div>
            <div id="orgCardName" style="font-size: 18px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
        </div>
        <a href="/mobile/admin/organization" style="color: white; opacity: 0.8; text-decoration: none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
    </div>
</div>

<% if (canInspect) { %>
<!-- Dashboard Stats -->
<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-value">5</div>
        <div class="stat-label">Today's Tasks</div>
    </div>
    <div class="stat-card">
        <div class="stat-value danger">2</div>
        <div class="stat-label">Overdue</div>
    </div>
</div>

<!-- Overdue Alert -->
<div class="alert-banner">
    <span class="alert-icon">⚠️</span>
    <div class="alert-content">
        <div class="alert-title">2 Overdue Inspections</div>
        <div class="alert-subtitle">Requires immediate attention</div>
    </div>
</div>
<% } %>

<% if (isAdmin) { %>
<!-- Admin Welcome -->
<div class="card" style="margin-bottom: 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
    <div style="padding: 20px;">
        <div style="font-size: 20px; font-weight: 600; margin-bottom: 8px;">Admin Dashboard</div>
        <div style="font-size: 14px; opacity: 0.9; margin-bottom: 16px;">
            Manage your maintenance system settings, coverage, and configurations.
        </div>
        <a href="/mobile/admin" class="btn" style="background: white; color: #667eea; border: none; font-weight: 500;">
            Go to Admin Panel →
        </a>
    </div>
</div>

<!-- Quick Stats for Admin -->
<div class="dashboard-stats">
    <div class="stat-card">
        <div class="stat-value" style="color: var(--primary);">🛡️</div>
        <div class="stat-label">Coverage</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" style="color: var(--success);">⚙️</div>
        <div class="stat-label">Settings</div>
    </div>
</div>
<% } %>

<!-- Quick Scan Button -->
<% if (canInspect) { %>
<button class="btn-scan-large" onclick="openQRScanner()">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="7" height="7"/>
        <rect x="14" y="3" width="7" height="7"/>
        <rect x="14" y="14" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/>
    </svg>
    Scan Asset QR
</button>
<% } %>

<% if (canInspect) { %>
<!-- Recent Work Orders -->
<div class="card">
    <div class="card-title">Priority Tasks</div>
    
    <div class="wo-card card" style="margin-bottom: 8px;">
        <div class="wo-header">
            <div>
                <div class="wo-title">Pump P-101</div>
                <div class="wo-meta">WO-2026-0042 • North Plant</div>
            </div>
            <span class="status-badge status-released">Released</span>
        </div>
        <div class="wo-equipment">Centrifugal Pump</div>
        <div class="wo-footer">
            <span class="wo-due today">Due Today</span>
            <button class="btn btn-primary" style="min-width: 80px;" onclick="location.href='/mobile/inspection/WO-2026-0042'">Start</button>
        </div>
    </div>
    
    <div class="wo-card card" style="margin-bottom: 0;">
        <div class="wo-header">
            <div>
                <div class="wo-title">Motor M-205</div>
                <div class="wo-meta">WO-2026-0038 • South Plant</div>
            </div>
            <span class="status-badge status-released">Released</span>
        </div>
        <div class="wo-equipment">Electric Motor</div>
        <div class="wo-footer">
            <span class="wo-due overdue">2 Days Overdue</span>
            <button class="btn btn-danger" style="min-width: 80px;" onclick="location.href='/mobile/inspection/WO-2026-0038'">Start</button>
        </div>
    </div>
</div>

<a href="/mobile/work-orders" class="btn btn-outline btn-full" style="margin-bottom: 12px;">View All Tasks</a>
<% } %>

<% if (isAdmin) { %>
<!-- Admin Tools -->
<div class="admin-tools" style="margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--gray-200);">
    <div style="font-size: 13px; font-weight: 600; color: var(--gray-500); margin-bottom: 12px; text-transform: uppercase;">Admin Tools</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;">
        <button class="btn btn-secondary" onclick="location.href='/mobile/admin'">
            <span style="font-size: 20px;">⚙️</span>
            <div style="font-size: 12px; margin-top: 4px;">Admin</div>
        </button>
        <button class="btn btn-secondary" onclick="location.href='/mobile/admin/coverage'">
            <span style="font-size: 20px;">🛡️</span>
            <div style="font-size: 12px; margin-top: 4px;">Coverage</div>
        </button>
        <button class="btn btn-secondary" onclick="location.href='/mobile/qr-labels'">
            <span style="font-size: 20px;">🏷️</span>
            <div style="font-size: 12px; margin-top: 4px;">QR Labels</div>
        </button>
    </div>
</div>
<% } %>

<script>
// Load organization info
(async function loadOrgInfo() {
    try {
        const response = await fetch('/api/organizations/my', { credentials: 'same-origin' });
        const data = await response.json();
        if (data.success && data.data.organization) {
            const org = data.data.organization;
            const card = document.getElementById('orgCard');
            const name = document.getElementById('orgCardName');
            if (card && name) {
                name.textContent = org.organization_name;
                card.style.display = 'block';
            }
        }
    } catch (err) {
        console.error('Failed to load org info:', err);
    }
})();
</script>
