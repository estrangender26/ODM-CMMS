<% title = plan.id ? 'Edit Plan' : 'New Maintenance Plan' %>

<div class="container" style="padding: 16px; max-width: 600px; margin: 0 auto;">
    <!-- Header -->
    <div style="margin-bottom: 24px;">
        <h1 style="font-size: 24px; font-weight: 700; margin: 0 0 8px 0; color: var(--gray-900);"><%= plan.id ? 'Edit Maintenance Plan' : 'New Maintenance Plan' %></h1>
        <p style="font-size: 14px; color: var(--gray-600); margin: 0;">Define when and where to apply an inspection template</p>
    </div>
    
    <!-- Basic Info Card -->
    <div class="card" style="margin-bottom: 16px; padding: 20px;">
        <div style="font-size: 14px; font-weight: 600; color: var(--gray-700); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">Basic Information</div>
        
        <!-- Plan Name -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Plan Name <span style="color: var(--danger);">*</span>
            </label>
            <input type="text" id="planName" class="form-input" value="<%= plan.plan_name %>" placeholder="e.g., Daily Pump Inspection - North Plant" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box;">
        </div>
        
        <!-- Template Selection -->
        <div class="form-group" style="margin-bottom: 12px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Inspection Template <span style="color: var(--danger);">*</span>
            </label>
            <select id="templateId" class="form-input" onchange="onTemplateChange()"
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="">Select Template</option>
                <% templates.forEach(function(t) { %>
                <option value="<%= t.id %>" data-equipment-type="<%= t.equipment_type %>" <%= plan.task_template_id == t.id ? 'selected' : '' %>>
                    <%= t.name %> (<%= t.equipment_type %>)
                </option>
                <% }); %>
            </select>
            <div style="font-size: 12px; color: var(--gray-500); margin-top: 6px; padding-left: 4px;">
                💡 Templates define WHAT to inspect
            </div>
        </div>
    </div>
    
    <!-- Equipment Selection Card -->
    <div class="card" style="margin-bottom: 16px; padding: 20px;">
        <div style="font-size: 14px; font-weight: 600; color: var(--gray-700); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">Equipment Selection</div>
        
        <!-- Equipment Mode Toggle -->
        <div style="display: flex; gap: 8px; margin-bottom: 16px; background: var(--gray-100); padding: 4px; border-radius: 8px;">
            <button type="button" id="modeAll" class="btn btn-full" onclick="setEquipmentMode('all')" 
                style="flex: 1; padding: 10px; font-size: 14px; font-weight: 500; border-radius: 6px; <%= !plan.equipment_id ? 'background: var(--primary); color: white;' : 'background: transparent; color: var(--gray-700);' %>">
                All Equipment
            </button>
            <button type="button" id="modeSpecific" class="btn btn-full" onclick="setEquipmentMode('specific')" 
                style="flex: 1; padding: 10px; font-size: 14px; font-weight: 500; border-radius: 6px; <%= plan.equipment_id ? 'background: var(--primary); color: white;' : 'background: transparent; color: var(--gray-700);' %>">
                Specific Equipment
            </button>
        </div>
        
        <!-- Equipment Selection (shown when mode is specific) -->
        <div id="equipmentSelection" style="display: <%= plan.equipment_id ? 'block' : 'none' %>;">
            <!-- Search -->
            <div class="form-group" style="margin-bottom: 12px;">
                <input type="text" id="equipmentSearch" placeholder="🔍 Search equipment by name or code..." 
                    style="width: 100%; padding: 12px; font-size: 14px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box;"
                    onkeyup="filterEquipment()">
            </div>
            
            <!-- Selected Equipment Display -->
            <div id="selectedEquipmentDisplay" style="margin-bottom: 12px; padding: 12px; background: #e3f2fd; border-radius: 8px; display: <%= plan.equipment_id ? 'block' : 'none' %>;">
                <div style="font-size: 12px; color: var(--gray-600); margin-bottom: 4px;">Selected:</div>
                <div id="selectedEquipmentName" style="font-weight: 600; color: var(--primary);">
                    <% if (plan.equipment_id) { %>
                        <% const selected = equipment.find(e => e.id == plan.equipment_id); %>
                        <%= selected ? selected.name + ' (' + selected.code + ')' : '' %>
                    <% } %>
                </div>
            </div>
            
            <!-- Equipment List -->
            <div style="max-height: 250px; overflow-y: auto; border: 1px solid var(--gray-300); border-radius: 8px;">
                <% 
                // Group equipment by type
                const equipmentByType = {};
                equipment.forEach(function(e) {
                    if (!equipmentByType[e.type]) equipmentByType[e.type] = [];
                    equipmentByType[e.type].push(e);
                });
                %>
                
                <% Object.keys(equipmentByType).sort().forEach(function(type) { %>
                <div class="equipment-group" data-type="<%= type %>">
                    <div style="padding: 10px 12px; background: var(--gray-100); font-size: 12px; font-weight: 600; color: var(--gray-700); text-transform: uppercase; letter-spacing: 0.5px; position: sticky; top: 0;">
                        <%= type %>
                    </div>
                    <% equipmentByType[type].forEach(function(e) { %>
                    <div class="equipment-item" data-name="<%= e.name.toLowerCase() %>" data-code="<%= e.code.toLowerCase() %>" data-type="<%= e.type.toLowerCase() %>"
                        onclick="selectEquipment('<%= e.id %>', '<%= e.name.replace(/'/g, "\\'") %>', '<%= e.code %>')"
                        style="padding: 12px; border-bottom: 1px solid var(--gray-200); cursor: pointer; <%= plan.equipment_id == e.id ? 'background: #e3f2fd;' : 'background: white;' %> hover: background: var(--gray-100); transition: background 0.2s;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <div style="font-weight: 500; color: var(--gray-900);"><%= e.name %></div>
                                <div style="font-size: 12px; color: var(--gray-600); margin-top: 2px;">
                                    Code: <%= e.code %> • <%= e.type %>
                                </div>
                            </div>
                            <div class="equipment-radio" data-id="<%= e.id %>" style="width: 20px; height: 20px; border-radius: 50%; border: 2px solid <%= plan.equipment_id == e.id ? 'var(--primary)' : 'var(--gray-400)' %>; background: <%= plan.equipment_id == e.id ? 'var(--primary)' : 'white' %>; display: flex; align-items: center; justify-content: center;">
                                <% if (plan.equipment_id == e.id) { %>
                                <span style="color: white; font-size: 12px;">✓</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                </div>
                <% }); %>
            </div>
            
            <input type="hidden" id="equipmentId" value="<%= plan.equipment_id || '' %>">
        </div>
        
        <!-- All Equipment Message -->
        <div id="allEquipmentMessage" style="display: <%= !plan.equipment_id ? 'block' : 'none' %>; padding: 16px; background: #f5f5f5; border-radius: 8px; text-align: center;">
            <div style="font-size: 24px; margin-bottom: 8px;">🏭</div>
            <div style="font-size: 14px; color: var(--gray-700); font-weight: 500;">Plan will apply to ALL equipment</div>
            <div style="font-size: 12px; color: var(--gray-600); margin-top: 4px;">of the selected template's equipment type</div>
        </div>
    </div>
    
    <!-- Schedule Card -->
    <div class="card" style="margin-bottom: 16px; padding: 20px;">
        <div style="font-size: 14px; font-weight: 600; color: var(--gray-700); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">Schedule Configuration</div>
        
        <!-- Frequency -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Frequency <span style="color: var(--danger);">*</span>
            </label>
            <select id="frequencyType" class="form-input" onchange="onFrequencyChange()" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="daily" <%= plan.frequency_type === 'daily' ? 'selected' : '' %>>Daily</option>
                <option value="weekly" <%= plan.frequency_type === 'weekly' ? 'selected' : '' %>>Weekly</option>
                <option value="monthly" <%= plan.frequency_type === 'monthly' ? 'selected' : '' %>>Monthly</option>
            </select>
        </div>
        
        <!-- Interval -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Every</label>
            <div style="display: flex; align-items: center; gap: 12px;">
                <input type="number" id="frequencyInterval" class="form-input" value="<%= plan.frequency_interval %>" min="1" 
                    style="width: 80px; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; text-align: center;">
                <span id="intervalLabel" style="font-size: 16px; color: var(--gray-700);">day(s)</span>
            </div>
        </div>
        
        <!-- Day of Week (for weekly) -->
        <div class="form-group" id="dayOfWeekGroup" style="display: <%= plan.frequency_type === 'weekly' ? 'block' : 'none' %>; margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Day of Week</label>
            <select id="dayOfWeek" class="form-input" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="1" <%= plan.day_of_week == 1 ? 'selected' : '' %>>Monday</option>
                <option value="2" <%= plan.day_of_week == 2 ? 'selected' : '' %>>Tuesday</option>
                <option value="3" <%= plan.day_of_week == 3 ? 'selected' : '' %>>Wednesday</option>
                <option value="4" <%= plan.day_of_week == 4 ? 'selected' : '' %>>Thursday</option>
                <option value="5" <%= plan.day_of_week == 5 ? 'selected' : '' %>>Friday</option>
                <option value="6" <%= plan.day_of_week == 6 ? 'selected' : '' %>>Saturday</option>
                <option value="0" <%= plan.day_of_week == 0 ? 'selected' : '' %>>Sunday</option>
            </select>
        </div>
        
        <!-- Day of Month (for monthly) -->
        <div class="form-group" id="dayOfMonthGroup" style="display: <%= plan.frequency_type === 'monthly' ? 'block' : 'none' %>; margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Day of Month</label>
            <input type="number" id="dayOfMonth" class="form-input" value="<%= plan.day_of_month || 1 %>" min="1" max="31" 
                style="width: 100px; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; text-align: center;">
        </div>
        
        <!-- Start Date -->
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Start Date <span style="color: var(--danger);">*</span>
            </label>
            <input type="date" id="startDate" class="form-input" value="<%= plan.start_date %>" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box;">
        </div>
    </div>
    
    <!-- Settings Card -->
    <div class="card" style="margin-bottom: 20px; padding: 20px;">
        <div style="font-size: 14px; font-weight: 600; color: var(--gray-700); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">Settings</div>
        
        <!-- Priority -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Priority</label>
            <select id="priority" class="form-input" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="low" <%= plan.priority === 'low' ? 'selected' : '' %>>Low</option>
                <option value="medium" <%= plan.priority === 'medium' ? 'selected' : '' %>>Medium</option>
                <option value="high" <%= plan.priority === 'high' ? 'selected' : '' %>>High</option>
                <option value="urgent" <%= plan.priority === 'urgent' ? 'selected' : '' %>>Urgent</option>
            </select>
        </div>
        
        <!-- Active Status -->
        <div class="form-group" style="margin-bottom: 0;">
            <label style="display: flex; align-items: center; gap: 12px; cursor: pointer; font-size: 16px; color: var(--gray-700);">
                <input type="checkbox" id="isActive" <%= plan.is_active ? 'checked' : '' %> 
                    style="width: 22px; height: 22px; accent-color: var(--primary);">
                <span>Active</span>
            </label>
        </div>
    </div>
    
    <!-- Save Button -->
    <button class="btn btn-primary btn-large btn-full" onclick="savePlan()" 
        style="padding: 16px; font-size: 16px; font-weight: 600; border-radius: 8px; margin-bottom: 40px;">
        <%= plan.id ? 'Save Changes' : 'Create Plan' %>
    </button>
</div>

<script>
// Equipment selection mode
function setEquipmentMode(mode) {
    const allBtn = document.getElementById('modeAll');
    const specificBtn = document.getElementById('modeSpecific');
    const equipmentSelection = document.getElementById('equipmentSelection');
    const allEquipmentMessage = document.getElementById('allEquipmentMessage');
    const equipmentIdInput = document.getElementById('equipmentId');
    
    if (mode === 'all') {
        allBtn.style.background = 'var(--primary)';
        allBtn.style.color = 'white';
        specificBtn.style.background = 'transparent';
        specificBtn.style.color = 'var(--gray-700)';
        equipmentSelection.style.display = 'none';
        allEquipmentMessage.style.display = 'block';
        equipmentIdInput.value = '';
    } else {
        specificBtn.style.background = 'var(--primary)';
        specificBtn.style.color = 'white';
        allBtn.style.background = 'transparent';
        allBtn.style.color = 'var(--gray-700)';
        equipmentSelection.style.display = 'block';
        allEquipmentMessage.style.display = 'none';
    }
}

// Select specific equipment
function selectEquipment(id, name, code) {
    document.getElementById('equipmentId').value = id;
    
    // Update selected display
    document.getElementById('selectedEquipmentDisplay').style.display = 'block';
    document.getElementById('selectedEquipmentName').textContent = name + ' (' + code + ')';
    
    // Update all radio buttons
    document.querySelectorAll('.equipment-radio').forEach(radio => {
        radio.style.borderColor = 'var(--gray-400)';
        radio.style.background = 'white';
        radio.innerHTML = '';
    });
    
    // Update selected radio
    const selectedRadio = document.querySelector('.equipment-radio[data-id="' + id + '"]');
    if (selectedRadio) {
        selectedRadio.style.borderColor = 'var(--primary)';
        selectedRadio.style.background = 'var(--primary)';
        selectedRadio.innerHTML = '<span style="color: white; font-size: 12px;">✓</span>';
    }
    
    // Update row backgrounds
    document.querySelectorAll('.equipment-item').forEach(item => {
        item.style.background = 'white';
    });
    const selectedItem = document.querySelector('.equipment-item[onclick*="' + id + '"');
    if (selectedItem) {
        selectedItem.style.background = '#e3f2fd';
    }
}

// Filter equipment by search
function filterEquipment() {
    const search = document.getElementById('equipmentSearch').value.toLowerCase();
    
    document.querySelectorAll('.equipment-item').forEach(item => {
        const name = item.dataset.name;
        const code = item.dataset.code;
        const type = item.dataset.type;
        
        if (name.includes(search) || code.includes(search) || type.includes(search)) {
            item.style.display = 'block';
        } else {
            item.style.display = 'none';
        }
    });
    
    // Hide empty groups
    document.querySelectorAll('.equipment-group').forEach(group => {
        const visibleItems = group.querySelectorAll('.equipment-item[style*="block"]').length;
        const totalItems = group.querySelectorAll('.equipment-item').length;
        if (search && visibleItems === 0) {
            group.style.display = 'none';
        } else {
            group.style.display = 'block';
        }
    });
}

// On template change, filter equipment by type
function onTemplateChange() {
    const templateSelect = document.getElementById('templateId');
    const selectedOption = templateSelect.options[templateSelect.selectedIndex];
    const equipmentType = selectedOption.dataset.equipmentType;
    
    // Filter equipment list
    document.querySelectorAll('.equipment-group').forEach(group => {
        const groupType = group.dataset.type;
        if (!equipmentType || groupType === equipmentType) {
            group.style.opacity = '1';
        } else {
            group.style.opacity = '0.5';
        }
    });
}

function onFrequencyChange() {
    const type = document.getElementById('frequencyType').value;
    document.getElementById('dayOfWeekGroup').style.display = type === 'weekly' ? 'block' : 'none';
    document.getElementById('dayOfMonthGroup').style.display = type === 'monthly' ? 'block' : 'none';
    
    const labels = { daily: 'day(s)', weekly: 'week(s)', monthly: 'month(s)' };
    document.getElementById('intervalLabel').textContent = labels[type] || 'day(s)';
}

async function savePlan() {
    const planId = '<%= plan.id %>';
    const data = {
        plan_name: document.getElementById('planName').value,
        task_template_id: document.getElementById('templateId').value,
        equipment_id: document.getElementById('equipmentId').value || null,
        frequency_type: document.getElementById('frequencyType').value,
        frequency_interval: parseInt(document.getElementById('frequencyInterval').value) || 1,
        day_of_week: document.getElementById('frequencyType').value === 'weekly' ? parseInt(document.getElementById('dayOfWeek').value) : null,
        day_of_month: document.getElementById('frequencyType').value === 'monthly' ? parseInt(document.getElementById('dayOfMonth').value) : null,
        start_date: document.getElementById('startDate').value,
        priority: document.getElementById('priority').value,
        is_active: document.getElementById('isActive').checked
    };
    
    // Validate
    if (!data.plan_name || !data.task_template_id || !data.start_date) {
        alert('Please fill in all required fields (marked with *)');
        return;
    }
    
    try {
        const url = planId ? `/api/maintenance-plans/${planId}` : '/api/maintenance-plans';
        const method = planId ? 'PUT' : 'POST';
        
        const response = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert(planId ? 'Plan updated!' : 'Plan created!');
            location.href = '/mobile/maintenance-plans';
        } else {
            alert('Error: ' + result.message);
        }
    } catch (err) {
        alert('Error saving plan');
    }
}

// Initialize on load
document.addEventListener('DOMContentLoaded', function() {
    onTemplateChange();
});
</script>
