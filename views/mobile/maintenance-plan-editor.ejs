<% title = plan.id ? 'Edit Plan' : 'New Maintenance Plan' %>

<div class="container" style="padding: 16px; max-width: 600px; margin: 0 auto;">
    <!-- Header -->
    <div style="margin-bottom: 24px;">
        <h1 style="font-size: 24px; font-weight: 700; margin: 0 0 8px 0; color: var(--gray-900);"><%= plan.id ? 'Edit Maintenance Plan' : 'New Maintenance Plan' %></h1>
        <p style="font-size: 14px; color: var(--gray-600); margin: 0;">Define when and where to apply an inspection template</p>
    </div>
    
    <!-- Basic Info Card -->
    <div class="card" style="margin-bottom: 16px; padding: 20px;">
        <div style="font-size: 14px; font-weight: 600; color: var(--gray-700); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">Basic Information</div>
        
        <!-- Plan Name -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Plan Name <span style="color: var(--danger);">*</span>
            </label>
            <input type="text" id="planName" class="form-input" value="<%= plan.plan_name %>" placeholder="e.g., Daily Pump Inspection - North Plant" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box;">
        </div>
        
        <!-- Template Selection -->
        <div class="form-group" style="margin-bottom: 12px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Inspection Template <span style="color: var(--danger);">*</span>
            </label>
            <select id="templateId" class="form-input" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="">Select Template</option>
                <% templates.forEach(function(t) { %>
                <option value="<%= t.id %>" <%= plan.task_template_id == t.id ? 'selected' : '' %>>
                    <%= t.name %>
                </option>
                <% }); %>
            </select>
            <div style="font-size: 12px; color: var(--gray-500); margin-top: 6px; padding-left: 4px;">
                💡 Templates define WHAT to inspect
            </div>
        </div>
        
        <!-- Equipment Selection (Optional) -->
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Specific Equipment <span style="font-size: 12px; color: var(--gray-500); font-weight: 400;">(Optional)</span>
            </label>
            <select id="equipmentId" class="form-input" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="">All equipment of this type</option>
                <% equipment.forEach(function(e) { %>
                <option value="<%= e.id %>" <%= plan.equipment_id == e.id ? 'selected' : '' %>>
                    <%= e.name %> (<%= e.code %>)
                </option>
                <% }); %>
            </select>
            <div style="font-size: 12px; color: var(--gray-500); margin-top: 6px; padding-left: 4px;">
                Leave empty to apply to all equipment of this type
            </div>
        </div>
    </div>
    
    <!-- Schedule Card -->
    <div class="card" style="margin-bottom: 16px; padding: 20px;">
        <div style="font-size: 14px; font-weight: 600; color: var(--gray-700); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">Schedule Configuration</div>
        
        <!-- Frequency -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Frequency <span style="color: var(--danger);">*</span>
            </label>
            <select id="frequencyType" class="form-input" onchange="onFrequencyChange()" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="daily" <%= plan.frequency_type === 'daily' ? 'selected' : '' %>>Daily</option>
                <option value="weekly" <%= plan.frequency_type === 'weekly' ? 'selected' : '' %>>Weekly</option>
                <option value="monthly" <%= plan.frequency_type === 'monthly' ? 'selected' : '' %>>Monthly</option>
            </select>
        </div>
        
        <!-- Interval -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Every</label>
            <div style="display: flex; align-items: center; gap: 12px;">
                <input type="number" id="frequencyInterval" class="form-input" value="<%= plan.frequency_interval %>" min="1" 
                    style="width: 80px; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; text-align: center;">
                <span id="intervalLabel" style="font-size: 16px; color: var(--gray-700);">day(s)</span>
            </div>
        </div>
        
        <!-- Day of Week (for weekly) -->
        <div class="form-group" id="dayOfWeekGroup" style="display: <%= plan.frequency_type === 'weekly' ? 'block' : 'none' %>; margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Day of Week</label>
            <select id="dayOfWeek" class="form-input" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="1" <%= plan.day_of_week == 1 ? 'selected' : '' %>>Monday</option>
                <option value="2" <%= plan.day_of_week == 2 ? 'selected' : '' %>>Tuesday</option>
                <option value="3" <%= plan.day_of_week == 3 ? 'selected' : '' %>>Wednesday</option>
                <option value="4" <%= plan.day_of_week == 4 ? 'selected' : '' %>>Thursday</option>
                <option value="5" <%= plan.day_of_week == 5 ? 'selected' : '' %>>Friday</option>
                <option value="6" <%= plan.day_of_week == 6 ? 'selected' : '' %>>Saturday</option>
                <option value="0" <%= plan.day_of_week == 0 ? 'selected' : '' %>>Sunday</option>
            </select>
        </div>
        
        <!-- Day of Month (for monthly) -->
        <div class="form-group" id="dayOfMonthGroup" style="display: <%= plan.frequency_type === 'monthly' ? 'block' : 'none' %>; margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Day of Month</label>
            <input type="number" id="dayOfMonth" class="form-input" value="<%= plan.day_of_month || 1 %>" min="1" max="31" 
                style="width: 100px; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; text-align: center;">
        </div>
        
        <!-- Start Date -->
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">
                Start Date <span style="color: var(--danger);">*</span>
            </label>
            <input type="date" id="startDate" class="form-input" value="<%= plan.start_date %>" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box;">
        </div>
    </div>
    
    <!-- Settings Card -->
    <div class="card" style="margin-bottom: 20px; padding: 20px;">
        <div style="font-size: 14px; font-weight: 600; color: var(--gray-700); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">Settings</div>
        
        <!-- Priority -->
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display: block; font-size: 14px; font-weight: 500; color: var(--gray-700); margin-bottom: 6px;">Priority</label>
            <select id="priority" class="form-input" 
                style="width: 100%; padding: 12px; font-size: 16px; border: 2px solid var(--gray-300); border-radius: 8px; box-sizing: border-box; background: white;">
                <option value="low" <%= plan.priority === 'low' ? 'selected' : '' %>>Low</option>
                <option value="medium" <%= plan.priority === 'medium' ? 'selected' : '' %>>Medium</option>
                <option value="high" <%= plan.priority === 'high' ? 'selected' : '' %>>High</option>
                <option value="urgent" <%= plan.priority === 'urgent' ? 'selected' : '' %>>Urgent</option>
            </select>
        </div>
        
        <!-- Active Status -->
        <div class="form-group" style="margin-bottom: 0;">
            <label style="display: flex; align-items: center; gap: 12px; cursor: pointer; font-size: 16px; color: var(--gray-700);">
                <input type="checkbox" id="isActive" <%= plan.is_active ? 'checked' : '' %> 
                    style="width: 22px; height: 22px; accent-color: var(--primary);">
                <span>Active</span>
            </label>
        </div>
    </div>
    
    <!-- Save Button -->
    <button class="btn btn-primary btn-large btn-full" onclick="savePlan()" 
        style="padding: 16px; font-size: 16px; font-weight: 600; border-radius: 8px; margin-bottom: 40px;">
        <%= plan.id ? 'Save Changes' : 'Create Plan' %>
    </button>
</div>

<script>
function onFrequencyChange() {
    const type = document.getElementById('frequencyType').value;
    document.getElementById('dayOfWeekGroup').style.display = type === 'weekly' ? 'block' : 'none';
    document.getElementById('dayOfMonthGroup').style.display = type === 'monthly' ? 'block' : 'none';
    
    const labels = { daily: 'day(s)', weekly: 'week(s)', monthly: 'month(s)' };
    document.getElementById('intervalLabel').textContent = labels[type] || 'day(s)';
}

async function savePlan() {
    const planId = '<%= plan.id %>';
    const data = {
        plan_name: document.getElementById('planName').value,
        task_template_id: document.getElementById('templateId').value,
        equipment_id: document.getElementById('equipmentId').value || null,
        frequency_type: document.getElementById('frequencyType').value,
        frequency_interval: parseInt(document.getElementById('frequencyInterval').value) || 1,
        day_of_week: document.getElementById('frequencyType').value === 'weekly' ? parseInt(document.getElementById('dayOfWeek').value) : null,
        day_of_month: document.getElementById('frequencyType').value === 'monthly' ? parseInt(document.getElementById('dayOfMonth').value) : null,
        start_date: document.getElementById('startDate').value,
        priority: document.getElementById('priority').value,
        is_active: document.getElementById('isActive').checked
    };
    
    // Validate
    if (!data.plan_name || !data.task_template_id || !data.start_date) {
        alert('Please fill in all required fields (marked with *)');
        return;
    }
    
    try {
        const url = planId ? `/api/maintenance-plans/${planId}` : '/api/maintenance-plans';
        const method = planId ? 'PUT' : 'POST';
        
        const response = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert(planId ? 'Plan updated!' : 'Plan created!');
            location.href = '/mobile/maintenance-plans';
        } else {
            alert('Error: ' + result.message);
        }
    } catch (err) {
        alert('Error saving plan');
    }
}
</script>
