<% title = 'Work Orders' %>

<!-- Filters -->
<div class="filter-bar">
    <button class="filter-chip active" onclick="setFilter(this, 'all')">All</button>
    <button class="filter-chip" onclick="setFilter(this, 'today')">Today</button>
    <button class="filter-chip" onclick="setFilter(this, 'overdue')">Overdue</button>
    <button class="filter-chip" onclick="setFilter(this, 'in_progress')">In Progress</button>
    <button class="filter-chip" onclick="setFilter(this, 'north_plant')">North Plant</button>
</div>

<!-- Work Orders List -->
<div class="wo-list">
    <div class="wo-card card" data-status="released" data-due="today" data-facility="North Plant" onclick="location.href='/mobile/work-orders/WO-2026-0042'">
        <div class="wo-header">
            <div>
                <div class="wo-title">Pump P-101</div>
                <div class="wo-meta">WO-2026-0042 • North Plant</div>
            </div>
            <span class="status-badge status-released">Released</span>
        </div>
        <div class="wo-equipment">Centrifugal Pump</div>
        <div class="wo-footer">
            <span class="wo-due today">Due Today</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </div>
    </div>

    <div class="wo-card card" data-status="released" data-due="overdue" data-facility="South Plant" onclick="location.href='/mobile/work-orders/WO-2026-0038'">
        <div class="wo-header">
            <div>
                <div class="wo-title">Motor M-205</div>
                <div class="wo-meta">WO-2026-0038 • South Plant</div>
            </div>
            <span class="status-badge status-released">Released</span>
        </div>
        <div class="wo-equipment">Electric Motor</div>
        <div class="wo-footer">
            <span class="wo-due overdue">2 Days Overdue</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </div>
    </div>

    <div class="wo-card card" data-status="in_progress" data-due="upcoming" data-facility="North Plant" onclick="location.href='/mobile/work-orders/WO-2026-0035'">
        <div class="wo-header">
            <div>
                <div class="wo-title">Heat Exchanger HX-301</div>
                <div class="wo-meta">WO-2026-0035 • North Plant</div>
            </div>
            <span class="status-badge status-in_progress">In Progress</span>
        </div>
        <div class="wo-equipment">Shell and Tube Heat Exchanger</div>
        <div class="wo-footer">
            <span class="wo-due">Due Apr 5</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </div>
    </div>

    <div class="wo-card card" data-status="scheduled" data-due="upcoming" data-facility="East Plant" onclick="location.href='/mobile/work-orders/WO-2026-0030'">
        <div class="wo-header">
            <div>
                <div class="wo-title">Compressor C-102</div>
                <div class="wo-meta">WO-2026-0030 • East Plant</div>
            </div>
            <span class="status-badge status-scheduled">Scheduled</span>
        </div>
        <div class="wo-equipment">Rotary Screw Compressor</div>
        <div class="wo-footer">
            <span class="wo-due">Due Apr 6</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </div>
    </div>

    <div class="wo-card card" data-status="completed" data-due="completed" data-facility="South Plant" onclick="location.href='/mobile/work-orders/WO-2026-0028'">
        <div class="wo-header">
            <div>
                <div class="wo-title">Fan F-201</div>
                <div class="wo-meta">WO-2026-0028 • South Plant</div>
            </div>
            <span class="status-badge status-completed">Completed</span>
        </div>
        <div class="wo-equipment">Centrifugal Fan</div>
        <div class="wo-footer">
            <span class="wo-due">Completed Apr 2</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </div>
    </div>
</div>

<script>
function setFilter(btn, filter) {
    document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    
    // Filter work order cards
    const cards = document.querySelectorAll('.wo-card');
    cards.forEach(card => {
        const status = card.getAttribute('data-status');
        const due = card.getAttribute('data-due');
        const facility = card.getAttribute('data-facility');
        
        let show = false;
        if (filter === 'all') show = true;
        else if (filter === 'today' && due === 'today') show = true;
        else if (filter === 'overdue' && due === 'overdue') show = true;
        else if (filter === 'in_progress' && status === 'in_progress') show = true;
        else if (filter === 'north_plant' && facility === 'North Plant') show = true;
        
        card.style.display = show ? 'block' : 'none';
    });
}
</script>
