<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#1976d2">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>ODM - <%= title %></title>
    <link rel="stylesheet" href="/css/odm-mobile.css?v=<%= Date.now() %>">
    <link rel="stylesheet" href="/css/odm-responsive.css?v=<%= Date.now() %>">
    <link rel="manifest" href="/manifest.json">
    <style>
        .bottom-nav {
            display: flex;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .bottom-nav::-webkit-scrollbar {
            display: none;
        }
        .bottom-nav .nav-item {
            flex: 1 0 auto;
            min-width: 64px;
            padding: 8px 4px;
        }
        .bottom-nav .nav-item span {
            font-size: 11px;
        }
    </style>
</head>
<body>
    <%- include('../partials/mobile-header', { showBack: showBack, title: title, headerAction: typeof headerAction !== 'undefined' ? headerAction : null }) %>

    <main class="app-content" style="padding-bottom: <%= showNav ? '80px' : '16px' %>;">
        <%- body %>
    </main>

    <% if (showNav) { %>
        <%- include('../partials/mobile-bottom-nav', { activeNav: activeNav }) %>
    <% } %>

    <!-- QR Scanner Modal -->
    <div id="qrModal" class="modal">
        <div class="modal-content qr-scanner">
            <div class="scanner-header">
                <h2>Scan Asset QR Code</h2>
                <button class="btn-close" onclick="closeQRScanner()">&times;</button>
            </div>
            <div class="scanner-viewport">
                <video id="qrVideo" autoplay playsinline></video>
                <div class="scanner-frame"></div>
                <p class="scanner-hint">Align QR code within frame</p>
            </div>
            <button class="btn-manual" onclick="manualEntry()">Enter Manually</button>
        </div>
    </div>

    <!-- Offline Indicator -->
    <div id="offlineIndicator" class="offline-indicator" style="display: none;">
        <span>⚠️ Offline Mode</span>
    </div>

    <script src="/js/permissions.js?v=<%= Date.now() %>"></script>
    <script src="/js/auth-check.js?v=<%= Date.now() %>"></script>
    <script src="/js/odm-mobile.js?v=<%= Date.now() %>"></script>
    <script>
        // Load organization badge
        (async function loadOrgBadge() {
            const badge = document.getElementById('orgBadge');
            const nameSpan = document.getElementById('orgNameBadge');
            if (!badge || !nameSpan) return;
            
            try {
                const response = await fetch('/api/organizations/my', { credentials: 'same-origin' });
                const data = await response.json();
                if (data.success && data.data.organization) {
                    nameSpan.textContent = data.data.organization.organization_name;
                    badge.style.display = 'block';
                }
            } catch (err) {
                // Silent fail - badge just won't show
            }
        })();
    </script>
</body>
</html>
