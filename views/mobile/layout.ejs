<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#1976d2">
    <title>ODM - <%= title %></title>
    <link rel="stylesheet" href="/css/odm-mobile.css">
    <link rel="manifest" href="/manifest.json">
</head>
<body>
    <!-- Header -->
    <header class="app-header">
        <button class="btn-back" onclick="history.back()" style="visibility: <%= showBack ? 'visible' : 'hidden' %>">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
        </button>
        <h1 class="header-title"><%= title %></h1>
        <button class="btn-qr" onclick="openQRScanner()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"/>
                <rect x="14" y="3" width="7" height="7"/>
                <rect x="14" y="14" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/>
            </svg>
        </button>
    </header>

    <!-- Main Content -->
    <main class="app-content">
        <%- body %>
    </main>

    <!-- Bottom Navigation -->
    <% if (showNav) { %>
    <nav class="bottom-nav">
        <a href="/mobile/home" class="nav-item <%= activeNav === 'home' ? 'active' : '' %>">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span>Home</span>
        </a>
        <a href="/mobile/work-orders" class="nav-item <%= activeNav === 'work-orders' ? 'active' : '' %>">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            <span>Tasks</span>
        </a>
        <a href="/mobile/profile" class="nav-item <%= activeNav === 'profile' ? 'active' : '' %>">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            <span>Profile</span>
        </a>
    </nav>
    <% } %>

    <!-- QR Scanner Modal -->
    <div id="qrModal" class="modal">
        <div class="modal-content qr-scanner">
            <div class="scanner-header">
                <h2>Scan Asset QR Code</h2>
                <button class="btn-close" onclick="closeQRScanner()">&times;</button>
            </div>
            <div class="scanner-viewport">
                <video id="qrVideo" autoplay playsinline></video>
                <div class="scanner-frame"></div>
                <p class="scanner-hint">Align QR code within frame</p>
            </div>
            <button class="btn-manual" onclick="manualEntry()">Enter Manually</button>
        </div>
    </div>

    <!-- Offline Indicator -->
    <div id="offlineIndicator" class="offline-indicator" style="display: none;">
        <span>⚠️ Offline Mode</span>
    </div>

    <script src="/js/odm-mobile.js"></script>
</body>
</html>
