<% title = 'Reports' %>
<% showBack = false %>
<% showNav = true %>
<% activeNav = 'reports' %>

<!-- Subscription Warning -->
<div id="subscriptionWarning" class="card" style="display: none; background: #fff3e0; border: 1px solid #ff9800; margin-bottom: 16px;">
  <div style="display: flex; align-items: center; gap: 12px;">
    <span style="font-size: 24px;">⚠️</span>
    <div>
      <div style="font-weight: 600; color: #ef6c00;">Subscription Required</div>
      <div style="font-size: 13px; color: #666;">Upgrade to access advanced reports</div>
    </div>
    <a href="/mobile/admin/subscription" class="btn btn-primary" style="margin-left: auto; font-size: 13px; padding: 8px 16px;">Upgrade</a>
  </div>
</div>

<!-- Current Plan Badge -->
<div id="planBadge" class="card" style="display: none; margin-bottom: 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <div style="font-size: 12px; opacity: 0.8;">Current Plan</div>
      <div id="planName" style="font-size: 18px; font-weight: 600;"></div>
    </div>
    <span id="planCode" class="plan-badge" style="background: rgba(255,255,255,0.2); color: white;"></span>
  </div>
</div>

<!-- Available Reports -->
<div id="reportsList" class="card" style="margin-bottom: 20px;">
  <div class="card-title">📊 Available Reports</div>
  <div style="color: var(--gray-600); padding: 20px; text-align: center;">
    Loading reports...
  </div>
</div>

<!-- Report Access Info -->
<div class="card" style="background: var(--gray-50);">
  <div class="card-title">ℹ️ Report Access by Plan</div>
  <div style="font-size: 13px; color: var(--gray-700); line-height: 1.6;">
    <div style="margin-bottom: 8px;"><strong>Free:</strong> Work Order Summary</div>
    <div style="margin-bottom: 8px;"><strong>Starter:</strong> + Equipment Reports</div>
    <div style="margin-bottom: 8px;"><strong>Professional:</strong> + All Reports & Trends</div>
    <div><strong>Enterprise:</strong> + CSV Export</div>
  </div>
</div>

<style>
.report-card {
  border: 1px solid var(--gray-200);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  transition: all 0.2s;
  position: relative;
}
.report-card:hover {
  border-color: var(--primary);
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
.report-card.locked {
  opacity: 0.7;
  background: var(--gray-50);
}
.report-card.locked::after {
  content: '🔒';
  position: absolute;
  top: 12px;
  right: 12px;
  font-size: 18px;
}
.report-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}
.report-icon {
  width: 40px;
  height: 40px;
  background: var(--primary);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}
.report-title {
  font-weight: 600;
  font-size: 16px;
}
.report-desc {
  font-size: 13px;
  color: var(--gray-600);
  margin-left: 52px;
}
.report-plan {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: #e3f2fd;
  color: var(--primary);
  margin-left: 52px;
  margin-top: 8px;
  display: inline-block;
}
.report-plan.required {
  background: #ffebee;
  color: var(--danger);
}
</style>

<script>
// Report definitions with plan requirements
const REPORTS = [
  {
    id: 'work-order-summary',
    title: 'Work Order Summary',
    description: 'Overview of work orders by status, priority, and type',
    icon: '📋',
    endpoint: '/api/reports/work-orders/summary',
    planRequired: 'free',
    params: ['start_date', 'end_date', 'facility_id']
  },
  {
    id: 'equipment-report',
    title: 'Equipment Maintenance Report',
    description: 'Maintenance history and work order counts by equipment',
    icon: '⚙️',
    endpoint: '/api/reports/equipment',
    planRequired: 'starter',
    params: ['facility_id', 'category']
  },
  {
    id: 'technician-report',
    title: 'Technician Performance',
    description: 'Work completed, hours logged, and efficiency by technician',
    icon: '👷',
    endpoint: '/api/reports/technicians',
    planRequired: 'professional',
    params: ['start_date', 'end_date', 'facility_id']
  },
  {
    id: 'schedule-compliance',
    title: 'Schedule Compliance',
    description: 'Overdue schedules and PM compliance metrics',
    icon: '📅',
    endpoint: '/api/reports/schedule-compliance',
    planRequired: 'professional',
    params: ['facility_id']
  },
  {
    id: 'trends',
    title: 'Work Order Trends',
    description: 'Historical trends and analytics over time',
    icon: '📈',
    endpoint: '/api/reports/trends',
    planRequired: 'professional',
    params: ['start_date', 'end_date']
  }
];

// Plan hierarchy for access checking
const PLAN_HIERARCHY = {
  'free': 0,
  'starter': 1,
  'professional': 2,
  'enterprise': 3,
  'utility': 3
};

let currentPlan = null;

document.addEventListener('DOMContentLoaded', async () => {
  await loadSubscription();
  renderReports();
});

async function loadSubscription() {
  try {
    const response = await fetch('/api/subscriptions/current', { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success && data.data.subscription) {
      currentPlan = data.data.subscription.plan;
      
      // Show plan badge
      const badge = document.getElementById('planBadge');
      const nameEl = document.getElementById('planName');
      const codeEl = document.getElementById('planCode');
      
      if (badge && nameEl && codeEl) {
        nameEl.textContent = currentPlan.name;
        codeEl.textContent = (currentPlan.code || 'FREE').toUpperCase();
        badge.style.display = 'block';
      }
    } else {
      // Default to free if no subscription
      currentPlan = { code: 'free', name: 'Free' };
    }
  } catch (err) {
    console.error('Failed to load subscription:', err);
    currentPlan = { code: 'free', name: 'Free' };
  }
}

function canAccessReport(report) {
  if (!currentPlan) return false;
  const userPlanLevel = PLAN_HIERARCHY[currentPlan.code] || 0;
  const requiredPlanLevel = PLAN_HIERARCHY[report.planRequired] || 0;
  return userPlanLevel >= requiredPlanLevel;
}

function renderReports() {
  const container = document.getElementById('reportsList');
  const userPlanLevel = PLAN_HIERARCHY[currentPlan?.code] || 0;
  
  // Check if any reports are locked
  const hasLockedReports = REPORTS.some(r => !canAccessReport(r));
  
  // Show warning if user has limited access
  const warningEl = document.getElementById('subscriptionWarning');
  if (warningEl && hasLockedReports) {
    warningEl.style.display = 'block';
  }
  
  let html = '<div class="card-title">📊 Available Reports</div>';
  
  REPORTS.forEach(report => {
    const hasAccess = canAccessReport(report);
    const planName = report.planRequired.charAt(0).toUpperCase() + report.planRequired.slice(1);
    
    html += `
      <div class="report-card ${hasAccess ? '' : 'locked'}" 
           ${hasAccess ? `onclick="viewReport('${report.id}')" style="cursor: pointer;"` : ''}>
        <div class="report-header">
          <div class="report-icon">${report.icon}</div>
          <div class="report-title">${report.title}</div>
        </div>
        <div class="report-desc">${report.description}</div>
        <span class="report-plan ${hasAccess ? '' : 'required'}">
          ${hasAccess ? '✓ Available' : `🔒 ${planName}+ required`}
        </span>
      </div>
    `;
  });
  
  // Add Export option for Enterprise
  const canExport = userPlanLevel >= 3;
  html += `
    <div class="report-card ${canExport ? '' : 'locked'}" 
         ${canExport ? `onclick="exportReports()" style="cursor: pointer;"` : ''}>
      <div class="report-header">
        <div class="report-icon">📥</div>
        <div class="report-title">Export Reports (CSV)</div>
      </div>
      <div class="report-desc">Download all reports as CSV files</div>
      <span class="report-plan ${canExport ? '' : 'required'}">
        ${canExport ? '✓ Available' : '🔒 Enterprise required'}
      </span>
    </div>
  `;
  
  container.innerHTML = html;
}

function viewReport(reportId) {
  const report = REPORTS.find(r => r.id === reportId);
  if (!report) return;
  
  // Navigate to report detail page
  const urlMap = {
    'work-order-summary': '/mobile/reports/work-order-summary',
    'equipment-report': '/mobile/reports/equipment-report',
    'technician-report': '/mobile/reports/technician-report',
    'schedule-compliance': '/mobile/reports/schedule-compliance',
    'trends': '/mobile/reports/trends'
  };
  
  window.location.href = urlMap[reportId] || `/mobile/reports/${reportId}`;
}

function exportReports() {
  // Show export options
  const types = ['work-orders', 'equipment', 'technicians'];
  const choice = prompt('Select export type:\n1. Work Orders\n2. Equipment\n3. Technicians');
  
  if (!choice) return;
  
  const typeMap = { '1': 'work-orders', '2': 'equipment', '3': 'technicians' };
  const type = typeMap[choice];
  
  if (type) {
    window.open(`/api/reports/export/${type}`, '_blank');
  }
}
</script>
