<% title = 'Profile' %>
<% showBack = false %>
<% showNav = true %>
<% activeNav = 'profile' %>

<!-- User Info -->
<div class="card" style="text-align: center; padding: 24px;">
    <div style="width: 80px; height: 80px; background: var(--primary); border-radius: 50%; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; color: white; font-size: 32px; font-weight: 600;">
        <%= user.initials %>
    </div>
    <div style="font-size: 20px; font-weight: 600; margin-bottom: 4px;"><%= user.name %></div>
    <div style="font-size: 14px; color: var(--gray-600); margin-bottom: 8px;"><%= user.email %></div>
    <span class="status-badge" style="background: <%= user.role === 'admin' ? '#e3f2fd' : user.role === 'supervisor' ? '#f3e5f5' : '#e8f5e9' %>; color: <%= user.role === 'admin' ? '#1565c0' : user.role === 'supervisor' ? '#7b1fa2' : '#2e7d32' %>; text-transform: uppercase;">
        <%= user.role %>
    </span>
</div>

<!-- Organization -->
<div class="card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
    <div style="display: flex; align-items: center; gap: 16px;">
        <% if (user.isPaid) { %>
            <!-- Paid: Show custom logo or upload placeholder -->
            <div id="orgLogoContainer" style="width: 56px; height: 56px; background: rgba(255,255,255,0.2); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; overflow: hidden;">
                <img id="orgLogo" src="<%= user.logoUrl || '/img/logo.png' %>" alt="Logo" style="width: 100%; height: 100%; object-fit: cover; display: <%= user.logoUrl ? 'block' : 'none' %>">
                <span id="orgLogoPlaceholder" style="display: <%= user.logoUrl ? 'none' : 'block' %>">🏭</span>
            </div>
        <% } else { %>
            <!-- Free: Show app logo -->
            <div style="width: 56px; height: 56px; background: rgba(255,255,255,0.2); border-radius: 16px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                <img src="/img/logo.png" alt="ODM-CMMS" style="width: 40px; height: 40px; object-fit: contain;">
            </div>
        <% } %>
        <div style="flex: 1; min-width: 0;">
            <div style="font-size: 12px; opacity: 0.8; margin-bottom: 2px;">Organization</div>
            <div id="profileOrgName" style="font-size: 20px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= user.organization %></div>
            <div id="profileOrgPlan" style="font-size: 13px; opacity: 0.9; margin-top: 4px;">
                <span class="plan-badge" style="background: rgba(255,255,255,0.2); color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; text-transform: uppercase;"><%= user.plan || 'Free' %></span>
            </div>
        </div>
        <a href="/mobile/admin/organization" style="color: white; opacity: 0.8; text-decoration: none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
    </div>
    
    <% if (user.isPaid && !user.logoUrl) { %>
    <!-- Paid users without logo: Show upload prompt -->
    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.2);">
        <a href="/mobile/admin/organization" style="color: white; font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 8px;">
            <span>📷</span>
            <span>Upload organization logo</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
    </div>
    <% } %>
</div>

<!-- Admin Link (only for admins/supervisors) -->
<% if (user.isAdmin) { %>
<div class="card" style="background: linear-gradient(135deg, var(--primary) 0%, #1565c0 100%); color: white;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
        <div>
            <div style="font-weight: 600; margin-bottom: 4px;">Administration</div>
            <div style="font-size: 13px; opacity: 0.9;">Manage users, organization & settings</div>
        </div>
        <a href="/mobile/admin" style="background: rgba(255,255,255,0.2); color: white; padding: 10px 16px; border-radius: 8px; text-decoration: none; font-weight: 500;">
            Open Admin →
        </a>
    </div>
</div>
<% } %>

<!-- Stats -->
<div class="card">
    <div class="card-title">This Month</div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 16px; text-align: center;">
        <div>
            <div style="font-size: 24px; font-weight: 700; color: var(--primary);"><%= stats.completedThisMonth %></div>
            <div style="font-size: 12px; color: var(--gray-600);">Completed</div>
        </div>
        <div>
            <div style="font-size: 24px; font-weight: 700; color: var(--warning);"><%= stats.findingsThisMonth %></div>
            <div style="font-size: 12px; color: var(--gray-600);">Findings</div>
        </div>
        <div>
            <div style="font-size: 24px; font-weight: 700; color: var(--success);"><%= stats.onTimeRate %>%</div>
            <div style="font-size: 12px; color: var(--gray-600);">On Time</div>
        </div>
    </div>
</div>

<!-- Settings -->
<div class="card">
    <div class="card-title">Settings</div>
    <div style="margin-top: 12px;">
        <a href="/mobile/home" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--gray-200); text-decoration: none; color: var(--text);">
            <span>🔔 Notifications</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
        <a href="/mobile/home" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--gray-200); text-decoration: none; color: var(--text);">
            <span>🔒 Change Password</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
        <a href="/mobile/home" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 0; text-decoration: none; color: var(--text);">
            <span>❓ Help & Support</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
    </div>
</div>

<!-- Sync Status -->
<div class="card">
    <div style="display: flex; align-items: center; justify-content: space-between;">
        <div>
            <div style="font-weight: 500; margin-bottom: 4px;">Sync Status</div>
            <div style="font-size: 14px; color: var(--gray-600);">Last synced: <%= syncStatus.lastSync %></div>
        </div>
        <div style="display: flex; align-items: center; gap: 8px; color: <%= syncStatus.isOnline ? 'var(--success)' : 'var(--danger)' %>;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span style="font-size: 14px; font-weight: 500;"><%= syncStatus.isOnline ? 'Online' : 'Offline' %></span>
        </div>
    </div>
</div>

<!-- Logout -->
<button class="btn btn-outline btn-full" style="margin-top: 8px; color: var(--danger); border-color: var(--danger);" onclick="logout()">
    Log Out
</button>

<div style="text-align: center; padding: 24px; font-size: 12px; color: var(--gray-600);">
    ODM-CMMS v2.0.0
</div>

<script>
// Load organization info
(async function loadOrgInfo() {
    try {
        const response = await fetch('/api/organizations/my', { credentials: 'same-origin' });
        const data = await response.json();
        if (data.success && data.data.organization) {
            const org = data.data.organization;
            const nameEl = document.getElementById('profileOrgName');
            if (nameEl && org.organization_name) {
                nameEl.textContent = org.organization_name;
            }
            
            // Load logo for paid users
            if (org.logo_url) {
                const logoImg = document.getElementById('orgLogo');
                const logoPlaceholder = document.getElementById('orgLogoPlaceholder');
                if (logoImg) {
                    logoImg.src = org.logo_url;
                    logoImg.style.display = 'block';
                }
                if (logoPlaceholder) {
                    logoPlaceholder.style.display = 'none';
                }
            }
        }
        
        // Also load subscription info
        const subResponse = await fetch('/api/subscriptions/current', { credentials: 'same-origin' });
        const subData = await subResponse.json();
        if (subData.success && subData.data.subscription) {
            const plan = subData.data.subscription.plan;
            const planEl = document.getElementById('profileOrgPlan');
            if (planEl && plan) {
                planEl.innerHTML = `<span class="plan-badge" style="background: rgba(255,255,255,0.2); color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; text-transform: uppercase;">${plan.code || 'FREE'}</span>`;
            }
        }
    } catch (err) {
        console.error('Failed to load org info:', err);
    }
})();

async function logout() {
    try {
        await fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' });
    } catch (err) {
        console.error('Logout error:', err);
    }
    localStorage.clear();
    window.location.href = '/login';
}
</script>
