<% title = 'Profile' %>
<% showBack = false %>
<% showNav = true %>
<% activeNav = 'profile' %>

<!-- User Info -->
<div class="card" style="text-align: center; padding: 24px;">
    <div style="width: 80px; height: 80px; background: var(--primary); border-radius: 50%; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; color: white; font-size: 32px; font-weight: 600;">
        JS
    </div>
    <div style="font-size: 20px; font-weight: 600; margin-bottom: 4px;">Juan Santos</div>
    <div style="font-size: 14px; color: var(--gray-600); margin-bottom: 8px;">j.santos@acme.com</div>
    <span class="status-badge" style="background: #e3f2fd; color: var(--primary);">Operator</span>
</div>

<!-- Organization -->
<div class="card">
    <div class="card-title">Organization</div>
    <div style="margin-top: 12px;">
        <div style="font-weight: 500; margin-bottom: 4px;">Acme Manufacturing</div>
        <div style="font-size: 14px; color: var(--gray-600);">Professional Plan</div>
    </div>
</div>

<!-- Stats -->
<div class="card">
    <div class="card-title">This Month</div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 16px; text-align: center;">
        <div>
            <div style="font-size: 24px; font-weight: 700; color: var(--primary);">42</div>
            <div style="font-size: 12px; color: var(--gray-600);">Completed</div>
        </div>
        <div>
            <div style="font-size: 24px; font-weight: 700; color: var(--warning);">3</div>
            <div style="font-size: 12px; color: var(--gray-600);">Findings</div>
        </div>
        <div>
            <div style="font-size: 24px; font-weight: 700; color: var(--success);">98%</div>
            <div style="font-size: 12px; color: var(--gray-600);">On Time</div>
        </div>
    </div>
</div>

<!-- Settings -->
<div class="card">
    <div class="card-title">Settings</div>
    <div style="margin-top: 12px;">
        <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--gray-200); text-decoration: none; color: var(--text);">
            <span>Change Facility</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
        <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--gray-200); text-decoration: none; color: var(--text);">
            <span>Notifications</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
        <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 0; text-decoration: none; color: var(--text);">
            <span>Help & Support</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
    </div>
</div>

<!-- Sync Status -->
<div class="card">
    <div style="display: flex; align-items: center; justify-content: space-between;">
        <div>
            <div style="font-weight: 500; margin-bottom: 4px;">Sync Status</div>
            <div style="font-size: 14px; color: var(--gray-600);">Last synced: 2 min ago</div>
        </div>
        <div style="display: flex; align-items: center; gap: 8px; color: var(--success);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span style="font-size: 14px; font-weight: 500;">Online</span>
        </div>
    </div>
</div>

<!-- Logout -->
<button class="btn btn-outline btn-full" style="margin-top: 8px; color: var(--danger); border-color: var(--danger);">
    Log Out
</button>

<div style="text-align: center; padding: 24px; font-size: 12px; color: var(--gray-600);">
    ODM v1.0.0
</div>
