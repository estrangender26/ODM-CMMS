            <div style="font-size: 20px; font-weight: 700;">7</div>
            <div style="font-size: 11px;">1</div>
        </div>
        <div style="min-width: 60px; text-align: center; padding: 12px 8px; background: var(--gray-200); border-radius: 12px;">
            <div style="font-size: 12px;">Wed</div>
            <div style="font-size: 20px; font-weight: 700;">8</div>
            <div style="font-size: 11px;">2</div>
