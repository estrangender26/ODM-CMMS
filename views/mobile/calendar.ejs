        </tbody>
    </table>
</div>

<script>
function previousDay() {
    console.log('Previous day');
}

function nextDay() {
    console.log('Next day');
}

function setFilter(btn, filter) {
    document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    
    const cards = document.querySelectorAll('.wo-card');
    cards.forEach(card => {
        const facility = card.getAttribute('data-facility');
        const assigned = card.getAttribute('data-assigned');
        
        let show = false;
        if (filter === 'all') show = true;
        else if (filter === 'north' && facility === 'North Plant') show = true;
        else if (filter === 'south' && facility === 'South Plant') show = true;
        else if (filter === 'mytasks' && assigned === 'Juan Santos') show = true;
        
        card.style.display = show ? 'block' : 'none';
    });
}

async function previewSchedule() {
    const resultDiv = document.getElementById('schedulerResult');
    resultDiv.style.display = 'block';
    resultDiv.innerHTML = '<span style="color: var(--gray-600);">Loading preview...</span>';
    
    try {
        const response = await fetch('/api/scheduler/preview', {
            credentials: 'same-origin'
        });
        
        if (!response.ok) {
            const text = await response.text();
            throw new Error(`HTTP ${response.status}: ${text.substring(0, 100)}`);
        }
        
        const data = await response.json();
        
        if (data.success) {
            resultDiv.innerHTML = `
                <span style="color: var(--success);">✓ Preview: ${data.data.would_create} work orders would be created</span>
                <br><small style="color: var(--gray-600);">${data.data.would_skip} already exist and would be skipped</small>
            `;
        } else {
            resultDiv.innerHTML = `<span style="color: var(--danger);">✗ ${data.message || data.error || 'Unknown error'}</span>`;
        }
    } catch (err) {
        resultDiv.innerHTML = `<span style="color: var(--danger);">✗ ${err.message}</span>`;
    }
}

async function runScheduler() {
    if (!confirm('Run scheduler now? This will create work orders.')) return;
    
    const resultDiv = document.getElementById('schedulerResult');
    resultDiv.style.display = 'block';
    resultDiv.innerHTML = '<span style="color: var(--gray-600);">Running scheduler...</span>';
    
    try {
        const response = await fetch('/api/scheduler/run', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin'
        });
        const data = await response.json();
        
        if (data.success) {
            resultDiv.innerHTML = `
                <span style="color: var(--success);">✓ ${data.message}</span>
                <br><small style="color: var(--gray-600);">Created: ${data.data.created} | Skipped: ${data.data.skipped}</small>
            `;
            // Reload after a delay to show new work orders
            setTimeout(() => location.reload(), 2000);
        } else {
            resultDiv.innerHTML = `<span style="color: var(--danger);">✗ ${data.message}</span>`;
        }
    } catch (err) {
        resultDiv.innerHTML = `<span style="color: var(--danger);">✗ Scheduler failed</span>`;
    }
}

// Load scheduler stats on page load
async function loadSchedulerStats() {
    try {
        const response = await fetch('/api/scheduler/preview', {
            credentials: 'same-origin'
        });
        const data = await response.json();
        
        if (data.success) {
            document.getElementById('activeSchedules').textContent = data.data.total || '0';
        }
    } catch (err) {
        console.log('Could not load scheduler stats');
    }
}

// Load active maintenance plans
async function loadMaintenancePlans() {
    try {
        const response = await fetch('/api/maintenance-plans?active=true', {
            credentials: 'same-origin'
        });
        const data = await response.json();
        
        if (data.success && data.data && data.data.length > 0) {
            const container = document.getElementById('plansContainer');
            const listCard = document.getElementById('plansList');
            
            container.innerHTML = data.data.map(p => `
                <div class="plan-item" style="padding: 12px; background: var(--gray-100); border-radius: 8px; margin-bottom: 8px;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div style="font-weight: 600; font-size: 14px;">${p.plan_name}</div>
                            <div style="font-size: 12px; color: var(--gray-600); margin-top: 2px;">
                                ${p.template_name} • ${p.frequency_type}, every ${p.frequency_interval} ${p.frequency_type === 'daily' ? 'day' : p.frequency_type === 'weekly' ? 'week' : 'month'}${p.frequency_interval > 1 ? 's' : ''}
                            </div>
                        </div>
                        <div style="display: flex; gap: 8px;">
                            <a href="/mobile/maintenance-plans/${p.id}/edit" class="btn btn-outline" style="padding: 4px 8px; font-size: 12px;">Edit</a>
                        </div>
                    </div>
                </div>
            `).join('');
            
            listCard.style.display = 'block';
        }
    } catch (err) {
        console.log('Could not load maintenance plans:', err);
    }
}

loadSchedulerStats();
loadMaintenancePlans();
</script>
