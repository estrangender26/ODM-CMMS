<% title = 'Scheduler' %>

<!-- Scheduler Status Card -->
<div class="card" style="background: linear-gradient(135deg, var(--primary) 0%, #1565c0 100%); color: white;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
            <div style="font-size: 13px; opacity: 0.9; margin-bottom: 4px;">Next Auto-Run</div>
            <div style="font-size: 24px; font-weight: 700;" id="nextRunTime">Tomorrow 6:00 AM</div>
        </div>
        <div style="text-align: right;">
            <div style="font-size: 13px; opacity: 0.9; margin-bottom: 4px;">Active Schedules</div>
            <div style="font-size: 32px; font-weight: 700;" id="activeSchedules">12</div>
        </div>
    </div>
</div>

<!-- Admin Actions -->
<div class="card" id="adminActions">
    <div class="card-title" style="display: flex; justify-content: space-between; align-items: center;">
        <span>Scheduler Controls</span>
        <a href="/mobile/maintenance-plans/new" class="btn btn-outline" style="font-size: 13px; padding: 6px 12px;">
            + New Plan
        </a>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px;">
        <button class="btn btn-primary btn-full" onclick="previewSchedule()">
            <span style="margin-right: 6px;">👁️</span> Preview
        </button>
        <button class="btn btn-success btn-full" onclick="runScheduler()">
            <span style="margin-right: 6px;">▶️</span> Run Now
        </button>
    </div>
    <div id="schedulerResult" style="margin-top: 12px; font-size: 13px; display: none;"></div>
</div>

<!-- Active Maintenance Plans (Schedules) -->
<div class="card" id="plansList" style="display: none;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
        <div class="card-title" style="margin: 0;">Active Maintenance Plans</div>
        <a href="/mobile/maintenance-plans" style="font-size: 13px; color: var(--primary);">View All</a>
    </div>
    <div style="font-size: 12px; color: var(--gray-600); margin-bottom: 12px;">
        Define WHEN and WHERE to apply inspection templates
    </div>
    <div id="plansContainer" style="margin-top: 12px;">
        <!-- Plans loaded dynamically -->
    </div>
</div>

<!-- Task Templates Info Card -->
<div class="card" style="background: var(--gray-100);">
    <div style="font-size: 13px; color: var(--gray-600);">
        <strong>📋 Task Templates:</strong> Define WHAT to inspect (inspection items)<br>
        <strong>📅 Maintenance Plans:</strong> Define WHEN and WHERE to apply templates
    </div>
    <div style="margin-top: 12px; display: flex; gap: 8px;">
        <a href="/mobile/templates" class="btn btn-outline" style="flex: 1; font-size: 13px;">Manage Templates</a>
        <a href="/mobile/maintenance-plans" class="btn btn-outline" style="flex: 1; font-size: 13px;">Manage Plans</a>
    </div>
</div>

<!-- Date Navigation -->
<div class="card" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 16px;">
    <button class="btn btn-outline" style="min-width: auto; padding: 8px 12px; height: 40px;" onclick="previousDay()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
    </button>
    <div style="font-weight: 600; font-size: 16px;">April 6, 2026</div>
    <button class="btn btn-outline" style="min-width: auto; padding: 8px 12px; height: 40px;" onclick="nextDay()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"/>
        </svg>
    </button>
</div>

<!-- Filters -->
<div class="filter-bar">
    <button class="filter-chip active" onclick="setFilter(this, 'all')">All</button>
    <button class="filter-chip" onclick="setFilter(this, 'north')">North Plant</button>
    <button class="filter-chip" onclick="setFilter(this, 'south')">South Plant</button>
    <button class="filter-chip" onclick="setFilter(this, 'mytasks')">My Tasks</button>
</div>

<!-- Work Orders for Selected Date -->
<div class="card">
    <div class="card-title">Scheduled Work Orders</div>
    
    <div style="margin-top: 16px;" id="woList">
        <div class="wo-card card" style="margin-bottom: 12px; border-left: 4px solid var(--warning);" data-facility="North Plant" data-assigned="Juan Santos" onclick="location.href='/mobile/inspection/WO-2026-0042'">
            <div class="wo-header">
                <div>
                    <div class="wo-title">Pump P-101</div>
                    <div class="wo-meta">WO-2026-0042 • North Plant</div>
                </div>
                <span class="status-badge status-released">Due</span>
            </div>
            <div class="wo-equipment">Centrifugal Pump</div>
            <div class="wo-footer">
                <span class="wo-due today">Due Today</span>
                <span style="font-size: 13px; color: var(--gray-600);">Juan Santos</span>
            </div>
        </div>
        
        <div class="wo-card card" style="margin-bottom: 12px; border-left: 4px solid var(--danger);" data-facility="South Plant" data-assigned="Maria Garcia" onclick="location.href='/mobile/inspection/WO-2026-0043'">
            <div class="wo-header">
                <div>
                    <div class="wo-title">Motor M-205</div>
                    <div class="wo-meta">WO-2026-0043 • South Plant</div>
                </div>
                <span class="status-badge status-released">Due</span>
            </div>
            <div class="wo-equipment">Electric Motor</div>
            <div class="wo-footer">
                <span class="wo-due overdue">2 Days Overdue</span>
                <span style="font-size: 13px; color: var(--gray-600);">Maria Garcia</span>
            </div>
        </div>
        
        <div class="wo-card card" style="margin-bottom: 0; border-left: 4px solid var(--success);" data-facility="South Plant" data-assigned="Juan Santos" onclick="location.href='/mobile/work-orders/WO-2026-0041'">
            <div class="wo-header">
                <div>
                    <div class="wo-title">Fan F-201</div>
                    <div class="wo-meta">WO-2026-0041 • South Plant</div>
                </div>
                <span class="status-badge status-completed">Done</span>
            </div>
            <div class="wo-equipment">Centrifugal Fan</div>
            <div class="wo-footer">
                <span class="wo-due">Completed 8:30 AM</span>
                <span style="font-size: 13px; color: var(--gray-600);">Juan Santos</span>
            </div>
        </div>
    </div>
</div>

