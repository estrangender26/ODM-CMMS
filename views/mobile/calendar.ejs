                <td>12</td>
                <td>3</td>
                <td class="run-status-success">✓ Success</td>
                <td>System</td>
            </tr>
            <tr>
                <td>Apr 5, 2026 06:00 AM</td>
                <td><span style="background: var(--gray-200); padding: 4px 12px; border-radius: 4px; font-size: 12px;">Auto</span></td>
                <td>8</td>
                <td>5</td>
                <td class="run-status-success">✓ Success</td>
                <td>System</td>
            </tr>
            <tr>
                <td>Apr 4, 2026 02:30 PM</td>
                <td><span style="background: var(--primary); color: white; padding: 4px 12px; border-radius: 4px; font-size: 12px;">Manual</span></td>
                <td>5</td>
