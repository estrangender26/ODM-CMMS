<% title = 'Asset Not Found' %>
<% showBack = true %>
<% showNav = false %>
<% activeNav = '' %>

<!-- Error State -->
<div style="text-align: center; padding: 48px 24px;">
    <div style="font-size: 64px; margin-bottom: 16px;">❌</div>
    <div style="font-weight: 600; font-size: 20px; margin-bottom: 8px;">Asset Not Found</div>
    <div style="color: var(--gray-600); margin-bottom: 8px;"><%= message %></div>
    <div style="font-family: monospace; background: var(--gray-100); padding: 8px 16px; border-radius: 4px; display: inline-block; margin-bottom: 32px;">
        <%= qrCode %>
    </div>
    
    <div style="display: flex; flex-direction: column; gap: 12px; max-width: 280px; margin: 0 auto;">
        <button class="btn btn-primary btn-large btn-full" onclick="location.href='/mobile/home'">
            Back to Home
        </button>
        <button class="btn btn-outline btn-full" onclick="retryScan()">
            Try Again
        </button>
        <button class="btn btn-text btn-full" onclick="manualEntry()">
            Enter Code Manually
        </button>
    </div>
</div>

<script>
function retryScan() {
    history.back();
    setTimeout(() => openQRScanner(), 100);
}

function manualEntry() {
    const code = prompt('Enter Asset QR Code:');
    if (code) {
        location.href = '/mobile/asset?code=' + encodeURIComponent(code);
    }
}
</script>
