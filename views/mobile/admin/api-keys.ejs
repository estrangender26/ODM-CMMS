<% title = 'API Keys' %>

<!-- Header -->
<div style="margin-bottom: 20px;">
  <a href="/mobile/admin" style="display: flex; align-items: center; gap: 8px; color: var(--primary); text-decoration: none; margin-bottom: 12px;">
    <span style="font-size: 20px;">←</span> Back to Admin
  </a>
  <h1 style="font-size: 24px; font-weight: 600; margin: 0;">API Keys</h1>
  <p style="color: var(--gray-600); margin: 8px 0 0 0; font-size: 14px;">Manage API access for integrations</p>
</div>

<!-- Usage Card -->
<div class="card" style="margin-bottom: 20px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <div style="font-size: 13px; opacity: 0.9; margin-bottom: 4px;">API Keys Used</div>
      <div id="usageDisplay" style="font-size: 28px; font-weight: 700;">- / -</div>
    </div>
    <div style="font-size: 40px; opacity: 0.3;">🔑</div>
  </div>
  <div id="usageBar" style="margin-top: 16px; height: 8px; background: rgba(255,255,255,0.2); border-radius: 4px; overflow: hidden;">
    <div style="height: 100%; width: 0%; background: white; border-radius: 4px; transition: width 0.3s;"></div>
  </div>
</div>

<!-- Usage Stats -->
<div class="card" style="margin-bottom: 20px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
    <div class="card-title" style="margin: 0;">API Usage (30 days)</div>
    <button class="btn btn-sm btn-outline" onclick="loadStats()">↻ Refresh</button>
  </div>
  
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; text-align: center;">
    <div>
      <div id="statTotalRequests" style="font-size: 24px; font-weight: 700; color: var(--primary);">-</div>
      <div style="font-size: 12px; color: var(--gray-600);">Total Requests</div>
    </div>
    <div>
      <div id="statErrorRate" style="font-size: 24px; font-weight: 700; color: var(--warning);">-</div>
      <div style="font-size: 12px; color: var(--gray-600);">Error Rate</div>
    </div>
    <div>
      <div id="statTopEndpoint" style="font-size: 14px; font-weight: 600; color: var(--gray-800); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">-</div>
      <div style="font-size: 12px; color: var(--gray-600);">Top Endpoint</div>
    </div>
  </div>
</div>

<!-- Add Key Button -->
<button class="btn btn-primary btn-full" onclick="showAddKeyModal()" style="margin-bottom: 16px;">
  + Create API Key
</button>

<!-- API Keys List -->
<div id="keysList">
  <div class="loading-state" style="text-align: center; padding: 40px; color: var(--gray-600);">
    Loading API keys...
  </div>
</div>

<!-- Create Key Modal -->
<div id="keyModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: flex-end;">
  <div style="background: white; border-radius: 20px 20px 0 0; padding: 24px; max-height: 90vh; overflow-y: auto; width: 100%;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h3 style="margin: 0; font-size: 20px;">Create API Key</h3>
      <button onclick="closeModal()" style="background: none; border: none; font-size: 24px; cursor: pointer;">×</button>
    </div>
    
    <form id="keyForm" onsubmit="saveKey(event)">
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Key Name *</label>
        <input type="text" id="keyName" required placeholder="e.g., Integration Production"
               style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px;">
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Scopes</label>
        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
          <label style="display: flex; align-items: center; gap: 6px; cursor: pointer;">
            <input type="checkbox" name="scopes" value="read" checked style="width: 18px; height: 18px;">
            <span style="font-size: 14px;">Read</span>
          </label>
          <label style="display: flex; align-items: center; gap: 6px; cursor: pointer;">
            <input type="checkbox" name="scopes" value="write" style="width: 18px; height: 18px;">
            <span style="font-size: 14px;">Write</span>
          </label>
          <label style="display: flex; align-items: center; gap: 6px; cursor: pointer;">
            <input type="checkbox" name="scopes" value="admin" style="width: 18px; height: 18px;">
            <span style="font-size: 14px;">Admin</span>
          </label>
        </div>
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Rate Limit (requests per minute)</label>
        <select id="keyRateLimit"
                style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px; background: white;">
          <option value="60">60</option>
          <option value="100">100</option>
          <option value="500">500</option>
          <option value="1000">1000</option>
        </select>
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Expiration (Optional)</label>
        <input type="date" id="keyExpiresAt"
               style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px;">
        <small style="color: var(--gray-600); font-size: 12px;">Leave empty for no expiration</small>
      </div>
      
      <div style="display: flex; gap: 12px;">
        <button type="button" class="btn btn-outline" onclick="closeModal()" style="flex: 1;">Cancel</button>
        <button type="submit" class="btn btn-primary" style="flex: 1;">Create Key</button>
      </div>
    </form>
  </div>
</div>

<!-- Show New Key Modal -->
<div id="newKeyModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center;">
  <div style="background: white; border-radius: 16px; padding: 32px; max-width: 90%; width: 500px; margin: 20px;">
    <div style="text-align: center; margin-bottom: 24px;">
      <div style="font-size: 64px; margin-bottom: 16px;">🔑</div>
      <h3 style="margin: 0; font-size: 24px; color: var(--success);">API Key Created!</h3>
    </div>
    
    <div style="background: #fff3e0; border: 1px solid #ff9800; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
      <div style="font-size: 13px; font-weight: 600; color: #ef6c00; margin-bottom: 8px;">
        ⚠️ This is the only time you'll see this key. Copy it now!
      </div>
      <div style="display: flex; gap: 8px;">
        <input type="text" id="newKeyValue" readonly
               style="flex: 1; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 14px; font-family: monospace; background: var(--gray-50);">
        <button class="btn btn-primary" onclick="copyNewKey()" style="white-space: nowrap;">Copy</button>
      </div>
    </div>
    
    <button class="btn btn-primary btn-full" onclick="closeNewKeyModal()">
      I've Copied the Key
    </button>
  </div>
</div>

<style>
.key-card {
  background: white;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid var(--gray-200);
}
.key-card:hover {
  border-color: var(--primary);
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.scope-badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  margin-right: 4px;
}
.scope-read { background: #e3f2fd; color: #1565c0; }
.scope-write { background: #fff3e0; color: #ef6c00; }
.scope-admin { background: #ffebee; color: #c62828; }
</style>

<script>
let keys = [];
let limit = 0;
let usage = 0;

document.addEventListener('DOMContentLoaded', () => {
  loadKeys();
  loadStats();
});

async function loadKeys() {
  try {
    const response = await fetch('/api/api-keys', { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success) {
      keys = data.data.keys || [];
      usage = keys.length;
      limit = data.data.limit || 5; // Default to 5 for professional
      
      renderKeys();
      updateUsageDisplay();
    }
  } catch (err) {
    console.error('Failed to load keys:', err);
    document.getElementById('keysList').innerHTML = `
      <div style="text-align: center; padding: 40px; color: var(--danger);">
        Failed to load API keys
      </div>
    `;
  }
}

function updateUsageDisplay() {
  const limitText = limit === null ? '∞' : limit;
  document.getElementById('usageDisplay').textContent = `${usage} / ${limitText}`;
  
  const percentage = limit ? Math.min((usage / limit) * 100, 100) : 0;
  document.querySelector('#usageBar div').style.width = `${percentage}%`;
}

function renderKeys() {
  if (keys.length === 0) {
    document.getElementById('keysList').innerHTML = `
      <div style="text-align: center; padding: 60px 40px; color: var(--gray-600);">
        <div style="font-size: 64px; margin-bottom: 16px;">🔑</div>
        <div style="font-weight: 500; margin-bottom: 8px;">No API keys yet</div>
        <div style="font-size: 14px;">Create an API key to enable programmatic access</div>
      </div>
    `;
    return;
  }
  
  document.getElementById('keysList').innerHTML = keys.map(key => `
    <div class="key-card">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
        <div>
          <div style="font-weight: 600; font-size: 16px; margin-bottom: 4px;">${escapeHtml(key.name)}</div>
          <div style="font-size: 13px; color: var(--gray-600); font-family: monospace;">
            ${key.prefix}...
          </div>
        </div>
        <div style="display: flex; gap: 8px;">
          ${key.is_active 
            ? `<span style="background: #e8f5e9; color: #2e7d32; padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600;">Active</span>`
            : `<span style="background: var(--gray-100); color: var(--gray-600); padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 600;">Inactive</span>`
          }
        </div>
      </div>
      
      <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 12px;">
        ${key.scopes.map(s => `<span class="scope-badge scope-${s}">${s}</span>`).join('')}
      </div>
      
      <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: var(--gray-600);">
        <div>
          ${key.last_used_at ? `Last used: ${formatDate(key.last_used_at)}` : 'Never used'}
          <span style="margin: 0 8px;">•</span>
          ${key.usage_count} requests
        </div>
        <div style="display: flex; gap: 8px;">
          <button class="btn btn-sm btn-outline" onclick="toggleKey(${key.id}, ${!key.is_active})" style="padding: 6px 12px; font-size: 12px;">
            ${key.is_active ? 'Disable' : 'Enable'}
          </button>
          <button class="btn btn-sm btn-outline" onclick="deleteKey(${key.id})" style="padding: 6px 12px; font-size: 12px; color: var(--danger); border-color: var(--danger);">
            Delete
          </button>
        </div>
      </div>
      
      ${key.expires_at ? `
        <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--gray-100); font-size: 12px; color: var(--gray-500);">
          Expires: ${formatDate(key.expires_at)}
        </div>
      ` : ''}
    </div>
  `).join('');
}

async function loadStats() {
  try {
    const response = await fetch('/api/api-keys/stats/usage?days=30', { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success) {
      document.getElementById('statTotalRequests').textContent = data.data.total_requests?.toLocaleString() || '0';
      document.getElementById('statErrorRate').textContent = data.data.error_rate + '%' || '0%';
      document.getElementById('statTopEndpoint').textContent = data.data.top_endpoints?.[0]?.endpoint || '-';
    }
  } catch (err) {
    console.error('Failed to load stats:', err);
  }
}

function showAddKeyModal() {
  document.getElementById('keyForm').reset();
  document.getElementById('keyModal').style.display = 'flex';
}

function closeModal() {
  document.getElementById('keyModal').style.display = 'none';
}

async function saveKey(event) {
  event.preventDefault();
  
  // Get selected scopes
  const scopeCheckboxes = document.querySelectorAll('input[name="scopes"]:checked');
  const scopes = Array.from(scopeCheckboxes).map(cb => cb.value);
  
  if (scopes.length === 0) {
    alert('Please select at least one scope');
    return;
  }
  
  const keyData = {
    name: document.getElementById('keyName').value,
    scopes: scopes,
    rate_limit_per_minute: parseInt(document.getElementById('keyRateLimit').value),
    expires_at: document.getElementById('keyExpiresAt').value || null
  };
  
  try {
    const response = await fetch('/api/api-keys', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(keyData)
    });
    
    const data = await response.json();
    
    if (data.success) {
      closeModal();
      
      // Show the new key
      document.getElementById('newKeyValue').value = data.data.key.api_key;
      document.getElementById('newKeyModal').style.display = 'flex';
      
      loadKeys();
    } else {
      alert(data.message || 'Failed to create API key');
    }
  } catch (err) {
    console.error('Failed to create key:', err);
    alert('Failed to create API key');
  }
}

function copyNewKey() {
  const input = document.getElementById('newKeyValue');
  input.select();
  navigator.clipboard.writeText(input.value).then(() => {
    alert('Copied to clipboard!');
  });
}

function closeNewKeyModal() {
  document.getElementById('newKeyModal').style.display = 'none';
}

async function toggleKey(id, newState) {
  try {
    const response = await fetch(`/api/api-keys/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ is_active: newState })
    });
    
    const data = await response.json();
    
    if (data.success) {
      loadKeys();
    } else {
      alert(data.message || 'Failed to update API key');
    }
  } catch (err) {
    console.error('Failed to toggle key:', err);
    alert('Failed to update API key');
  }
}

async function deleteKey(id) {
  if (!confirm('Are you sure you want to delete this API key? This action cannot be undone.')) {
    return;
  }
  
  try {
    const response = await fetch(`/api/api-keys/${id}`, {
      method: 'DELETE',
      credentials: 'same-origin'
    });
    
    const data = await response.json();
    
    if (data.success) {
      loadKeys();
    } else {
      alert(data.message || 'Failed to delete API key');
    }
  } catch (err) {
    console.error('Failed to delete key:', err);
    alert('Failed to delete API key');
  }
}

function formatDate(dateString) {
  if (!dateString) return 'Never';
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}
</script>
