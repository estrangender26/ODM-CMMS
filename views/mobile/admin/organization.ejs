<% title = 'Organization Settings' %>

<!-- Organization Info Card -->
<div class="card" style="margin-bottom: 20px;">
  <div class="card-title">Organization Information</div>
  
  <!-- Logo Upload Section (Paid only) -->
  <div id="logoSection" style="display: none; margin-bottom: 20px; padding: 20px; background: var(--bg-secondary); border-radius: 8px; text-align: center;">
    <div style="font-size: 14px; font-weight: 500; margin-bottom: 12px; color: var(--text-secondary);">Organization Logo</div>
    <div id="logoPreview" style="width: 100px; height: 100px; margin: 0 auto 12px; background: var(--bg-elevated); border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 2px dashed var(--border-medium);">
      <img id="orgLogoImg" src="" alt="Logo" style="width: 100%; height: 100%; object-fit: cover; display: none;">
      <span id="logoPlaceholder" style="font-size: 40px;">🏭</span>
    </div>
    <input type="file" id="logoInput" accept="image/*" style="display: none;" onchange="handleLogoUpload(event)">
    <button type="button" class="btn btn-outline" onclick="document.getElementById('logoInput').click()">
      📷 Upload Logo
    </button>
    <div style="font-size: 12px; color: var(--text-muted); margin-top: 8px;">Max 2MB (JPG, PNG)</div>
  </div>
  
  <!-- Free Plan Logo Notice -->
  <div id="logoFreeNotice" style="margin-bottom: 20px; padding: 16px; background: var(--bg-secondary); border-radius: 8px; text-align: center;">
    <div style="font-size: 14px; color: var(--text-secondary);">
      🏭 <strong>Free Plan:</strong> Upgrade to Professional or Enterprise to upload your organization logo
    </div>
    <a href="/mobile/admin/subscription" class="btn btn-primary btn-full" style="margin-top: 12px;">
      View Plans
    </a>
  </div>
  
  <div id="orgForm">
    <div style="margin-bottom: 16px;">
      <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--text-secondary);">Organization Name</label>
      <input type="text" id="orgName" 
             style="width: 100%; padding: 12px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 16px;">
    </div>
    
    <div style="margin-bottom: 16px;">
      <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--text-secondary);">Industry</label>
      <select id="industryCode" 
              style="width: 100%; padding: 12px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 16px; background: var(--bg-elevated);">
        <option value="">Select Industry</option>
      </select>
    </div>
    
    <div style="margin-bottom: 16px;">
      <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--text-secondary);">Billing Email</label>
      <input type="email" id="billingEmail"
             style="width: 100%; padding: 12px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 16px;">
    </div>
    
    <div style="margin-bottom: 20px;">
      <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--text-secondary);">Phone</label>
      <input type="tel" id="orgPhone"
             style="width: 100%; padding: 12px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 16px;">
    </div>
    
    <div id="orgError" style="color: var(--danger); margin-bottom: 16px; font-size: 14px; display: none;"></div>
    <div id="orgSuccess" style="color: var(--success); margin-bottom: 16px; font-size: 14px; display: none;"></div>
    
    <button type="button" class="btn btn-primary" onclick="saveOrganization()" id="saveOrgBtn">
      Save Changes
    </button>
  </div>
</div>

<!-- Usage Stats Card -->
<div class="card" style="margin-bottom: 20px;">
  <div class="card-title">Usage & Limits</div>
  
  <div id="usageStats" style="display: flex; flex-direction: column; gap: 20px;">
    <div class="loading-state" style="text-align: center; padding: 20px; color: var(--text-secondary);">
      Loading usage stats...
    </div>
  </div>
</div>

<!-- Subscription Card -->
<div class="card" style="margin-bottom: 20px;">
  <div class="card-title">Subscription</div>
  
  <div id="subscriptionInfo">
    <div class="loading-state" style="text-align: center; padding: 20px; color: var(--text-secondary);">
      Loading subscription...
    </div>
  </div>
</div>

<!-- Danger Zone -->
<div class="card" style="border: 1px solid var(--danger); background: #fff5f5;">
  <div class="card-title" style="color: var(--danger);">Danger Zone</div>
  
  <div style="display: flex; flex-direction: column; gap: 12px;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <div style="font-weight: 500;">Deactivate Organization</div>
        <div style="font-size: 13px; color: var(--text-secondary);">Temporarily disable all access</div>
      </div>
      <button class="btn btn-outline" style="color: var(--danger); border-color: var(--danger);" onclick="deactivateOrg()">
        Deactivate
      </button>
    </div>
  </div>
</div>

<style>
.usage-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.usage-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.usage-label {
  font-weight: 500;
  color: var(--gray-800);
  font-size: 14px;
}
.usage-value {
  font-size: 13px;
  color: var(--text-secondary);
  font-weight: 500;
}
.usage-bar {
  height: 6px;
  background: var(--gray-200);
  border-radius: 3px;
  overflow: hidden;
}
.usage-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.3s ease;
  min-width: 2px; /* Ensure very small percentages are visible */
}
.usage-fill.safe { background: var(--success); }
.usage-fill.warning { background: var(--warning); }
.usage-fill.danger { background: var(--danger); }

.plan-badge {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
}
.plan-free { background: #e8f5e9; color: #2e7d32; }
.plan-basic { background: #e3f2fd; color: #1565c0; }
.plan-professional { background: #f3e5f5; color: #7b1fa2; }
.plan-enterprise { background: #fff3e0; color: #ef6c00; }

.status-badge {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
}
.status-active { background: #e8f5e9; color: #2e7d32; }
.status-trial { background: #fff3e0; color: #ef6c00; }
.status-cancelled { background: #ffebee; color: #c62828; }
</style>

<script>
let currentOrg = null;
let currentSubscription = null;

document.addEventListener('DOMContentLoaded', async () => {
  await loadIndustries();
  await loadOrganization();
  await loadUsageStats();
  await loadSubscription();
});

async function loadIndustries() {
  try {
    const response = await fetch('/api/industries?is_active=true', { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success) {
      const select = document.getElementById('industryCode');
      data.data.industries.forEach(industry => {
        const option = document.createElement('option');
        option.value = industry.code;
        option.textContent = industry.name;
        select.appendChild(option);
      });
    }
  } catch (err) {
    console.error('Failed to load industries:', err);
  }
}

async function loadOrganization() {
  try {
    const response = await fetch('/api/organizations/my', { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success) {
      currentOrg = data.data.organization;
      document.getElementById('orgName').value = currentOrg.organization_name || '';
      document.getElementById('billingEmail').value = currentOrg.billing_email || '';
      document.getElementById('orgPhone').value = currentOrg.phone || '';
      if (currentOrg.industry) {
        document.getElementById('industryCode').value = currentOrg.industry;
      }
      
      // Load logo if exists
      if (currentOrg.logo_url) {
        document.getElementById('orgLogoImg').src = currentOrg.logo_url;
        document.getElementById('orgLogoImg').style.display = 'block';
        document.getElementById('logoPlaceholder').style.display = 'none';
      }
    } else {
      showError('orgError', data.message);
    }
  } catch (err) {
    console.error('Failed to load organization:', err);
    showError('orgError', 'Failed to load organization');
  }
}

async function loadUsageStats() {
  try {
    if (!currentOrg) return;
    
    const response = await fetch(`/api/organizations/${currentOrg.id}/stats`, { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success) {
      const stats = data.data.stats || {};
      const limits = stats.limits || {};
      
      // Use actual counts
      const userCount = stats.user_count || 0;
      const facilityCount = stats.facility_count || 0;
      const equipmentCount = stats.equipment_count || 0;
      const workOrderCount = stats.work_order_count || 0;
      
      // Use limits from subscription plan ONLY
      // API returns null for unlimited plans (Enterprise), undefined if not set
      const maxUsers = limits.max_users === undefined ? 5 : limits.max_users;
      const maxFacilities = limits.max_facilities === undefined ? 1 : limits.max_facilities;
      const maxEquipment = limits.max_equipment === undefined ? 10 : limits.max_equipment;
      const maxWorkOrders = limits.max_work_orders_per_month ?? null;
      
      // Calculate percentages directly from counts and limits (ignore API percentages)
      const userPct = maxUsers > 0 ? (userCount / maxUsers) * 100 : 0;
      const facilityPct = maxFacilities > 0 ? (facilityCount / maxFacilities) * 100 : 0;
      const equipmentPct = maxEquipment > 0 ? (equipmentCount / maxEquipment) * 100 : 0;
      const workOrderPct = maxWorkOrders > 0 ? (workOrderCount / maxWorkOrders) * 100 : 0;
      
      const getBarClass = (pct) => {
        if (pct < 70) return 'safe';
        if (pct < 90) return 'warning';
        return 'danger';
      };
      
      const formatLimit = (limit) => limit === null || limit === undefined ? '∞' : limit;
      
      // Build Work Orders HTML - show progress bar only if there's a monthly limit
      const workOrdersHtml = maxWorkOrders > 0 ? `
        <div class="usage-bar">
          <div class="usage-fill ${getBarClass(workOrderPct)}" style="width: ${Math.min(workOrderPct, 100)}%"></div>
        </div>
      ` : '';
      
      document.getElementById('usageStats').innerHTML = `
        <div class="usage-item">
          <div class="usage-header">
            <span class="usage-label">👥 Users</span>
            <span class="usage-value">${userCount} / ${formatLimit(maxUsers)}</span>
          </div>
          <div class="usage-bar">
            <div class="usage-fill ${getBarClass(userPct)}" style="width: ${Math.min(userPct, 100)}%"></div>
          </div>
        </div>
        
        <div class="usage-item">
          <div class="usage-header">
            <span class="usage-label">🏭 Facilities</span>
            <span class="usage-value">${facilityCount} / ${formatLimit(maxFacilities)}</span>
          </div>
          <div class="usage-bar">
            <div class="usage-fill ${getBarClass(facilityPct)}" style="width: ${Math.min(facilityPct, 100)}%"></div>
          </div>
        </div>
        
        <div class="usage-item">
          <div class="usage-header">
            <span class="usage-label">⚙️ Equipment</span>
            <span class="usage-value">${equipmentCount} / ${formatLimit(maxEquipment)}</span>
          </div>
          <div class="usage-bar">
            <div class="usage-fill ${getBarClass(equipmentPct)}" style="width: ${Math.min(equipmentPct, 100)}%"></div>
          </div>
        </div>
        
        <div class="usage-item">
          <div class="usage-header">
            <span class="usage-label">📋 Work Orders (This Month)</span>
            <span class="usage-value">${workOrderCount}${maxWorkOrders ? ' / ' + maxWorkOrders : ''}</span>
          </div>
          ${workOrdersHtml}
        </div>
      `;
    } else {
      // Show default empty state
      document.getElementById('usageStats').innerHTML = `
        <div style="text-align: center; color: var(--text-secondary); padding: 20px;">
          No usage data available
        </div>
      `;
    }
  } catch (err) {
    console.error('Failed to load usage stats:', err);
    document.getElementById('usageStats').innerHTML = `
      <div style="text-align: center; color: var(--text-secondary); padding: 20px;">
        No usage data available
      </div>
    `;
  }
}

async function loadSubscription() {
  try {
    const response = await fetch('/api/subscriptions/current', { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success) {
      const subscription = data.data.subscription;
      const plan = subscription.plan;
      currentSubscription = subscription;
      
      // Show/hide logo section based on plan
      const isPaid = !['free'].includes(plan.code);
      const logoSection = document.getElementById('logoSection');
      const logoFreeNotice = document.getElementById('logoFreeNotice');
      
      if (isPaid) {
        logoSection.style.display = 'block';
        logoFreeNotice.style.display = 'none';
      } else {
        logoSection.style.display = 'none';
        logoFreeNotice.style.display = 'block';
      }
      
      const planClass = `plan-${plan.code || 'free'}`;
      const statusClass = `status-${subscription.status}`;
      
      document.getElementById('subscriptionInfo').innerHTML = `
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
          <div>
            <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 4px;">Current Plan</div>
            <div style="font-size: 20px; font-weight: 600;">${plan.name}</div>
          </div>
          <span class="plan-badge ${planClass}">${(plan.code || 'FREE').toUpperCase()}</span>
        </div>
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
          <div>
            <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 4px;">Status</div>
            <span class="status-badge ${statusClass}">${subscription.status}</span>
          </div>
          <div style="text-align: right;">
            <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 4px;">Renews</div>
            <div>${formatDate(subscription.currentPeriodEnd)}</div>
          </div>
        </div>
        
        <div style="background: var(--bg-secondary); padding: 16px; border-radius: 8px; margin-bottom: 16px;">
          <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 8px;">Plan Includes</div>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; text-align: center;">
            <div>
              <div style="font-size: 20px; font-weight: 600;">${plan.max_users || '∞'}</div>
              <div style="font-size: 12px; color: var(--text-secondary);">Users</div>
            </div>
            <div>
              <div style="font-size: 20px; font-weight: 600;">${plan.max_facilities || '∞'}</div>
              <div style="font-size: 12px; color: var(--text-secondary);">Facilities</div>
            </div>
            <div>
              <div style="font-size: 20px; font-weight: 600;">${plan.max_equipment || '∞'}</div>
              <div style="font-size: 12px; color: var(--text-secondary);">Equipment</div>
            </div>
          </div>
        </div>
        
        <a href="/mobile/admin/subscription" class="btn btn-primary btn-full" style="text-align: center; display: block; text-decoration: none;">
          Manage Subscription
        </a>
      `;
    } else {
      document.getElementById('subscriptionInfo').innerHTML = `
        <div style="text-align: center; color: var(--text-secondary);">
          <div style="margin-bottom: 12px;">No active subscription</div>
          <a href="/mobile/admin/subscription" class="btn btn-primary btn-full" style="text-align: center; display: block; text-decoration: none;">
            View Plans
          </a>
        </div>
      `;
    }
  } catch (err) {
    console.error('Failed to load subscription:', err);
    document.getElementById('subscriptionInfo').innerHTML = `
      <div style="text-align: center; color: var(--text-secondary);">
        <div style="margin-bottom: 12px;">No subscription data available</div>
        <a href="/mobile/admin/subscription" class="btn btn-primary btn-full" style="text-align: center; display: block; text-decoration: none;">
          View Plans
        </a>
      </div>
    `;
  }
}

async function saveOrganization() {
  const btn = document.getElementById('saveOrgBtn');
  btn.disabled = true;
  btn.textContent = 'Saving...';
  
  try {
    const payload = {
      organization_name: document.getElementById('orgName').value,
      industry: document.getElementById('industryCode').value || null,
      billing_email: document.getElementById('billingEmail').value,
      phone: document.getElementById('orgPhone').value
    };
    
    const response = await fetch(`/api/organizations/${currentOrg.id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(payload)
    });
    
    const data = await response.json();
    
    if (data.success) {
      showSuccess('orgSuccess', 'Organization updated successfully');
      hideError('orgError');
    } else {
      showError('orgError', data.message);
      hideSuccess('orgSuccess');
    }
  } catch (err) {
    console.error('Failed to save organization:', err);
    showError('orgError', 'Failed to save organization');
    hideSuccess('orgSuccess');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Save Changes';
  }
}

function deactivateOrg() {
  if (!confirm('WARNING: This will deactivate your organization and prevent all users from accessing the system. Are you sure?')) {
    return;
  }
  
  alert('Please contact support to deactivate your organization.');
}

function formatDate(dateString) {
  if (!dateString) return 'N/A';
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function showError(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.style.display = 'block';
}

function hideError(id) {
  document.getElementById(id).style.display = 'none';
}

function showSuccess(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.style.display = 'block';
  setTimeout(() => hideSuccess(id), 3000);
}

function hideSuccess(id) {
  document.getElementById(id).style.display = 'none';
}

// Logo Upload Handler
async function handleLogoUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  
  // Validate file
  if (file.size > 2 * 1024 * 1024) {
    showError('orgError', 'Logo must be less than 2MB');
    return;
  }
  
  if (!['image/jpeg', 'image/png', 'image/gif'].includes(file.type)) {
    showError('orgError', 'Logo must be JPG, PNG or GIF');
    return;
  }
  
  // Preview
  const reader = new FileReader();
  reader.onload = function(e) {
    document.getElementById('orgLogoImg').src = e.target.result;
    document.getElementById('orgLogoImg').style.display = 'block';
    document.getElementById('logoPlaceholder').style.display = 'none';
  };
  reader.readAsDataURL(file);
  
  // Upload
  const formData = new FormData();
  formData.append('logo', file);
  
  try {
    const response = await fetch('/api/organizations/logo', {
      method: 'POST',
      credentials: 'same-origin',
      body: formData
    });
    
    const data = await response.json();
    
    if (data.success) {
      showSuccess('orgSuccess', 'Logo uploaded successfully!');
      hideError('orgError');
    } else {
      showError('orgError', data.message || 'Failed to upload logo');
      hideSuccess('orgSuccess');
    }
  } catch (err) {
    console.error('Upload error:', err);
    showError('orgError', 'Failed to upload logo. Please try again.');
  }
}
</script>
