<!-- Organization Card -->
<div id="adminOrgCard" class="card" style="margin-bottom: 16px; background: linear-gradient(135deg, #78350f 0%, #92400e 50%, #b45309 100%); color: white; display: none; border: none;">
  <div style="display: flex; align-items: center; gap: 16px;">
    <div style="width: 56px; height: 56px; background: rgba(255,255,255,0.2); border-radius: 16px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
      <img src="/img/logo.png" alt="ODM-CMMS" style="width: 40px; height: 40px; object-fit: contain;">
    </div>
    <div style="flex: 1; min-width: 0;">
      <div style="font-size: 12px; opacity: 0.8; margin-bottom: 2px;">Organization</div>
      <div id="adminOrgName" style="font-size: 20px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
      <div id="adminOrgPlan" style="font-size: 13px; opacity: 0.9; margin-top: 4px;"></div>
    </div>
  </div>
</div>

<!-- Mobile Admin Grid -->
<div class="admin-mobile-grid" style="display: flex; flex-direction: column; gap: 2px; background: var(--bg-primary); padding: 16px;">
  <% sections.forEach(function(section, index) { %>
    <div class="card admin-section-card" onclick="location.href='<%= section.href %>'" style="padding: 14px 16px; display: flex; flex-direction: row; align-items: center; gap: 16px; cursor: pointer; border-radius: 0; <%= index === 0 ? 'border-radius: 12px 12px 0 0;' : index === sections.length - 1 ? 'border-radius: 0 0 12px 12px;' : 'border-radius: 0;' %> <%= index < sections.length - 1 ? 'border-bottom: 1px solid var(--border-light);' : '' %>">
      <div class="admin-section-icon" style="font-size: 22px; width: 28px; text-align: center; flex-shrink: 0;">
        <%= section.icon === 'rocket' ? '🚀' : section.icon === 'building' ? '🏭' : section.icon === 'box' ? '📦' : section.icon === 'file' ? '📋' : section.icon === 'calendar' ? '📅' : section.icon === 'qr' ? '🏷️' : section.icon === 'users' ? '👥' : section.icon === 'envelope' ? '✉️' : section.icon === 'settings' ? '⚙️' : section.icon === 'credit' ? '💳' : section.icon === 'form' ? '📝' : section.icon === 'key' ? '🔑' : section.icon === 'lock' ? '🔐' : section.icon === 'shield' ? '🛡️' : '⚙️' %>
      </div>
      <div class="admin-section-title" style="flex: 1; font-size: 16px; font-weight: 500; color: var(--text-primary);"><%= section.label %></div>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; color: var(--text-muted);">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </div>
  <% }) %>
</div>

<!-- Desktop Admin with Sidebar (hidden on mobile) -->
<div class="admin-desktop-layout" style="display: none;">
  <aside class="admin-sidebar">
    <nav class="admin-sidebar-nav">
      <% sections.forEach(function(section, index) { %>
        <a href="<%= section.href %>" class="admin-sidebar-item <%= index === 0 ? 'active' : '' %>">
          <span class="admin-sidebar-icon">
            <%= section.icon === 'rocket' ? '🚀' : section.icon === 'building' ? '🏭' : section.icon === 'box' ? '📦' : section.icon === 'file' ? '📋' : section.icon === 'calendar' ? '📅' : section.icon === 'qr' ? '🏷️' : section.icon === 'users' ? '👥' : section.icon === 'envelope' ? '✉️' : section.icon === 'settings' ? '⚙️' : section.icon === 'credit' ? '💳' : section.icon === 'form' ? '📝' : section.icon === 'key' ? '🔑' : section.icon === 'lock' ? '🔐' : section.icon === 'shield' ? '🛡️' : '⚙️' %>
          </span>
          <span class="admin-sidebar-label"><%= section.label %></span>
        </a>
      <% }) %>
    </nav>
  </aside>
  
  <main class="admin-main-content">
    <div class="admin-dashboard-header">
      <h1>Admin Dashboard</h1>
      <p>Manage your maintenance system settings and data</p>
    </div>
    
    <div class="admin-dashboard-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
      <div class="admin-dash-card">
        <div class="admin-dash-icon">👥</div>
        <div class="admin-dash-info">
          <h3>Users</h3>
          <p class="admin-dash-count" id="userCount">-</p>
          <a href="/mobile/admin/users" class="admin-dash-link">Manage →</a>
        </div>
      </div>
      
      <div class="admin-dash-card">
        <div class="admin-dash-icon">⚙️</div>
        <div class="admin-dash-info">
          <h3>Organization</h3>
          <p class="admin-dash-count" style="font-size: 14px;">Settings</p>
          <a href="/mobile/admin/organization" class="admin-dash-link">Manage →</a>
        </div>
      </div>
      
      <div class="admin-dash-card">
        <div class="admin-dash-icon">💳</div>
        <div class="admin-dash-info">
          <h3>Subscription</h3>
          <p class="admin-dash-count" id="planName" style="font-size: 14px;">-</p>
          <a href="/mobile/admin/subscription" class="admin-dash-link">Manage →</a>
        </div>
      </div>
      
      <div class="admin-dash-card">
        <div class="admin-dash-icon">🏭</div>
        <div class="admin-dash-info">
          <h3>Facilities</h3>
          <p class="admin-dash-count" id="facilityCount">-</p>
          <a href="/mobile/admin/facilities" class="admin-dash-link">Manage →</a>
        </div>
      </div>
      
      <div class="admin-dash-card">
        <div class="admin-dash-icon">📦</div>
        <div class="admin-dash-info">
          <h3>Assets</h3>
          <p class="admin-dash-count" id="assetCount">-</p>
          <a href="/mobile/admin/assets" class="admin-dash-link">Manage →</a>
        </div>
      </div>
      
      <div class="admin-dash-card">
        <div class="admin-dash-icon">📋</div>
        <div class="admin-dash-info">
          <h3>Templates</h3>
          <p class="admin-dash-count" id="templateCount">-</p>
          <a href="/mobile/admin/templates" class="admin-dash-link">Manage →</a>
        </div>
      </div>
      
      <div class="admin-dash-card">
        <div class="admin-dash-icon">📊</div>
        <div class="admin-dash-info">
          <h3>Coverage</h3>
          <p class="admin-dash-count" style="font-size: 14px;">Industry/Family</p>
          <a href="/mobile/admin/coverage" class="admin-dash-link">Manage →</a>
        </div>
      </div>
    </div>
    
    <script>
    // Load real stats
    async function loadAdminStats() {
      try {
        // Load org stats
        const orgRes = await fetch('/api/organizations/my', { credentials: 'same-origin' });
        const orgData = await orgRes.json();
        if (orgData.success) {
          const org = orgData.data.organization;
          document.getElementById('userCount').textContent = org.user_count || '-';
          document.getElementById('facilityCount').textContent = org.facility_count || '-';
          document.getElementById('assetCount').textContent = org.equipment_count || '-';
        }
        
        // Load subscription
        const subRes = await fetch('/api/subscriptions/current', { credentials: 'same-origin' });
        const subData = await subRes.json();
        if (subData.success) {
          document.getElementById('planName').textContent = subData.data.plan.name || '-';
        }
      } catch (err) {
        console.error('Failed to load stats:', err);
      }
    }
    loadAdminStats();
    </script>
    
    <div class="admin-quick-actions">
      <h2>Quick Actions</h2>
      <div class="admin-action-buttons">
        <a href="/mobile/onboarding" class="btn btn-primary">
          <span>🚀</span> Start Onboarding
        </a>
        <a href="/mobile/qr-labels" class="btn btn-outline">
          <span>🏷️</span> Print QR Labels
        </a>
        <a href="/mobile/calendar" class="btn btn-outline">
          <span>📅</span> View Scheduler
        </a>
      </div>
    </div>
  </main>
</div>

<script>
// Load organization info
(async function loadAdminOrgInfo() {
    try {
        // Load org
        const orgResponse = await fetch('/api/organizations/my', { credentials: 'same-origin' });
        const orgData = await orgResponse.json();
        
        // Load subscription
        const subResponse = await fetch('/api/subscriptions/current', { credentials: 'same-origin' });
        const subData = await subResponse.json();
        
        if (orgData.success && orgData.data.organization) {
            const org = orgData.data.organization;
            const card = document.getElementById('adminOrgCard');
            const nameEl = document.getElementById('adminOrgName');
            const planEl = document.getElementById('adminOrgPlan');
            
            if (nameEl) nameEl.textContent = org.organization_name;
            
            if (subData.success && subData.data.subscription) {
                const plan = subData.data.subscription.plan;
                if (planEl && plan) {
                    planEl.innerHTML = `<span class="plan-badge" style="background: rgba(255,255,255,0.2); color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; text-transform: uppercase;">${plan.code || 'FREE'}</span>`;
                }
            }
            
            if (card) card.style.display = 'block';
        }
    } catch (err) {
        console.error('Failed to load admin org info:', err);
    }
})();
</script>
