<% title = 'Custom Fields' %>

<!-- Header -->
<div style="margin-bottom: 20px;">
  <a href="/mobile/admin" style="display: flex; align-items: center; gap: 8px; color: var(--primary); text-decoration: none; margin-bottom: 12px;">
    <span style="font-size: 20px;">←</span> Back to Admin
  </a>
  <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Custom Fields</h1>
  <p style="color: var(--gray-600); margin: 8px 0 0 0; font-size: 14px;">Create custom fields for work orders, equipment, and more</p>
</div>

<!-- Usage Stats -->
<div class="card" style="margin-bottom: 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <div style="font-size: 13px; opacity: 0.9; margin-bottom: 4px;">Fields Used</div>
      <div id="usageDisplay" style="font-size: 28px; font-weight: 700;">- / -</div>
    </div>
    <div style="font-size: 40px; opacity: 0.3;">📝</div>
  </div>
  <div id="usageBar" style="margin-top: 16px; height: 8px; background: rgba(255,255,255,0.2); border-radius: 4px; overflow: hidden;">
    <div style="height: 100%; width: 0%; background: white; border-radius: 4px; transition: width 0.3s;"></div>
  </div>
</div>

<!-- Entity Type Tabs -->
<div style="display: flex; gap: 8px; margin-bottom: 16px; overflow-x: auto; padding-bottom: 4px;">
  <button class="entity-tab active" data-entity="work_order" onclick="switchEntity('work_order')" style="padding: 10px 20px; border-radius: 20px; border: none; background: var(--primary); color: white; font-weight: 500; white-space: nowrap; cursor: pointer;">
    Work Orders
  </button>
  <button class="entity-tab" data-entity="equipment" onclick="switchEntity('equipment')" style="padding: 10px 20px; border-radius: 20px; border: 1px solid var(--gray-300); background: white; color: var(--gray-700); font-weight: 500; white-space: nowrap; cursor: pointer;">
    Equipment
  </button>
  <button class="entity-tab" data-entity="finding" onclick="switchEntity('finding')" style="padding: 10px 20px; border-radius: 20px; border: 1px solid var(--gray-300); background: white; color: var(--gray-700); font-weight: 500; white-space: nowrap; cursor: pointer;">
    Findings
  </button>
</div>

<!-- Add Field Button -->
<button class="btn btn-primary btn-full" onclick="showAddFieldModal()" style="margin-bottom: 16px;">
  + Add Custom Field
</button>

<!-- Fields List -->
<div id="fieldsList">
  <div class="loading-state" style="text-align: center; padding: 40px; color: var(--gray-600);">
    Loading custom fields...
  </div>
</div>

<!-- Add/Edit Field Modal -->
<div id="fieldModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: flex-end;">
  <div style="background: white; border-radius: 20px 20px 0 0; padding: 24px; max-height: 90vh; overflow-y: auto; width: 100%;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h3 id="modalTitle" style="margin: 0; font-size: 20px;">Add Custom Field</h3>
      <button onclick="closeModal()" style="background: none; border: none; font-size: 24px; cursor: pointer;">×</button>
    </div>
    
    <form id="fieldForm" onsubmit="saveField(event)">
      <input type="hidden" id="fieldId">
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Field Label *</label>
        <input type="text" id="fieldLabel" required placeholder="e.g., Purchase Date"
               style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px;">
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Field Name *</label>
        <input type="text" id="fieldName" required placeholder="e.g., purchase_date" pattern="[a-zA-Z][a-zA-Z0-9_]*"
               style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px;">
        <small style="color: var(--gray-600); font-size: 12px;">Must start with a letter, use only letters, numbers, and underscores</small>
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Field Type *</label>
        <select id="fieldType" required onchange="onFieldTypeChange()"
                style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px; background: white;">
          <option value="text">Text</option>
          <option value="number">Number</option>
          <option value="date">Date</option>
          <option value="datetime">Date & Time</option>
          <option value="select">Single Select</option>
          <option value="multiselect">Multi Select</option>
          <option value="checkbox">Checkbox</option>
          <option value="url">URL</option>
          <option value="email">Email</option>
        </select>
      </div>
      
      <!-- Options for select/multiselect -->
      <div id="optionsContainer" style="margin-bottom: 16px; display: none;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Options (one per line)</label>
        <textarea id="fieldOptions" rows="4" placeholder="Option 1&#10;Option 2&#10;Option 3"
                  style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px; resize: vertical;"></textarea>
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Placeholder</label>
        <input type="text" id="fieldPlaceholder" placeholder="Enter placeholder text"
               style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px;">
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: block; font-size: 14px; font-weight: 500; margin-bottom: 6px; color: var(--gray-700);">Help Text</label>
        <input type="text" id="fieldHelpText" placeholder="Additional information about this field"
               style="width: 100%; padding: 12px; border: 1px solid var(--gray-300); border-radius: 8px; font-size: 16px;">
      </div>
      
      <div style="margin-bottom: 16px;">
        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
          <input type="checkbox" id="fieldRequired" style="width: 20px; height: 20px;">
          <span style="font-size: 14px; color: var(--gray-700);">Required field</span>
        </label>
      </div>
      
      <div style="display: flex; gap: 12px;">
        <button type="button" class="btn btn-outline" onclick="closeModal()" style="flex: 1;">Cancel</button>
        <button type="submit" class="btn btn-primary" style="flex: 1;">Save Field</button>
      </div>
    </form>
  </div>
</div>

<style>
.field-card {
  background: white;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid var(--gray-200);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.field-card:hover {
  border-color: var(--primary);
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.field-type-badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  background: var(--gray-100);
  color: var(--gray-700);
}
.field-required {
  color: var(--danger);
  font-weight: 600;
  font-size: 12px;
  margin-left: 8px;
}
</style>

<script>
let currentEntity = 'work_order';
let fields = [];
let limit = 0;
let usage = 0;

document.addEventListener('DOMContentLoaded', () => {
  loadStats();
  loadFields();
});

function switchEntity(entity) {
  currentEntity = entity;
  
  // Update tabs
  document.querySelectorAll('.entity-tab').forEach(tab => {
    if (tab.dataset.entity === entity) {
      tab.style.background = 'var(--primary)';
      tab.style.color = 'white';
      tab.style.borderColor = 'var(--primary)';
    } else {
      tab.style.background = 'white';
      tab.style.color = 'var(--gray-700)';
      tab.style.borderColor = 'var(--gray-300)';
    }
  });
  
  loadFields();
}

async function loadStats() {
  try {
    const response = await fetch('/api/custom-fields/stats', { credentials: 'same-origin' });
    const data = await response.json();
    
    if (data.success) {
      usage = data.data.total_fields || 0;
      limit = data.data.limit;
      
      const limitText = limit === null ? '∞' : limit;
      document.getElementById('usageDisplay').textContent = `${usage} / ${limitText}`;
      
      const percentage = limit ? Math.min((usage / limit) * 100, 100) : 0;
      document.querySelector('#usageBar div').style.width = `${percentage}%`;
    }
  } catch (err) {
    console.error('Failed to load stats:', err);
  }
}

async function loadFields() {
  try {
    const response = await fetch(`/api/custom-fields/definitions/${currentEntity}`, { 
      credentials: 'same-origin' 
    });
    const data = await response.json();
    
    if (data.success) {
      fields = data.data.definitions || [];
      renderFields();
    }
  } catch (err) {
    console.error('Failed to load fields:', err);
    document.getElementById('fieldsList').innerHTML = `
      <div style="text-align: center; padding: 40px; color: var(--danger);">
        Failed to load custom fields
      </div>
    `;
  }
}

function renderFields() {
  if (fields.length === 0) {
    document.getElementById('fieldsList').innerHTML = `
      <div style="text-align: center; padding: 40px; color: var(--gray-600);">
        <div style="font-size: 48px; margin-bottom: 16px;">📝</div>
        <div style="font-weight: 500; margin-bottom: 8px;">No custom fields yet</div>
        <div style="font-size: 14px;">Click "Add Custom Field" to create your first field</div>
      </div>
    `;
    return;
  }
  
  document.getElementById('fieldsList').innerHTML = fields.map(field => `
    <div class="field-card">
      <div>
        <div style="display: flex; align-items: center; margin-bottom: 4px;">
          <span style="font-weight: 600; font-size: 16px;">${escapeHtml(field.field_label)}</span>
          ${field.is_required ? '<span class="field-required">*</span>' : ''}
        </div>
        <div style="font-size: 13px; color: var(--gray-600); margin-bottom: 6px;">
          ${escapeHtml(field.field_name)}
        </div>
        <div style="display: flex; gap: 8px; align-items: center;">
          <span class="field-type-badge">${field.field_type}</span>
          ${field.help_text ? `<span style="font-size: 12px; color: var(--gray-500);">${escapeHtml(field.help_text)}</span>` : ''}
        </div>
      </div>
      <div style="display: flex; gap: 8px;">
        <button class="btn btn-sm btn-outline" onclick="editField(${field.id})" style="padding: 8px 12px;">
          Edit
        </button>
        <button class="btn btn-sm btn-outline" onclick="deleteField(${field.id})" style="padding: 8px 12px; color: var(--danger); border-color: var(--danger);">
          🗑️
        </button>
      </div>
    </div>
  `).join('');
}

function showAddFieldModal() {
  document.getElementById('fieldId').value = '';
  document.getElementById('modalTitle').textContent = 'Add Custom Field';
  document.getElementById('fieldForm').reset();
  document.getElementById('optionsContainer').style.display = 'none';
  document.getElementById('fieldModal').style.display = 'flex';
}

function editField(id) {
  const field = fields.find(f => f.id === id);
  if (!field) return;
  
  document.getElementById('fieldId').value = field.id;
  document.getElementById('modalTitle').textContent = 'Edit Custom Field';
  document.getElementById('fieldLabel').value = field.field_label;
  document.getElementById('fieldName').value = field.field_name;
  document.getElementById('fieldName').readOnly = true;
  document.getElementById('fieldType').value = field.field_type;
  document.getElementById('fieldPlaceholder').value = field.placeholder || '';
  document.getElementById('fieldHelpText').value = field.help_text || '';
  document.getElementById('fieldRequired').checked = field.is_required;
  
  if (field.field_options && (field.field_type === 'select' || field.field_type === 'multiselect')) {
    document.getElementById('fieldOptions').value = field.field_options.join('\n');
    document.getElementById('optionsContainer').style.display = 'block';
  } else {
    document.getElementById('optionsContainer').style.display = 'none';
  }
  
  document.getElementById('fieldModal').style.display = 'flex';
}

function closeModal() {
  document.getElementById('fieldModal').style.display = 'none';
  document.getElementById('fieldName').readOnly = false;
}

function onFieldTypeChange() {
  const type = document.getElementById('fieldType').value;
  const showOptions = type === 'select' || type === 'multiselect';
  document.getElementById('optionsContainer').style.display = showOptions ? 'block' : 'none';
}

async function saveField(event) {
  event.preventDefault();
  
  const id = document.getElementById('fieldId').value;
  const isEdit = !!id;
  
  const fieldData = {
    entity_type: currentEntity,
    field_label: document.getElementById('fieldLabel').value,
    field_name: document.getElementById('fieldName').value,
    field_type: document.getElementById('fieldType').value,
    placeholder: document.getElementById('fieldPlaceholder').value,
    help_text: document.getElementById('fieldHelpText').value,
    is_required: document.getElementById('fieldRequired').checked
  };
  
  // Add options for select types
  if (fieldData.field_type === 'select' || fieldData.field_type === 'multiselect') {
    const optionsText = document.getElementById('fieldOptions').value;
    fieldData.field_options = optionsText.split('\n').map(o => o.trim()).filter(o => o);
  }
  
  try {
    const url = isEdit ? `/api/custom-fields/definitions/${id}` : '/api/custom-fields/definitions';
    const method = isEdit ? 'PUT' : 'POST';
    
    const response = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(fieldData)
    });
    
    const data = await response.json();
    
    if (data.success) {
      closeModal();
      loadStats();
      loadFields();
    } else {
      alert(data.message || 'Failed to save field');
    }
  } catch (err) {
    console.error('Failed to save field:', err);
    alert('Failed to save field');
  }
}

async function deleteField(id) {
  if (!confirm('Are you sure you want to delete this field? All data associated with this field will be lost.')) {
    return;
  }
  
  try {
    const response = await fetch(`/api/custom-fields/definitions/${id}`, {
      method: 'DELETE',
      credentials: 'same-origin'
    });
    
    const data = await response.json();
    
    if (data.success) {
      loadStats();
      loadFields();
    } else {
      alert(data.message || 'Failed to delete field');
    }
  } catch (err) {
    console.error('Failed to delete field:', err);
    alert('Failed to delete field');
  }
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// Auto-generate field name from label
document.getElementById('fieldLabel').addEventListener('input', function() {
  const nameField = document.getElementById('fieldName');
  if (!nameField.readOnly && !nameField.value) {
    const name = this.value
      .toLowerCase()
      .replace(/[^a-z0-9_]/g, '_')
      .replace(/_+/g, '_')
      .replace(/^_|_$/g, '');
    nameField.value = name;
  }
});
</script>
