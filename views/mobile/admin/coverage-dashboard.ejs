  <div class="gap-cards" style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px;">
    
    <!-- Unmapped Equipment -->
    <a href="/mobile/admin/coverage/gaps?type=unmapped" class="gap-card card" style="padding: 16px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit;">
      <div class="gap-icon" style="width: 44px; height: 44px; background: var(--danger-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">⚠️</div>
      <div class="gap-info" style="flex: 1;">
        <div class="gap-title" style="font-weight: 600; color: var(--text-primary);">Unmapped Equipment</div>
        <div class="gap-desc" style="font-size: 13px; color: var(--text-secondary);">No family assigned</div>
      </div>
      <div class="gap-count" id="unmappedCount" style="font-size: 24px; font-weight: 700; color: var(--danger);">0</div>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--text-muted);">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <!-- Missing Industry -->
    <a href="/mobile/admin/coverage/gaps?type=missing_industry" class="gap-card card" style="padding: 16px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit;">
      <div class="gap-icon" style="width: 44px; height: 44px; background: var(--warning-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">🏭</div>
      <div class="gap-info" style="flex: 1;">
        <div class="gap-title" style="font-weight: 600; color: var(--text-primary);">Missing Industry</div>
        <div class="gap-desc" style="font-size: 13px; color: var(--text-secondary);">No industry assigned</div>
      </div>
      <div class="gap-count" id="missingIndustryCount" style="font-size: 24px; font-weight: 700; color: var(--warning);">0</div>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--text-muted);">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <!-- Missing Templates -->
    <a href="/mobile/admin/coverage/gaps?type=missing_templates" class="gap-card card" style="padding: 16px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit;">
      <div class="gap-icon" style="width: 44px; height: 44px; background: var(--amber-100); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">📋</div>
      <div class="gap-info" style="flex: 1;">
        <div class="gap-title" style="font-weight: 600; color: var(--text-primary);">Missing Templates</div>
        <div class="gap-desc" style="font-size: 13px; color: var(--text-secondary);">No system templates</div>
      </div>
      <div class="gap-count" id="missingTemplatesCount" style="font-size: 24px; font-weight: 700; color: var(--primary);">0</div>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--text-muted);">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>
  </div>

  <!-- Quick Actions -->
  <h2 style="font-size: 16px; font-weight: 600; margin: 24px 0 12px 0;">Quick Actions</h2>
  <div class="quick-actions" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
    <a href="/mobile/admin/coverage/equipment" class="action-card card" style="padding: 20px; text-align: center; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100px; transition: all 0.2s ease; cursor: pointer; border: 1px solid var(--border-light);">
      <div style="width: 48px; height: 48px; background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; box-shadow: 0 4px 10px rgba(217, 119, 6, 0.3);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
      </div>
      <div style="font-weight: 600; font-size: 14px; color: var(--text-primary);">Browse Equipment</div>
    </a>
    <a href="/mobile/admin/coverage/templates" class="action-card card" style="padding: 20px; text-align: center; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100px; transition: all 0.2s ease; cursor: pointer; border: 1px solid var(--border-light);">
      <div style="width: 48px; height: 48px; background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; box-shadow: 0 4px 10px rgba(217, 119, 6, 0.3);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </div>
      <div style="font-weight: 600; font-size: 14px; color: var(--text-primary);">Browse Templates</div>
    </a>
    <a href="/mobile/admin/coverage/audit" class="action-card card" style="padding: 20px; text-align: center; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100px; transition: all 0.2s ease; cursor: pointer; border: 1px solid var(--border-light);">
      <div style="width: 48px; height: 48px; background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; box-shadow: 0 4px 10px rgba(217, 119, 6, 0.3);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M3 3v18h18"/>
          <path d="M18 17V9"/>
          <path d="M13 17V5"/>
          <path d="M8 17v-3"/>
        </svg>
      </div>
      <div style="font-weight: 600; font-size: 14px; color: var(--text-primary);">View Audit Log</div>
    </a>
    <a href="/mobile/admin/coverage/validate" class="action-card card" style="padding: 20px; text-align: center; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100px; transition: all 0.2s ease; cursor: pointer; border: 1px solid var(--border-light);">
      <div style="width: 48px; height: 48px; background: linear-gradient(135deg, var(--amber-500) 0%, var(--amber-600) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; box-shadow: 0 4px 10px rgba(217, 119, 6, 0.3);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div style="font-weight: 600; font-size: 14px; color: var(--text-primary);">Run Validation</div>
    </a>
  </div>

  <!-- Recent Changes -->
  <h2 style="font-size: 16px; font-weight: 600; margin: 24px 0 12px 0;">Recent Changes</h2>
  <div id="recentChanges" class="recent-changes" style="background: var(--bg-secondary); border-radius: 12px; padding: 12px;">
    <div class="loading" style="text-align: center; color: var(--text-muted); padding: 20px;">Loading...</div>
  </div>

</div>

<script>
// Load dashboard data
async function loadDashboard() {
  try {
    const response = await fetch('/api/admin/coverage-ui/dashboard', {
      credentials: 'same-origin',
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    const result = await response.json();
    
    if (result.success) {
      const { stats, recent_changes, gap_summary, industry_code } = result.data;
      
      // Update stats
      document.getElementById('totalEquipment').textContent = stats.total_equipment_types || 0;
      document.getElementById('coveragePercent').textContent = (stats.coverage_percentage || 0) + '%';
      
      // Update gap counts
      document.getElementById('unmappedCount').textContent = gap_summary.unmapped || 0;
      document.getElementById('missingIndustryCount').textContent = gap_summary.missing_industry || 0;
      document.getElementById('missingTemplatesCount').textContent = gap_summary.missing_templates || 0;
      
      // Show industry badge
      const badge = document.getElementById('industryBadge');
      if (industry_code && badge) {
        badge.querySelector('span').textContent = industry_code.replace(/_/g, ' ');
        badge.style.display = 'block';
      }
      
      // Render recent changes
      renderRecentChanges(recent_changes || []);
    }
  } catch (err) {
    console.error('Failed to load dashboard:', err);
    document.getElementById('recentChanges').innerHTML = '<div style="text-align: center; color: var(--danger); padding: 20px;">Failed to load data</div>';
  }
}

function renderRecentChanges(changes) {
  const container = document.getElementById('recentChanges');
  
  if (changes.length === 0) {
    container.innerHTML = '<div style="text-align: center; color: var(--text-muted); padding: 20px;">No recent changes</div>';
    return;
  }
  
  const icons = {
    'family_assigned': '🔧',
    'family_changed': '🔧',
    'family_removed': '❌',
    'industry_added': '🏭',
    'industry_removed': '🏭'
  };
  
  container.innerHTML = changes.map(change => `
    <div class="change-item" style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--bg-elevated); border-radius: 8px; margin-bottom: 8px;">
      <div style="font-size: 20px;">${icons[change.change_type] || '📝'}</div>
      <div style="flex: 1; min-width: 0;">
        <div style="font-weight: 500; font-size: 14px; color: var(--text-primary);">${change.type_name}</div>
        <div style="font-size: 12px; color: var(--text-secondary);">${formatChangeType(change.change_type)} • ${formatTime(change.changed_at)}</div>
      </div>
      <div style="font-size: 12px; color: var(--text-muted);">${change.changed_by || 'System'}</div>
    </div>
  `).join('');
}

function formatChangeType(type) {
  return type.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

function formatTime(time) {
  const date = new Date(time);
  const now = new Date();
  const diff = (now - date) / 1000;
  
  if (diff < 60) return 'Just now';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  return date.toLocaleDateString();
}

// Load on page load
loadDashboard();
</script>

<style>
/* Coverage Dashboard Specific Styles */
.gap-card:hover {
  transform: translateX(4px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary) !important;
}

.action-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary) !important;
}

.action-card:active {
  transform: translateY(-2px);
}

.stat-card {
  transition: all 0.2s ease;
}

.stat-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}
</style>
