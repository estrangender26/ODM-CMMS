<!-- Coverage Dashboard - Step 5B -->
<!-- Industry-aware coverage management dashboard -->

<div class="coverage-dashboard">
  
  <!-- Header -->
  <div class="page-header" style="margin-bottom: 16px;">
    <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Coverage Management</h1>
    <p style="color: var(--gray-500); margin: 4px 0 0 0; font-size: 14px;">
      Industry-aware template coverage and equipment mapping
    </p>
  </div>

  <!-- Stats Cards -->
  <div class="stats-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 20px;">
    <div class="stat-card card" style="padding: 16px; text-align: center;">
      <div class="stat-value" id="totalEquipment" style="font-size: 32px; font-weight: 700; color: var(--primary);">-</div>
      <div class="stat-label" style="font-size: 12px; color: var(--gray-500); margin-top: 4px;">Equipment Types</div>
    </div>
    <div class="stat-card card" style="padding: 16px; text-align: center;">
      <div class="stat-value" id="coveragePercent" style="font-size: 32px; font-weight: 700; color: var(--success);">-%</div>
      <div class="stat-label" style="font-size: 12px; color: var(--gray-500); margin-top: 4px;">Coverage</div>
    </div>
  </div>

  <!-- Gap Summary Cards -->
  <h2 style="font-size: 16px; font-weight: 600; margin: 24px 0 12px 0;">Coverage Gaps</h2>
  <div class="gap-cards" style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px;">
    
    <!-- Unmapped Equipment -->
    <a href="/mobile/admin/coverage/gaps?type=unmapped" class="gap-card card" style="padding: 16px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit;">
      <div class="gap-icon" style="width: 44px; height: 44px; background: var(--danger-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">⚠️</div>
      <div class="gap-info" style="flex: 1;">
        <div class="gap-title" style="font-weight: 600; color: var(--gray-900);">Unmapped Equipment</div>
        <div class="gap-desc" style="font-size: 13px; color: var(--gray-500);">No family assigned</div>
      </div>
      <div class="gap-count" id="unmappedCount" style="font-size: 24px; font-weight: 700; color: var(--danger);">-</div>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--gray-400);">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <!-- Missing Industry -->
    <a href="/mobile/admin/coverage/gaps?type=missing_industry" class="gap-card card" style="padding: 16px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit;">
      <div class="gap-icon" style="width: 44px; height: 44px; background: var(--warning-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">🏭</div>
      <div class="gap-info" style="flex: 1;">
        <div class="gap-title" style="font-weight: 600; color: var(--gray-900);">Missing Industry</div>
        <div class="gap-desc" style="font-size: 13px; color: var(--gray-500);">No industry assigned</div>
      </div>
      <div class="gap-count" id="missingIndustryCount" style="font-size: 24px; font-weight: 700; color: var(--warning);">-</div>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--gray-400);">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <!-- Missing Templates -->
    <a href="/mobile/admin/coverage/gaps?type=missing_templates" class="gap-card card" style="padding: 16px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit;">
      <div class="gap-icon" style="width: 44px; height: 44px; background: var(--info-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">📋</div>
      <div class="gap-info" style="flex: 1;">
        <div class="gap-title" style="font-weight: 600; color: var(--gray-900);">Missing Templates</div>
        <div class="gap-desc" style="font-size: 13px; color: var(--gray-500);">No system templates</div>
      </div>
      <div class="gap-count" id="missingTemplatesCount" style="font-size: 24px; font-weight: 700; color: var(--info);">-</div>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--gray-400);">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>
  </div>

  <!-- Quick Actions -->
  <h2 style="font-size: 16px; font-weight: 600; margin: 24px 0 12px 0;">Quick Actions</h2>
  <div class="quick-actions" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
    <a href="/mobile/admin/coverage/equipment" class="action-card card" style="padding: 16px; text-align: center; text-decoration: none; color: inherit;">
      <div style="font-size: 28px; margin-bottom: 8px;">🔧</div>
      <div style="font-weight: 500; font-size: 14px;">Browse Equipment</div>
    </a>
    <a href="/mobile/admin/coverage/templates" class="action-card card" style="padding: 16px; text-align: center; text-decoration: none; color: inherit;">
      <div style="font-size: 28px; margin-bottom: 8px;">📋</div>
      <div style="font-weight: 500; font-size: 14px;">Browse Templates</div>
    </a>
    <a href="/mobile/admin/coverage/audit" class="action-card card" style="padding: 16px; text-align: center; text-decoration: none; color: inherit;">
      <div style="font-size: 28px; margin-bottom: 8px;">📊</div>
      <div style="font-weight: 500; font-size: 14px;">View Audit Log</div>
    </a>
    <a href="/mobile/admin/coverage/validate" class="action-card card" style="padding: 16px; text-align: center; text-decoration: none; color: inherit;">
      <div style="font-size: 28px; margin-bottom: 8px;">✓</div>
      <div style="font-weight: 500; font-size: 14px;">Run Validation</div>
    </a>
  </div>

  <!-- Recent Changes -->
  <h2 style="font-size: 16px; font-weight: 600; margin: 24px 0 12px 0;">Recent Changes</h2>
  <div id="recentChanges" class="recent-changes" style="background: var(--gray-50); border-radius: 12px; padding: 12px;">
    <div class="loading" style="text-align: center; color: var(--gray-400); padding: 20px;">Loading...</div>
  </div>

</div>

<script>
// Load dashboard data
async function loadDashboard() {
  try {
    const response = await fetch('/api/admin/coverage-ui/dashboard', {
      credentials: 'same-origin',
      headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
    });
    
    const result = await response.json();
    
    if (result.success) {
      const { stats, recent_changes, gap_summary } = result.data;
      
      // Update stats
      document.getElementById('totalEquipment').textContent = stats.total_equipment_types || 0;
      document.getElementById('coveragePercent').textContent = (stats.coverage_percentage || 0) + '%';
      
      // Update gap counts
      document.getElementById('unmappedCount').textContent = gap_summary.unmapped || 0;
      document.getElementById('missingIndustryCount').textContent = gap_summary.missing_industry || 0;
      document.getElementById('missingTemplatesCount').textContent = gap_summary.missing_templates || 0;
      
      // Render recent changes
      renderRecentChanges(recent_changes || []);
    }
  } catch (err) {
    console.error('Failed to load dashboard:', err);
    document.getElementById('recentChanges').innerHTML = '<div style="text-align: center; color: var(--danger); padding: 20px;">Failed to load data</div>';
  }
}

function renderRecentChanges(changes) {
  const container = document.getElementById('recentChanges');
  
  if (changes.length === 0) {
    container.innerHTML = '<div style="text-align: center; color: var(--gray-400); padding: 20px;">No recent changes</div>';
    return;
  }
  
  const icons = {
    'family_assigned': '🔧',
    'family_changed': '🔧',
    'family_removed': '❌',
    'industry_added': '🏭',
    'industry_removed': '🏭'
  };
  
  container.innerHTML = changes.map(change => `
    <div class="change-item" style="display: flex; align-items: center; gap: 12px; padding: 12px; background: white; border-radius: 8px; margin-bottom: 8px;">
      <div style="font-size: 20px;">${icons[change.change_type] || '📝'}</div>
      <div style="flex: 1; min-width: 0;">
        <div style="font-weight: 500; font-size: 14px; color: var(--gray-900);">${change.type_name}</div>
        <div style="font-size: 12px; color: var(--gray-500);">${formatChangeType(change.change_type)} • ${formatTime(change.changed_at)}</div>
      </div>
      <div style="font-size: 12px; color: var(--gray-400);">${change.changed_by || 'System'}</div>
    </div>
  `).join('');
}

function formatChangeType(type) {
  return type.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

function formatTime(time) {
  const date = new Date(time);
  const now = new Date();
  const diff = (now - date) / 1000;
  
  if (diff < 60) return 'Just now';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  return date.toLocaleDateString();
}

// Load on page load
loadDashboard();
</script>
