    </div>
  </div>

  <!-- Stats Cards -->
  <div class="stats-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 20px;">
    <div class="stat-card card" style="padding: 16px; text-align: center;">
      <div class="stat-value" id="totalEquipment" style="font-size: 32px; font-weight: 700; color: var(--primary);">0</div>
      <div class="stat-label" style="font-size: 12px; color: var(--text-secondary); margin-top: 4px;">Equipment Types</div>
