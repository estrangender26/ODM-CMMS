<!-- Template Browser - Step 5B -->
<!-- Browse and filter system templates -->

<div class="coverage-templates">
  
  <!-- Header -->
  <div class="page-header" style="margin-bottom: 16px;">
    <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Template Browser</h1>
    <p style="color: var(--gray-500); margin: 4px 0 0 0; font-size: 14px;">
      Browse system templates by equipment, family, industry
    </p>
  </div>

  <!-- Search -->
  <div class="search-bar" style="margin-bottom: 12px;">
    <div style="position: relative;">
      <input 
        type="text" 
        id="searchInput"
        placeholder="Search templates..." 
        style="width: 100%; padding: 12px 16px 12px 44px; border: 1px solid var(--gray-200); border-radius: 12px; font-size: 16px;"
      >
      <span style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); font-size: 18px;">🔍</span>
    </div>
  </div>

  <!-- Filters -->
  <div class="filters card" style="padding: 16px; margin-bottom: 16px;">
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
      <div>
        <label style="font-size: 12px; font-weight: 500; color: var(--gray-600); display: block; margin-bottom: 6px;">Family</label>
        <select id="familyFilter" onchange="loadTemplates()" style="width: 100%; padding: 10px; border: 1px solid var(--gray-200); border-radius: 8px; font-size: 14px;">
          <option value="">All Families</option>
        </select>
      </div>
      <div>
        <label style="font-size: 12px; font-weight: 500; color: var(--gray-600); display: block; margin-bottom: 6px;">Industry</label>
        <div id="industryBadge" style="display: none; width: 100%; padding: 10px; background: var(--primary); color: white; border-radius: 8px; font-size: 14px; font-weight: 500; text-align: center;">
          All Industries
        </div>
        <select id="industryFilter" onchange="loadTemplates()" style="display: none; width: 100%; padding: 10px; border: 1px solid var(--gray-200); border-radius: 8px; font-size: 14px;">
          <option value="">All Industries</option>
        </select>
      </div>
      <div>
        <label style="font-size: 12px; font-weight: 500; color: var(--gray-600); display: block; margin-bottom: 6px;">Task Kind</label>
        <select id="taskKindFilter" onchange="loadTemplates()" style="width: 100%; padding: 10px; border: 1px solid var(--gray-200); border-radius: 8px; font-size: 14px;">
          <option value="">All Kinds</option>
        </select>
      </div>
      <div>
        <label style="font-size: 12px; font-weight: 500; color: var(--gray-600); display: block; margin-bottom: 6px;">Equipment</label>
        <select id="equipmentFilter" onchange="loadTemplates()" style="width: 100%; padding: 10px; border: 1px solid var(--gray-200); border-radius: 8px; font-size: 14px;">
          <option value="">All Equipment</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div id="templatesList" class="templates-list" style="display: flex; flex-direction: column; gap: 12px;">
    <div class="loading" style="text-align: center; padding: 40px; color: var(--gray-400);">
      <div style="font-size: 32px; margin-bottom: 12px;">⏳</div>
      <div>Loading templates...</div>
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" style="display: flex; justify-content: center; align-items: center; gap: 12px; margin-top: 20px; padding: 16px;"></div>

</div>

<!-- Template Detail Modal -->
<div id="templateModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: flex-end;">
  <div class="modal-content" style="background: white; border-radius: 20px 20px 0 0; width: 100%; max-height: 90vh; overflow-y: auto;">
    <div style="padding: 20px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="margin: 0; font-size: 18px;">Template Details</h2>
        <button onclick="closeTemplateModal()" style="background: none; border: none; font-size: 24px; cursor: pointer;">×</button>
      </div>
      <div id="templateModalContent">
        <!-- Dynamic content -->
      </div>
    </div>
  </div>
</div>

<script>
let currentPage = 1;
let filterOptions = {};

async function init() {
  await loadFilterOptions();
  await loadTemplates();
}

async function loadFilterOptions() {
  try {
    const response = await fetch('/api/admin/coverage-ui/template-browser?limit=1', {
      credentials: 'same-origin'
    });
    
    const result = await response.json();
    
    if (result.success && result.data.filters) {
      filterOptions = result.data.filters;
      
      // Populate family filter
      const familySelect = document.getElementById('familyFilter');
      filterOptions.families.forEach(f => {
        const option = document.createElement('option');
        option.value = f.family_code;
        option.textContent = f.family_name;
        familySelect.appendChild(option);
      });
      
      // Show industry badge if industry-locked
      if (result.data.industry && result.data.industry.code) {
        const badge = document.getElementById('industryBadge');
        badge.textContent = result.data.industry.name || result.data.industry.code;
        badge.style.display = 'block';
        document.getElementById('industryFilter').style.display = 'none';
      } else {
        // Fallback: show industry dropdown
        document.getElementById('industryBadge').style.display = 'none';
        const industrySelect = document.getElementById('industryFilter');
        industrySelect.style.display = 'block';
        filterOptions.industries.forEach(i => {
          const option = document.createElement('option');
          option.value = i.id;
          option.textContent = i.name;
          industrySelect.appendChild(option);
        });
      }
      
      // Populate task kind filter
      const taskKindSelect = document.getElementById('taskKindFilter');
      filterOptions.task_kinds.forEach(tk => {
        const option = document.createElement('option');
        option.value = tk;
        option.textContent = tk.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
        taskKindSelect.appendChild(option);
      });
    }
  } catch (err) {
    console.error('Failed to load filter options:', err);
  }
}

function populateEquipmentFilter(templates) {
  const equipmentSelect = document.getElementById('equipmentFilter');
  // Keep only the default option
  equipmentSelect.innerHTML = '<option value="">All Equipment</option>';
  
  const seen = new Set();
  templates.forEach(t => {
    if (!seen.has(t.equipment_type_id)) {
      seen.add(t.equipment_type_id);
      const option = document.createElement('option');
      option.value = t.equipment_type_id;
      option.textContent = t.type_name;
      equipmentSelect.appendChild(option);
    }
  });
}

async function loadTemplates(page = 1) {
  currentPage = page;
  
  const params = new URLSearchParams();
  params.append('page', page);
  params.append('limit', 20);
  
  const search = document.getElementById('searchInput').value;
  if (search) params.append('search', search);
  
  const family = document.getElementById('familyFilter').value;
  if (family) params.append('family_code', family);
  
  // Industry is now enforced server-side from req.user.industry

  const taskKind = document.getElementById('taskKindFilter').value;
  if (taskKind) params.append('task_kind', taskKind);
  
  try {
    const response = await fetch(`/api/admin/coverage-ui/template-browser?${params}`, {
      credentials: 'same-origin'
    });
    
    const result = await response.json();
    
    if (result.success) {
      renderTemplates(result.data.templates);
      renderPagination(result.data.pagination);
      populateEquipmentFilter(result.data.templates);
    } else {
      document.getElementById('templatesList').innerHTML = 
        '<div style="text-align: center; padding: 40px; color: var(--danger);">Failed to load templates: ' + (result.message || 'Unknown error') + '</div>';
    }
  } catch (err) {
    console.error('Failed to load templates:', err);
    document.getElementById('templatesList').innerHTML = 
      '<div style="text-align: center; padding: 40px; color: var(--danger);">Failed to load templates</div>';
  }
}

function renderTemplates(templates) {
  const container = document.getElementById('templatesList');
  
  if (templates.length === 0) {
    container.innerHTML = '<div style="text-align: center; padding: 40px; color: var(--gray-400);">No templates found</div>';
    return;
  }
  
  const taskKindColors = {
    'inspection': { bg: '#dbeafe', text: '#1e40af' },
    'measurement': { bg: '#dcfce7', text: '#166534' },
    'cleaning': { bg: '#fef3c7', text: '#92400e' },
    'lubrication': { bg: '#fce7f3', text: '#9d174d' },
    'adjustment': { bg: '#f3e8ff', text: '#6b21a8' },
    'tightening': { bg: '#e0e7ff', text: '#3730a3' },
    'testing': { bg: '#cffafe', text: '#155e75' },
    'calibration': { bg: '#ecfccb', text: '#3f6212' },
    'safety_check': { bg: '#fee2e2', text: '#991b1b' }
  };
  
  container.innerHTML = templates.map(t => {
    const color = taskKindColors[t.task_kind] || { bg: '#f3f4f6', text: '#374151' };
    
    return `
      <div class="template-card card" style="padding: 16px; cursor: pointer;" onclick="openTemplateModal(${t.id})">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
          <div style="flex: 1; min-width: 0;">
            <div style="font-weight: 600; font-size: 15px; color: var(--gray-900); margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              ${t.template_name}
            </div>
            <div style="font-size: 12px; color: var(--gray-500);">${t.template_code}</div>
          </div>
          <span style="background: ${color.bg}; color: ${color.text}; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 500; text-transform: uppercase; white-space: nowrap;">
            ${t.task_kind.replace(/_/g, ' ')}
          </span>
        </div>
        
        <div style="display: flex; flex-wrap: wrap; gap: 8px; font-size: 12px; color: var(--gray-600); margin-bottom: 12px;">
          <span style="background: var(--gray-100); padding: 4px 10px; border-radius: 6px;">
            📦 ${t.type_name}
          </span>
          <span style="background: var(--gray-100); padding: 4px 10px; border-radius: 6px;">
            🔧 ${t.family_name || 'Unknown'}
          </span>
          ${t.industry_name ? `
            <span style="background: var(--gray-100); padding: 4px 10px; border-radius: 6px;">
              🏭 ${t.industry_name}
            </span>
          ` : ''}
        </div>
        
        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 12px; border-top: 1px solid var(--gray-100);">
          <div style="display: flex; gap: 16px; font-size: 13px; color: var(--gray-500);">
            <span>📝 ${t.step_count} steps</span>
            <span>🛡️ ${t.safety_control_count} safety</span>
          </div>
          <div style="font-size: 13px; color: var(--gray-500);">
            ${t.frequency_value} ${t.frequency_unit}
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function renderPagination(pagination) {
  const container = document.getElementById('pagination');
  
  if (pagination.total_pages <= 1) {
    container.innerHTML = '';
    return;
  }
  
  container.innerHTML = `
    <button onclick="loadTemplates(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} 
      style="padding: 8px 16px; background: var(--gray-100); border: none; border-radius: 8px; font-weight: 500;">
      Previous
    </button>
    <span style="font-size: 14px; color: var(--gray-600);">
      Page ${currentPage}
    </span>
    <button onclick="loadTemplates(${currentPage + 1})" ${currentPage === pagination.total_pages ? 'disabled' : ''} 
      style="padding: 8px 16px; background: var(--gray-100); border: none; border-radius: 8px; font-weight: 500;">
      Next
    </button>
  `;
}

async function openTemplateModal(id) {
  const content = document.getElementById('templateModalContent');
  content.innerHTML = `
    <div style="text-align: center; padding: 40px; color: var(--gray-400);">
      <div style="font-size: 32px; margin-bottom: 12px;">⏳</div>
      <div>Loading template details...</div>
    </div>
  `;
  document.getElementById('templateModal').style.display = 'flex';
  
  try {
    const response = await fetch(`/api/task-templates/${id}`, { credentials: 'same-origin' });
    const result = await response.json();
    
    if (!result.success || !result.data || !result.data.template) {
      content.innerHTML = `
        <div style="text-align: center; padding: 40px; color: var(--danger);">
          <div style="font-size: 32px; margin-bottom: 12px;">⚠️</div>
          <div>Template not found</div>
        </div>
      `;
      return;
    }
    
    const t = result.data.template;
    const steps = t.steps || [];
    const safetyControls = t.safety_controls || [];
    
    const taskKindColors = {
      'inspection': { bg: '#dbeafe', text: '#1e40af' },
      'measurement': { bg: '#dcfce7', text: '#166534' },
      'cleaning': { bg: '#fef3c7', text: '#92400e' },
      'lubrication': { bg: '#fce7f3', text: '#9d174d' },
      'adjustment': { bg: '#f3e8ff', text: '#6b21a8' },
      'tightening': { bg: '#e0e7ff', text: '#3730a3' },
      'testing': { bg: '#cffafe', text: '#155e75' },
      'calibration': { bg: '#ecfccb', text: '#3f6212' },
      'safety_check': { bg: '#fee2e2', text: '#991b1b' }
    };
    const color = taskKindColors[t.task_kind] || { bg: '#f3f4f6', text: '#374151' };
    
    const metaItems = [];
    if (t.type_name) metaItems.push(`<span>📦 ${t.type_name}</span>`);
    if (t.industry_name) metaItems.push(`<span>🏭 ${t.industry_name}</span>`);
    if (t.category_name) metaItems.push(`<span>📂 ${t.category_name}</span>`);
    if (t.estimated_duration_minutes) metaItems.push(`<span>⏱️ ${t.estimated_duration_minutes} min</span>`);
    if (t.frequency_value && t.frequency_unit) metaItems.push(`<span>🔄 ${t.frequency_value} ${t.frequency_unit}</span>`);
    
    content.innerHTML = `
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
        <div>
          <div style="font-weight: 600; font-size: 17px; color: var(--gray-900); margin-bottom: 4px;">${t.template_name}</div>
          <div style="font-size: 12px; color: var(--gray-500);">${t.template_code}</div>
        </div>
        <span style="background: ${color.bg}; color: ${color.text}; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 500; text-transform: uppercase; white-space: nowrap;">
          ${(t.task_kind || 'unknown').replace(/_/g, ' ')}
        </span>
      </div>
      
      <div style="display: flex; flex-wrap: wrap; gap: 8px; font-size: 12px; color: var(--gray-600); margin-bottom: 20px;">
        ${metaItems.join('')}
      </div>
      
      ${t.description ? `
        <div style="background: var(--gray-50); padding: 12px; border-radius: 8px; font-size: 13px; color: var(--gray-700); margin-bottom: 20px;">
          ${t.description}
        </div>
      ` : ''}
      
      <div style="margin-bottom: 12px;">
        <div style="font-size: 13px; font-weight: 600; color: var(--gray-800); margin-bottom: 10px;">Steps (${steps.length})</div>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          ${steps.length === 0 ? '<div style="font-size: 13px; color: var(--gray-500);">No steps defined</div>' : steps.map((s, idx) => `
            <div style="background: var(--gray-50); padding: 12px; border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                <span style="background: var(--primary); color: white; font-size: 11px; font-weight: 600; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">${s.step_no}</span>
                <span style="font-size: 12px; font-weight: 500; color: var(--gray-700); text-transform: uppercase;">${(s.step_type || 'step').replace(/_/g, ' ')}</span>
                ${s.is_required ? '<span style="font-size: 11px; color: var(--danger);">*</span>' : ''}
                ${s.is_visual_only ? '<span style="font-size: 11px; color: var(--gray-500);">👁 Visual</span>' : ''}
              </div>
              <div style="font-size: 13px; color: var(--gray-800); margin-left: 28px;">${s.instruction}</div>
              ${s.safety_note ? `<div style="font-size: 12px; color: var(--warning); margin-left: 28px; margin-top: 6px;">⚠️ ${s.safety_note}</div>` : ''}
            </div>
          `).join('')}
        </div>
      </div>
      
      ${safetyControls.length > 0 ? `
        <div style="margin-top: 16px;">
          <div style="font-size: 13px; font-weight: 600; color: var(--gray-800); margin-bottom: 10px;">Safety Controls</div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            ${safetyControls.map(sc => `
              <div style="background: #fff7ed; border: 1px solid #ffedd5; padding: 10px; border-radius: 8px; font-size: 12px; color: #9a3412;">
                ${sc.control_name || sc.control_description || 'Safety control'}
              </div>
            `).join('')}
          </div>
        </div>
      ` : ''}
    `;
  } catch (err) {
    console.error('Failed to load template details:', err);
    content.innerHTML = `
      <div style="text-align: center; padding: 40px; color: var(--danger);">
        <div style="font-size: 32px; margin-bottom: 12px;">⚠️</div>
        <div>Failed to load template details</div>
      </div>
    `;
  }
}

function closeTemplateModal() {
  document.getElementById('templateModal').style.display = 'none';
}

// Search debounce
let searchTimeout;
document.getElementById('searchInput').addEventListener('input', (e) => {
  clearTimeout(searchTimeout);
  searchTimeout = setTimeout(() => loadTemplates(1), 300);
});

// Initialize
init();
</script>
