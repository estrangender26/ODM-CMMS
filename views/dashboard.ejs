<%- include('partials/header', { title: title, user: user }) %>

<div class="page dashboard-page">
  <header class="page-header">
    <button class="btn-back" onclick="history.back()" title="Go Back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </button>
    <h1>Dashboard</h1>
    <div class="header-actions">
      <button class="btn-icon" id="refresh-btn" title="Refresh">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 4v6h-6M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
      </button>
    </div>
  </header>

  <div class="dashboard-content">
    <!-- Stats Cards -->
    <div class="section-header" style="margin-bottom: 12px;">
      <h2 style="font-size: 14px; color: var(--gray-500);">System Overview</h2>
    </div>
    <div class="stats-grid" id="stats-grid">
      <div class="stat-card stat-filter" data-filter="all" onclick="filterWorkOrders('all')">
        <div class="stat-icon" style="background: var(--primary-50); color: var(--primary);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 11l3 3L22 4"/>
            <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-value loading" id="total-count">-</span>
          <span class="stat-label">Total</span>
        </div>
      </div>
      
      <div class="stat-card urgent stat-filter" data-filter="urgent" onclick="filterWorkOrders('urgent')">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-value loading" id="urgent-count">-</span>
          <span class="stat-label">Urgent</span>
        </div>
      </div>
      
      <div class="stat-card pending stat-filter" data-filter="pending" onclick="filterWorkOrders('pending')">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-value loading" id="pending-count">-</span>
          <span class="stat-label">Pending</span>
        </div>
      </div>
      
      <div class="stat-card completed stat-filter" data-filter="completed" onclick="filterWorkOrders('completed')">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-value loading" id="completed-count">-</span>
          <span class="stat-label">Completed</span>
        </div>
      </div>
    </div>
    
    <!-- Active Filter Indicator -->
    <div id="active-filter-bar" class="hidden" style="display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; background: var(--primary-50); border-radius: var(--radius); margin-bottom: var(--space-3); border: 1px solid var(--primary-100);">
      <span id="active-filter-text" style="font-size: var(--text-sm); color: var(--primary-700); font-weight: 500;">Showing: All</span>
      <button onclick="clearFilter()" style="background: none; border: none; color: var(--primary); font-size: var(--text-xs); font-weight: 600; cursor: pointer; padding: 4px 8px; border-radius: var(--radius-sm);">Clear Filter</button>
    </div>

    <!-- Today's Work Orders -->
    <% const isAdminOrSupervisor = user && (user.role === 'admin' || user.role === 'supervisor'); %>
    <section class="section">
      <div class="section-header">
        <h2>My Tasks</h2>
        <% if (isAdminOrSupervisor) { %>
        <a href="/work-orders?filter=all" class="view-all">View All System Tasks</a>
        <% } %>
      </div>
      <div class="work-order-list" id="today-wo-list">
        <div class="loading-skeleton">
          <div class="skeleton-item"></div>
          <div class="skeleton-item"></div>
          <div class="skeleton-item"></div>
        </div>
      </div>
    </section>

    <!-- Quick Actions -->
    <section class="section">
      <h2>Quick Actions</h2>
      <div class="quick-actions">
        <div class="action-card" onclick="navigateTo('/work-orders?filter=my')">
          <div class="action-icon blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 11l3 3L22 4"/>
              <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
          </div>
          <span>My Tasks</span>
        </div>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor')) { %>
        <div class="action-card" onclick="navigateTo('/work-orders?filter=all')">
          <div class="action-icon teal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <span>All Tasks</span>
        </div>
        <% } %>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor')) { %>
        <div class="action-card" onclick="navigateTo('/admin/schedules')">
          <div class="action-icon orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </div>
          <span>New Schedule</span>
        </div>
        <% } %>
        
        <div class="action-card" onclick="navigateTo('/equipment')">
          <div class="action-icon green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <span>Equipment</span>
        </div>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor' || user.role === 'operator')) { %>
        <div class="action-card" onclick="navigateTo('/admin/reports')">
          <div class="action-icon red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 3v18h18"/>
              <path d="M18 17V9"/>
              <path d="M13 17V5"/>
              <path d="M8 17v-3"/>
            </svg>
          </div>
          <span>Reports</span>
        </div>
        <% } %>
        
        <% if (user && (user.role === 'admin' || user.role === 'supervisor')) { %>
        <div class="action-card" onclick="navigateTo('/admin')">
          <div class="action-icon purple">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <span>Admin</span>
        </div>
        <% } %>
      </div>
    </section>
  </div>
</div>

<script>
// ============================================
// DASHBOARD STATE
// ============================================
const dashboardState = {
  isLoading: false,
  stats: null,
  workOrders: [],
  filteredWorkOrders: [],
  activeFilter: 'all'
};

// ============================================
// INITIALIZATION
// ============================================
document.addEventListener('DOMContentLoaded', () => {
  checkAuth();
  initEventListeners();
  loadDashboardData();
});

function initEventListeners() {
  // Refresh button with loading state
  const refreshBtn = document.getElementById('refresh-btn');
  console.log('[Dashboard] Refresh button found:', !!refreshBtn);
  
  if (refreshBtn) {
    refreshBtn.addEventListener('click', async () => {
      console.log('[Dashboard] Refresh clicked, isLoading:', dashboardState.isLoading);
      
      // Force reset loading state if stuck
      if (dashboardState.isLoading) {
        console.log('[Dashboard] Resetting stuck loading state');
        dashboardState.isLoading = false;
      }
      
      // Add spinning animation
      refreshBtn.style.animation = 'spin 1s linear infinite';
      
      // Clear current stats to show loading
      setStatsLoading(true);
      
      console.log('[Dashboard] Calling loadDashboardData...');
      try {
        await loadDashboardData();
      } catch (e) {
        console.error('[Dashboard] Refresh failed:', e);
      } finally {
        refreshBtn.style.animation = '';
        console.log('[Dashboard] Refresh complete');
      }
    });
  }
}

// ============================================
// DATA LOADING
// ============================================
async function loadDashboardData() {
  if (dashboardState.isLoading) {
    console.log('[Dashboard] Already loading, skipping');
    return;
  }
  
  console.log('[Dashboard] Starting load...');
  dashboardState.isLoading = true;
  setStatsLoading(true);
  
  // Clear current data to force visual update
  dashboardState.stats = null;
  dashboardState.workOrders = [];
  
  try {
    console.log('[Dashboard] Loading dashboard data...');
    
    // Load stats (with cache-busting)
    const statsRes = await fetch('/api/work-orders/stats?_=' + Date.now(), {
      headers: getAuthHeaders()
    });
    
    if (statsRes.status === 401) {
      handleAuthError();
      return;
    }
    
    const statsData = await statsRes.json();
    console.log('[Dashboard] Stats API response:', statsData);
    
    if (statsData.success && statsData.data?.stats) {
      const stats = statsData.data.stats;
      dashboardState.stats = stats;
      
      // For admin/supervisor: use system-wide stats
      // For operator: stats will be calculated from their work orders in loadTodayWorkOrders
      const user = JSON.parse(localStorage.getItem('user') || '{}');
      if (user.role === 'admin' || user.role === 'supervisor') {
        // Update stats display (convert strings to numbers, handle NULL)
        const totalCount = parseInt(stats.total) || 0;
        const urgentCount = parseInt(stats.urgent_pending) || 0;
        const pendingCount = (parseInt(stats.assigned) || 0) + (parseInt(stats.in_progress) || 0);
        const completedCount = (parseInt(stats.completed) || 0) + (parseInt(stats.closed) || 0);
        
        updateStatElement('total-count', totalCount);
        updateStatElement('urgent-count', urgentCount);
        updateStatElement('pending-count', pendingCount);
        updateStatElement('completed-count', completedCount);
        
        console.log('[Dashboard] System stats updated:', { totalCount, urgentCount, pendingCount, completedCount });
      } else {
        console.log('[Dashboard] Operator user - stats will be calculated from work orders');
      }
    } else {
      console.error('[Dashboard] Stats API returned unsuccessful response:', statsData);
      showStatsError();
    }
    
    // Load today's work orders
    await loadTodayWorkOrders();
    
  } catch (error) {
    console.error('[Dashboard] Error loading dashboard:', error);
    showStatsError();
    showWorkOrdersError();
    showToast('Failed to load dashboard data', 'error');
  } finally {
    dashboardState.isLoading = false;
    setStatsLoading(false);
  }
}

async function loadTodayWorkOrders() {
  try {
    console.log('[Dashboard] Loading my work orders...');
    
    const woRes = await fetch('/api/work-orders/my-work-orders?limit=5&status=&priority=&_=' + Date.now(), {
      headers: getAuthHeaders()
    });
    
    if (woRes.status === 401) {
      handleAuthError();
      return;
    }
    
    const woData = await woRes.json();
    console.log('[Dashboard] Work orders API response:', woData);
    
    if (woData.success) {
      const workOrders = woData.data?.work_orders || [];
      dashboardState.workOrders = workOrders;
      dashboardState.filteredWorkOrders = workOrders;
      console.log('[Dashboard] Work orders loaded:', workOrders.length);
      console.log('[Dashboard] First work order:', workOrders[0]?.title || 'none');
      
      // Calculate stats from actual work orders for operators
      calculateAndUpdateStats(workOrders);
      
      // Re-apply active filter if any
      if (dashboardState.activeFilter !== 'all') {
        filterWorkOrders(dashboardState.activeFilter);
      } else {
        renderWorkOrders(workOrders);
      }
    } else {
      console.error('[Dashboard] Work orders API failed:', woData);
      renderWorkOrders([]);
    }
  } catch (error) {
    console.error('[Dashboard] Error loading work orders:', error);
    showWorkOrdersError();
  }
}

function calculateAndUpdateStats(workOrders) {
  // Calculate stats from the actual work orders list
  const totalCount = workOrders.length;
  let urgentCount = 0;
  let pendingCount = 0;
  let completedCount = 0;
  
  workOrders.forEach(wo => {
    // Urgent = urgent priority
    if (wo.priority === 'urgent') {
      urgentCount++;
    }
    
    // Pending = assigned or in_progress
    if (wo.status === 'assigned' || wo.status === 'in_progress') {
      pendingCount++;
    }
    
    // Completed = completed or closed
    if (wo.status === 'completed' || wo.status === 'closed') {
      completedCount++;
    }
  });
  
  updateStatElement('total-count', totalCount);
  updateStatElement('urgent-count', urgentCount);
  updateStatElement('pending-count', pendingCount);
  updateStatElement('completed-count', completedCount);
  
  // Store counts for filter display
  dashboardState.stats = { total: totalCount, urgent: urgentCount, pending: pendingCount, completed: completedCount };
  
  console.log('[Dashboard] Stats calculated from work orders:', { totalCount, urgentCount, pendingCount, completedCount });
}

// ============================================
// RENDERING
// ============================================
function updateStatElement(id, value) {
  const el = document.getElementById(id);
  if (el) {
    el.textContent = value;
    el.classList.remove('loading');
  }
}

function setStatsLoading(loading) {
  const statValues = document.querySelectorAll('.stat-value');
  statValues.forEach(el => {
    if (loading) {
      el.classList.add('loading');
    } else {
      el.classList.remove('loading');
    }
  });
}

function showStatsError() {
  const statIds = ['urgent-count', 'pending-count', 'completed-count'];
  statIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.textContent = '!';
      el.classList.remove('loading');
      el.style.color = 'var(--danger)';
    }
  });
}

function renderWorkOrders(workOrders) {
  const container = document.getElementById('today-wo-list');
  
  if (!workOrders || workOrders.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p>No work orders assigned</p>
        <p class="empty-hint">You're all caught up!</p>
      </div>
    `;
    return;
  }
  
  try {
    container.innerHTML = workOrders.map(wo => `
      <div class="wo-card ${wo.priority}" onclick="window.location.href='/work-orders/${wo.id}'">
        <div class="wo-header">
          <span class="wo-number">${wo.wo_number || 'N/A'}</span>
          <span class="wo-status ${wo.status}">${formatStatus(wo.status)}</span>
        </div>
        <h3 class="wo-title">${escapeHtml(wo.title)}</h3>
        <div class="wo-meta">
          <span class="wo-equipment">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
            </svg>
            ${wo.equipment_code || 'N/A'}
          </span>
          <span class="wo-time">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            ${wo.estimated_hours || '-'}h
          </span>
        </div>
      </div>
    `).join('');
  } catch (err) {
    console.error('[Dashboard] Error rendering work orders:', err);
    showWorkOrdersError();
  }
}

function showWorkOrdersError() {
  const container = document.getElementById('today-wo-list');
  container.innerHTML = `
    <div class="error-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>Failed to load work orders</p>
      <button class="btn btn-secondary btn-sm" onclick="loadTodayWorkOrders()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 4v6h-6M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
        </svg>
        Try Again
      </button>
    </div>
  `;
}

// ============================================
// UTILITIES
// ============================================
function formatStatus(status) {
  if (!status) return 'Unknown';
  return status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function handleAuthError() {
  localStorage.clear();
  window.location.href = '/login';
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  if (!container) return;
  
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  
  setTimeout(() => {
    toast.classList.add('fade-out');
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}

function navigateTo(url) {
  window.location.href = url;
}

// ============================================
// FILTER FUNCTIONS
// ============================================
function filterWorkOrders(filterType) {
  dashboardState.activeFilter = filterType;
  
  // Update active filter UI
  document.querySelectorAll('.stat-filter').forEach(card => {
    card.classList.remove('active');
  });
  document.querySelector(`[data-filter="${filterType}"]`).classList.add('active');
  
  // Filter work orders
  let filtered = dashboardState.workOrders;
  
  switch (filterType) {
    case 'urgent':
      filtered = dashboardState.workOrders.filter(wo => wo.priority === 'urgent');
      break;
    case 'pending':
      filtered = dashboardState.workOrders.filter(wo => wo.status === 'assigned' || wo.status === 'in_progress');
      break;
    case 'completed':
      filtered = dashboardState.workOrders.filter(wo => wo.status === 'completed' || wo.status === 'closed');
      break;
    case 'all':
    default:
      filtered = dashboardState.workOrders;
      break;
  }
  
  dashboardState.filteredWorkOrders = filtered;
  
  // Show active filter bar
  const filterBar = document.getElementById('active-filter-bar');
  const filterText = document.getElementById('active-filter-text');
  filterBar.classList.remove('hidden');
  filterBar.style.display = 'flex';
  
  const filterLabels = {
    'all': 'All Tasks',
    'urgent': 'Urgent Priority',
    'pending': 'Pending Tasks',
    'completed': 'Completed Tasks'
  };
  filterText.textContent = `Showing: ${filterLabels[filterType]} (${filtered.length})`;
  
  // Re-render with filtered data
  renderWorkOrders(filtered);
  
  console.log('[Dashboard] Filter applied:', filterType, 'Results:', filtered.length);
}

function clearFilter() {
  dashboardState.activeFilter = 'all';
  dashboardState.filteredWorkOrders = dashboardState.workOrders;
  
  // Remove active states
  document.querySelectorAll('.stat-filter').forEach(card => {
    card.classList.remove('active');
  });
  
  // Hide filter bar
  const filterBar = document.getElementById('active-filter-bar');
  filterBar.classList.add('hidden');
  filterBar.style.display = 'none';
  
  // Re-render all
  renderWorkOrders(dashboardState.workOrders);
  
  console.log('[Dashboard] Filter cleared');
}
</script>

<%- include('partials/footer') %>
