<%- include('partials/header', { title: title, user: null }) %>

<div class="login-page signup-page">
  <div class="login-container">
    <div class="logo-section">
      <div class="logo">
        <img src="/img/logo.png?v=4" alt="ODM-CMMS Logo">
      </div>
      <h1>Create Account</h1>
      <p id="signup-subtitle">Join ODM-CMMS Maintenance System</p>
    </div>

    <!-- Toggle between Join Existing vs Create New -->
    <div class="signup-toggle" style="display: flex; gap: var(--space-2); margin-bottom: var(--space-4); padding: var(--space-1); background: var(--bg-tertiary); border-radius: var(--radius-lg);">
      <button type="button" class="toggle-btn active" id="btn-join-org" onclick="setSignupMode('join')" style="flex: 1; padding: var(--space-2) var(--space-3); border: none; border-radius: var(--radius); background: var(--bg-primary); color: var(--text-primary); font-size: var(--text-sm); font-weight: 500; cursor: pointer; transition: all 0.2s;">
        Join Organization
      </button>
      <button type="button" class="toggle-btn" id="btn-create-org" onclick="setSignupMode('create')" style="flex: 1; padding: var(--space-2) var(--space-3); border: none; border-radius: var(--radius); background: transparent; color: var(--text-secondary); font-size: var(--text-sm); font-weight: 500; cursor: pointer; transition: all 0.2s;">
        Create Organization
      </button>
    </div>

    <form class="login-form" id="signup-form" novalidate>
      <!-- Invitation Token (hidden, populated from URL) -->
      <input type="hidden" id="invitation_token" name="invitation_token">
      
      <!-- Organization Name (only for Create Organization mode) -->
      <div class="form-group hidden" id="org-name-group">
        <label for="organization_name">Organization Name <span class="required">*</span></label>
        <input 
          type="text" 
          id="organization_name" 
          name="organization_name" 
          placeholder="e.g., Acme Manufacturing"
        >
        <span class="form-error hidden" id="organization_name-error">Please enter your organization name</span>
      </div>
      
      <!-- Organization Selector (only for Join Organization mode) -->
      <div class="form-group" id="org-selector-group">
        <label for="organization_id">Organization <span class="required">*</span></label>
        <select id="organization_id" name="organization_id" required>
          <option value="">Select organization to join</option>
        </select>
        <span class="form-error hidden" id="organization_id-error">Please select an organization</span>
        <small class="form-hint" id="org-selector-hint">Or <a href="/signup?mode=create">create your own organization</a></small>
      </div>
      
      <!-- Invitation Info (shown when using invitation link) -->
      <div class="form-group hidden" id="invitation-info-group">
        <div style="padding: var(--space-3); background: var(--primary-light); border: 1px solid var(--primary); border-radius: var(--radius);">
          <div style="display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-2);">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" style="width: 20px; height: 20px;">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span style="font-weight: 600; color: var(--primary);">You're Invited!</span>
          </div>
          <p style="margin: 0; font-size: var(--text-sm); color: var(--text-secondary);">
            You've been invited to join <strong id="invited-org-name" style="color: var(--text-primary);">-</strong> 
            as <strong id="invited-role" style="color: var(--text-primary);">-</strong>.
          </p>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="full_name">Full Name <span class="required">*</span></label>
          <input 
            type="text" 
            id="full_name" 
            name="full_name" 
            placeholder="e.g., John Smith"
            required
          >
          <span class="form-error hidden" id="full_name-error">Please enter your full name</span>
        </div>
        
        <div class="form-group">
          <label for="username">Username <span class="required">*</span></label>
          <input 
            type="text" 
            id="username" 
            name="username" 
            placeholder="Choose a username"
            autocomplete="username"
            required
          >
          <span class="form-error hidden" id="username-error">Please choose a username</span>
        </div>
      </div>
      
      <div class="form-group">
        <label for="email">Email Address <span class="required">*</span></label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          placeholder="your.email@company.com"
          autocomplete="email"
          required
        >
        <span class="form-error hidden" id="email-error">Please enter a valid email</span>
      </div>
      
      <div class="form-group">
        <label for="phone">Phone Number</label>
        <div class="phone-input-group" style="display: flex; gap: 0;">
          <span style="padding: 10px 12px; background: var(--bg-tertiary); border: 1px solid var(--border-light); border-right: none; border-radius: var(--radius) 0 0 var(--radius); font-size: var(--text-sm); color: var(--text-secondary); font-weight: 500;">+63</span>
          <input type="tel" id="phone" name="phone" 
                 placeholder="917 123 4567" 
                 maxlength="12"
                 oninput="formatPhoneNumber(this)"
                 style="flex: 1; border-radius: 0 var(--radius) var(--radius) 0;">
        </div>
        <small class="form-hint">Philippine mobile number (e.g., +63 917 123 4567)</small>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="password">Password <span class="required">*</span></label>
          <div class="password-input">
            <input 
              type="password" 
              id="password" 
              name="password" 
              placeholder="Create a password"
              autocomplete="new-password"
              required
            >
            <button type="button" class="toggle-password" id="toggle-password" title="Toggle password visibility">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="eye-icon">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
          <small class="form-hint">Minimum 6 characters</small>
          <span class="form-error hidden" id="password-error">Password must be at least 6 characters</span>
        </div>
        
        <div class="form-group" id="role-group">
          <label for="role">Role <span class="required">*</span></label>
          <select id="role" name="role" required>
            <option value="">Select your role</option>
            <option value="operator">Operator</option>
            <option value="supervisor">Supervisor</option>
          </select>
          <span class="form-error hidden" id="role-error">Please select a role</span>
        </div>
        
        <!-- Admin badge (only for Create Organization mode) -->
        <div class="form-group hidden" id="admin-badge-group">
          <label>Role</label>
          <div style="padding: 10px 12px; background: var(--primary-light); border: 1px solid var(--primary); border-radius: var(--radius); color: var(--primary); font-weight: 500; font-size: var(--text-sm);">
            Organization Admin
          </div>
          <small class="form-hint" style="color: var(--primary);">You'll be the admin of your new organization</small>
        </div>
      </div>

      <div class="form-group" style="margin-top: var(--space-4);">
        <label class="checkbox" style="font-size: var(--text-xs); color: var(--text-secondary);">
          <input type="checkbox" id="terms" name="terms" required>
          <span>I agree to the <a href="#" onclick="showTermsModal(); return false;" style="color: var(--primary);">Terms of Service</a> and <a href="#" onclick="showPrivacyModal(); return false;" style="color: var(--primary);">Privacy Policy</a></span>
        </label>
        <span class="form-error hidden" id="terms-error">You must agree to the terms</span>
      </div>

      <button type="submit" class="btn btn-primary btn-block btn-lg" id="signup-btn" style="margin-top: var(--space-4);">
        <span class="btn-text">Create Account</span>
        <span class="spinner hidden"></span>
      </button>
    </form>

    <div class="login-footer">
      <p>Already have an account? <a href="/login" style="color: var(--primary); font-weight: 500;">Sign In</a></p>
    </div>
  </div>
</div>

<!-- Terms Modal -->
<div id="terms-modal" class="modal hidden">
  <div class="modal-overlay" onclick="closeTermsModal()"></div>
  <div class="modal-content" style="max-width: 560px;">
    <div class="modal-header">
      <h3>Terms of Service</h3>
      <button class="btn-close" onclick="closeTermsModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="modal-body" style="max-height: 400px; overflow-y: auto;">
      <p style="font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.6;">
        By using ODM-CMMS, you agree to:
      </p>
      <ul style="font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.8; margin-top: var(--space-3); padding-left: var(--space-5);">
        <li>Use the system for authorized maintenance operations only</li>
        <li>Keep your login credentials secure</li>
        <li>Report any system issues to your administrator</li>
        <li>Follow your organization's maintenance procedures</li>
        <li>Respect data privacy and confidentiality</li>
      </ul>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-secondary" onclick="closeTermsModal()">Close</button>
      <button type="button" class="btn btn-primary" onclick="acceptTerms()">I Understand</button>
    </div>
  </div>
</div>

<style>
/* Signup Page Specific Styles */
.phone-input-group input {
  border-left: none;
}

.phone-input-group input:focus {
  box-shadow: none;
  border-color: var(--border-light);
}

.phone-input-group:focus-within input {
  border-color: var(--primary);
}

.phone-input-group:focus-within span {
  border-color: var(--primary);
  border-right-color: var(--border-light);
}
</style>

<script>
// ============================================
// SIGNUP PAGE
// ============================================

// Current signup mode: 'join' or 'create'
let signupMode = 'join';

document.addEventListener('DOMContentLoaded', function() {
  console.log('[Signup] Page loaded, initializing...');
  
  const form = document.getElementById('signup-form');
  const togglePassword = document.getElementById('toggle-password');
  
  console.log('[Signup] Form found:', !!form);
  console.log('[Signup] Toggle password found:', !!togglePassword);
  
  if (form) {
    form.addEventListener('submit', handleSignup);
    console.log('[Signup] Submit handler attached');
  }
  
  if (togglePassword) {
    togglePassword.addEventListener('click', function() {
      const passwordInput = document.getElementById('password');
      const eyeIcon = document.getElementById('eye-icon');
      
      if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        eyeIcon.innerHTML = `
          <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
          <line x1="1" y1="1" x2="23" y2="23"/>
        `;
      } else {
        passwordInput.type = 'password';
        eyeIcon.innerHTML = `
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        `;
      }
    });
  }
  
  // Clear errors on input
  ['full_name', 'username', 'email', 'password', 'role', 'organization_name'].forEach(field => {
    const input = document.getElementById(field);
    if (input) {
      input.addEventListener('input', function() {
        clearFieldError(field);
      });
    }
  });
  
  // Load organizations for selector
  loadOrganizations();
  
  // Check for invitation token in URL
  checkInvitationToken();
  
  // Check for mode in URL
  const urlParams = new URLSearchParams(window.location.search);
  const mode = urlParams.get('mode');
  if (mode === 'create') {
    setSignupMode('create');
  }
  
  console.log('[Signup] Initialization complete');
});

async function loadOrganizations() {
  try {
    const response = await fetch('/api/organizations/public');
    const data = await response.json();
    
    if (data.success && data.data.organizations) {
      const select = document.getElementById('organization_id');
      select.innerHTML = '<option value="">Select organization to join</option>';
      
      data.data.organizations.forEach(org => {
        const option = document.createElement('option');
        option.value = org.id;
        option.textContent = org.organization_name;
        select.appendChild(option);
      });
      
      console.log('[Signup] Loaded', data.data.organizations.length, 'organizations');
    }
  } catch (error) {
    console.error('[Signup] Failed to load organizations:', error);
  }
}

async function checkInvitationToken() {
  const urlParams = new URLSearchParams(window.location.search);
  const token = urlParams.get('token');
  
  if (!token) return;
  
  console.log('[Signup] Found invitation token:', token);
  
  try {
    const response = await fetch(`/api/invitations/validate/${token}`);
    const data = await response.json();
    
    if (data.success) {
      const invitation = data.data.invitation;
      console.log('[Signup] Valid invitation:', invitation);
      
      // Set mode to join
      setSignupMode('join');
      
      // Hide org selector, show invitation info
      document.getElementById('org-selector-group').classList.add('hidden');
      document.getElementById('invitation-info-group').classList.remove('hidden');
      
      // Populate invitation info
      document.getElementById('invited-org-name').textContent = invitation.organization.name;
      document.getElementById('invited-role').textContent = invitation.role;
      
      // Set email (read-only)
      const emailInput = document.getElementById('email');
      emailInput.value = invitation.email;
      emailInput.readOnly = true;
      emailInput.style.background = 'var(--bg-tertiary)';
      
      // Store token
      document.getElementById('invitation_token').value = token;
      
      showToast(`You've been invited to join ${invitation.organization.name}!`, 'success');
    } else {
      showToast('Invalid or expired invitation link', 'error');
    }
  } catch (error) {
    console.error('[Signup] Failed to validate invitation:', error);
    showToast('Failed to validate invitation', 'error');
  }
}

function setSignupMode(mode) {
  signupMode = mode;
  console.log('[Signup] Mode changed to:', mode);
  
  const btnJoin = document.getElementById('btn-join-org');
  const btnCreate = document.getElementById('btn-create-org');
  const orgNameGroup = document.getElementById('org-name-group');
  const orgSelectorGroup = document.getElementById('org-selector-group');
  const roleGroup = document.getElementById('role-group');
  const adminBadgeGroup = document.getElementById('admin-badge-group');
  const subtitle = document.getElementById('signup-subtitle');
  const submitBtn = document.getElementById('signup-btn');
  
  if (mode === 'join') {
    // Join Existing Organization
    btnJoin.classList.add('active');
    btnJoin.style.background = 'var(--bg-primary)';
    btnJoin.style.color = 'var(--text-primary)';
    btnCreate.classList.remove('active');
    btnCreate.style.background = 'transparent';
    btnCreate.style.color = 'var(--text-secondary)';
    
    orgNameGroup.classList.add('hidden');
    orgSelectorGroup.classList.remove('hidden');
    roleGroup.classList.remove('hidden');
    adminBadgeGroup.classList.add('hidden');
    
    subtitle.textContent = 'Join an existing ODM-CMMS organization';
    submitBtn.querySelector('.btn-text').textContent = 'Create Account';
    
    // Make organization_name not required
    document.getElementById('organization_name').removeAttribute('required');
    document.getElementById('role').setAttribute('required', '');
  } else {
    // Create New Organization
    btnCreate.classList.add('active');
    btnCreate.style.background = 'var(--bg-primary)';
    btnCreate.style.color = 'var(--text-primary)';
    btnJoin.classList.remove('active');
    btnJoin.style.background = 'transparent';
    btnJoin.style.color = 'var(--text-secondary)';
    
    orgNameGroup.classList.remove('hidden');
    orgSelectorGroup.classList.add('hidden');
    roleGroup.classList.add('hidden');
    adminBadgeGroup.classList.remove('hidden');
    
    subtitle.textContent = 'Create your own ODM-CMMS organization';
    submitBtn.querySelector('.btn-text').textContent = 'Create Organization & Account';
    
    // Make organization_name required
    document.getElementById('organization_name').setAttribute('required', '');
    document.getElementById('role').removeAttribute('required');
  }
  
  // Clear any errors
  document.querySelectorAll('.form-error').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('input, select').forEach(el => el.classList.remove('error'));
}

async function handleSignup(e) {
  e.preventDefault();
  console.log('[Signup] Form submitted, mode:', signupMode);
  
  // Clear previous errors
  document.querySelectorAll('.form-error').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('input, select').forEach(el => el.classList.remove('error'));
  
  // Get form values
  const fullName = document.getElementById('full_name').value.trim();
  const username = document.getElementById('username').value.trim();
  const email = document.getElementById('email').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const password = document.getElementById('password').value;
  const organizationName = document.getElementById('organization_name').value.trim();
  const organizationId = document.getElementById('organization_id').value;
  const role = document.getElementById('role').value;
  const invitationToken = document.getElementById('invitation_token').value;
  const terms = document.getElementById('terms').checked;
  
  console.log('[Signup] Form values:', { signupMode, fullName, username, email, organizationName, organizationId, role, invitationToken });
  
  // Validate
  let hasError = false;
  
  if (!fullName) {
    showFieldError('full_name', 'Please enter your full name');
    hasError = true;
  }
  
  if (!username) {
    showFieldError('username', 'Please choose a username');
    hasError = true;
  }
  
  if (!email || !isValidEmail(email)) {
    showFieldError('email', 'Please enter a valid email address');
    hasError = true;
  }
  
  if (password.length < 6) {
    showFieldError('password', 'Password must be at least 6 characters');
    hasError = true;
  }
  
  if (signupMode === 'create' && !organizationName) {
    showFieldError('organization_name', 'Please enter your organization name');
    hasError = true;
  }
  
  if (signupMode === 'join' && !invitationToken && !organizationId) {
    showFieldError('organization_id', 'Please select an organization');
    hasError = true;
  }
  
  if (signupMode === 'join' && !role) {
    showFieldError('role', 'Please select a role');
    hasError = true;
  }
  
  if (!terms) {
    showFieldError('terms', 'You must agree to the terms and conditions');
    hasError = true;
  }
  
  if (hasError) {
    console.log('[Signup] Validation failed');
    return;
  }
  
  // Format phone number
  const formattedPhone = phone ? '+63' + phone.replace(/\s/g, '') : null;
  
  console.log('[Signup] Validation passed, submitting...');
  
  // Show loading state
  const submitBtn = document.getElementById('signup-btn');
  const btnText = submitBtn.querySelector('.btn-text');
  const spinner = submitBtn.querySelector('.spinner');
  
  btnText.classList.add('hidden');
  spinner.classList.remove('hidden');
  submitBtn.disabled = true;
  
  // Determine endpoint and payload based on mode
  let endpoint, payload;
  
  if (invitationToken) {
    // Accepting invitation
    endpoint = '/api/invitations/accept';
    payload = {
      token: invitationToken,
      username,
      password,
      full_name: fullName,
      phone: formattedPhone
    };
  } else if (signupMode === 'create') {
    // Creating new organization
    endpoint = '/api/auth/organization-signup';
    payload = {
      organization_name: organizationName,
      username,
      email,
      password,
      full_name: fullName,
      phone: formattedPhone
    };
  } else {
    // Joining existing organization (legacy - with org selection)
    endpoint = '/api/auth/signup';
    payload = {
      username,
      email,
      password,
      full_name: fullName,
      phone: formattedPhone,
      role,
      organization_id: organizationId
    };
  }
  
  try {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    
    console.log('[Signup] Response status:', response.status);
    
    const data = await response.json();
    console.log('[Signup] Response data:', data);
    
    if (data.success) {
      if (invitationToken) {
        // Invitation accepted
        showToast('Invitation accepted! Welcome to the organization!', 'success');
        setTimeout(() => {
          window.location.href = '/login';
        }, 1500);
      } else if (signupMode === 'create') {
        // Auto-login for organization creation
        showToast('Organization created successfully! Welcome!', 'success');
        // Store token and redirect to dashboard
        localStorage.setItem('token', data.data.token);
        setTimeout(() => {
          window.location.href = '/dashboard';
        }, 1000);
      } else {
        showToast('Account created successfully! Please sign in.', 'success');
        setTimeout(() => {
          window.location.href = '/login';
        }, 1500);
      }
    } else {
      showToast(data.message || 'Failed to create account', 'error');
    }
  } catch (error) {
    console.error('[Signup] Error:', error);
    showToast('Network error. Please try again.', 'error');
  } finally {
    btnText.classList.remove('hidden');
    spinner.classList.add('hidden');
    submitBtn.disabled = false;
  }
}

function showFieldError(fieldName, message) {
  const input = document.getElementById(fieldName);
  const error = document.getElementById(`${fieldName}-error`);
  
  if (input) input.classList.add('error');
  if (error) {
    error.textContent = message;
    error.classList.remove('hidden');
  }
}

function clearFieldError(fieldName) {
  const input = document.getElementById(fieldName);
  const error = document.getElementById(`${fieldName}-error`);
  
  if (input) input.classList.remove('error');
  if (error) error.classList.add('hidden');
}

function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

function formatPhoneNumber(input) {
  let value = input.value.replace(/\D/g, '').substring(0, 10);
  if (value.length >= 7) {
    value = value.substring(0, 3) + ' ' + value.substring(3, 6) + ' ' + value.substring(6);
  } else if (value.length >= 4) {
    value = value.substring(0, 3) + ' ' + value.substring(3);
  }
  input.value = value;
}

function showTermsModal() {
  document.getElementById('terms-modal').classList.remove('hidden');
}

function closeTermsModal() {
  document.getElementById('terms-modal').classList.add('hidden');
}

function acceptTerms() {
  document.getElementById('terms').checked = true;
  closeTermsModal();
  clearFieldError('terms');
}

function showPrivacyModal() {
  showToast('Privacy Policy - Your data is protected and will not be shared.', 'info');
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  if (!container) return;
  
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  
  setTimeout(() => {
    toast.classList.add('fade-out');
    setTimeout(() => toast.remove(), 300);
  }, 4000);
}
</script>

<%- include('partials/footer') %>
