<%- include('../partials/header', { title: title, user: user }) %>

<div class="page admin-page">
  <header class="page-header">
    <a href="/admin" class="btn-back" title="Back to Admin">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </a>
    <h1>Schedules</h1>
    <div class="header-actions">
      <button class="btn-icon" id="add-btn" onclick="openModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Schedule List -->
  <div class="schedule-list" id="schedule-list">
    <div class="loading-skeleton">
      <div class="skeleton-item"></div>
      <div class="skeleton-item"></div>
    </div>
  </div>
</div>

<!-- Add/Edit Schedule Modal -->
<div class="modal hidden" id="schedule-modal">
  <div class="modal-overlay" onclick="closeModal()"></div>
  <div class="modal-content modal-lg">
    <div class="modal-header">
      <h2 id="modal-title">Add Schedule</h2>
      <button class="btn-close" onclick="closeModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <form id="schedule-form" class="modal-body">
      <input type="hidden" id="schedule-id" name="id">
      
      <div class="form-group">
        <label for="schedule_code">Schedule Code *</label>
        <input type="text" id="schedule_code" name="schedule_code" required placeholder="e.g., SCH-PUMP-001">
      </div>
      
      <div class="form-group">
        <label for="title">Schedule Title *</label>
        <input type="text" id="title" name="title" required placeholder="e.g., Pump A Daily Inspection">
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="equipment_id">Equipment *</label>
          <select id="equipment_id" name="equipment_id" required>
            <option value="">Select Equipment...</option>
          </select>
        </div>
        <div class="form-group">
          <label for="task_master_id">Task Template *</label>
          <select id="task_master_id" name="task_master_id" required>
            <option value="">Select Task...</option>
          </select>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="frequency_type">Frequency *</label>
          <select id="frequency_type" name="frequency_type" required>
            <option value="daily">Daily</option>
            <option value="weekly">Weekly</option>
            <option value="monthly">Monthly</option>
            <option value="quarterly">Quarterly</option>
            <option value="yearly">Yearly</option>
            <option value="custom">Custom</option>
          </select>
        </div>
        <div class="form-group">
          <label for="frequency_value">Frequency Value</label>
          <input type="number" id="frequency_value" name="frequency_value" min="1" value="1" placeholder="e.g., 1">
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="start_date">Start Date *</label>
          <input type="date" id="start_date" name="start_date" required>
        </div>
        <div class="form-group">
          <label for="next_due_date">Next Due Date</label>
          <input type="date" id="next_due_date" name="next_due_date">
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="priority">Priority</label>
          <select id="priority" name="priority">
            <option value="low">Low</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High</option>
            <option value="urgent">Urgent</option>
          </select>
        </div>
        <div class="form-group">
          <label for="assigned_to">Assigned To</label>
          <select id="assigned_to" name="assigned_to">
            <option value="">Select Operator...</option>
          </select>
        </div>
      </div>
      
      <div class="form-group">
        <label for="is_active">Status</label>
        <select id="is_active" name="is_active">
          <option value="1">Active</option>
          <option value="0">Inactive</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3" placeholder="Schedule description..."></textarea>
      </div>
      
      <div class="form-actions">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Schedule</button>
      </div>
    </form>
  </div>
</div>

<script>
checkAuth();

let editingId = null;
let equipment = [];
let tasks = [];
let users = [];

// Load data on page load
loadSchedules();
loadEquipment();
loadTasks();
loadUsers();

// Set default dates
document.getElementById('start_date').valueAsDate = new Date();

// Form submission
document.getElementById('schedule-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const formData = {
    schedule_code: document.getElementById('schedule_code').value,
    title: document.getElementById('title').value,
    equipment_id: parseInt(document.getElementById('equipment_id').value),
    task_master_id: parseInt(document.getElementById('task_master_id').value),
    frequency_type: document.getElementById('frequency_type').value,
    frequency_value: parseInt(document.getElementById('frequency_value').value) || 1,
    start_date: document.getElementById('start_date').value,
    next_due_date: document.getElementById('next_due_date').value || document.getElementById('start_date').value,
    priority: document.getElementById('priority').value,
    assigned_to: document.getElementById('assigned_to').value || null,
    description: document.getElementById('description').value,
    is_active: document.getElementById('is_active').value === '1'
  };
  
  try {
    const url = editingId ? `/api/schedules/${editingId}` : '/api/schedules';
    const method = editingId ? 'PUT' : 'POST';
    
    const response = await fetch(url, {
      method: method,
      headers: getAuthHeaders(),
      body: JSON.stringify(formData)
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast(editingId ? 'Schedule updated' : 'Schedule created', 'success');
      closeModal();
      loadSchedules();
    } else {
      showToast(data.message || 'Failed to save', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error saving schedule', 'error');
  }
});

async function loadEquipment() {
  try {
    const response = await fetch('/api/equipment', {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    if (data.success) {
      equipment = data.data.equipment;
      const select = document.getElementById('equipment_id');
      select.innerHTML = '<option value="">Select Equipment...</option>' + 
        equipment.map(e => `<option value="${e.id}">${e.code} - ${e.name}</option>`).join('');
    }
  } catch (error) {
    console.error('Error loading equipment:', error);
  }
}

async function loadUsers() {
  try {
    const response = await fetch('/api/users?role=operator&active=true', {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    if (data.success) {
      users = data.data.users;
      const select = document.getElementById('assigned_to');
      select.innerHTML = '<option value="">Select Operator...</option>' + 
        users.map(u => `<option value="${u.id}">${u.full_name || u.username}</option>`).join('');
    }
  } catch (error) {
    console.error('Error loading users:', error);
  }
}

async function loadTasks() {
  try {
    const response = await fetch('/api/tasks?active=true', {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    if (data.success) {
      tasks = data.data.tasks;
      const select = document.getElementById('task_master_id');
      select.innerHTML = '<option value="">Select Task...</option>' + 
        tasks.map(t => `<option value="${t.id}">${t.task_code} - ${t.title}</option>`).join('');
    }
  } catch (error) {
    console.error('Error loading tasks:', error);
  }
}

async function loadSchedules() {
  try {
    const response = await fetch('/api/schedules', {
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      renderSchedules(data.data.schedules);
    }
  } catch (error) {
    console.error('Error loading schedules:', error);
    showToast('Failed to load schedules', 'error');
  }
}

function renderSchedules(schedules) {
  const container = document.getElementById('schedule-list');
  
  if (!schedules || schedules.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <p>No schedules found</p>
        <button class="btn btn-primary" onclick="openModal()">Add First Schedule</button>
      </div>
    `;
    return;
  }
  
  container.innerHTML = schedules.map(sch => `
    <div class="equipment-card">
      <div class="equipment-header">
        <span class="equipment-code">${sch.schedule_code}</span>
        <span class="wo-priority ${sch.priority}">${sch.priority}</span>
      </div>
      <h3 class="equipment-name">${sch.title}</h3>
      <p class="equipment-facility">${sch.equipment_code} - ${sch.equipment_name}</p>
      <div class="equipment-meta">
        <span class="badge ${sch.frequency_type}">${sch.frequency_type}</span>
        <span>Next: ${formatDate(sch.next_due_date)}</span>
        <span class="badge ${sch.is_active ? 'active' : 'inactive'}">${sch.is_active ? 'Active' : 'Inactive'}</span>
      </div>
      ${sch.assigned_to_name ? `<p class="equipment-facility">👤 Assigned: ${sch.assigned_to_name}</p>` : ''}
      <div class="equipment-actions">
        <button class="btn-icon" onclick="editSchedule(${sch.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
        <button class="btn-icon btn-danger" onclick="deleteSchedule(${sch.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          </svg>
        </button>
      </div>
    </div>
  `).join('');
}

async function editSchedule(id) {
  try {
    const response = await fetch(`/api/schedules/${id}`, {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    
    if (data.success && data.data.schedule) {
      const sch = data.data.schedule;
      editingId = id;
      document.getElementById('modal-title').textContent = 'Edit Schedule';
      document.getElementById('schedule-id').value = id;
      document.getElementById('schedule_code').value = sch.schedule_code;
      document.getElementById('title').value = sch.title;
      document.getElementById('equipment_id').value = sch.equipment_id;
      document.getElementById('task_master_id').value = sch.task_master_id;
      document.getElementById('frequency_type').value = sch.frequency_type;
      document.getElementById('frequency_value').value = sch.frequency_value || 1;
      document.getElementById('start_date').value = sch.start_date ? sch.start_date.substring(0, 10) : '';
      document.getElementById('next_due_date').value = sch.next_due_date ? sch.next_due_date.substring(0, 10) : '';
      document.getElementById('priority').value = sch.priority;
      document.getElementById('description').value = sch.description || '';
      document.getElementById('is_active').value = sch.is_active ? '1' : '0';
      document.getElementById('assigned_to').value = sch.assigned_to || '';
      document.getElementById('schedule-modal').classList.remove('hidden');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error loading schedule', 'error');
  }
}

function openModal() {
  editingId = null;
  document.getElementById('modal-title').textContent = 'Add Schedule';
  document.getElementById('schedule-form').reset();
  document.getElementById('schedule-id').value = '';
  document.getElementById('is_active').value = '1';
  document.getElementById('start_date').valueAsDate = new Date();
  document.getElementById('schedule-modal').classList.remove('hidden');
}

function closeModal() {
  document.getElementById('schedule-modal').classList.add('hidden');
  editingId = null;
}

async function deleteSchedule(id) {
  if (!confirm('Are you sure you want to delete this schedule?')) return;
  
  try {
    const response = await fetch(`/api/schedules/${id}`, {
      method: 'DELETE',
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast('Schedule deleted', 'success');
      loadSchedules();
    } else {
      showToast(data.message || 'Failed to delete', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error deleting schedule', 'error');
  }
}

function formatDate(dateString) {
  if (!dateString) return '-';
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}
</script>

<%- include('../partials/footer') %>
