<%- include('../partials/header', { title: title, user: user }) %>

<div class="page admin-page">
  <header class="page-header">
    <a href="/admin" class="btn-back" title="Back to Admin">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </a>
    <h1>Manage Users</h1>
    <div class="header-actions">
      <% if (user && user.role === 'admin') { %>
      <button class="btn-icon" id="invite-btn" onclick="openInviteModal()" title="Invite User">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="16 17 12 21 8 17"/>
          <line x1="12" y1="12" x2="12" y2="21"/>
        </svg>
      </button>
      <% } %>
      <button class="btn-icon" id="add-btn" onclick="openModal()" title="Add User">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    </div>
  </header>
  
  <% if (user && user.role === 'supervisor') { %>
  <div class="info-banner" style="background: #e0f2fe; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; color: #0369a1;">
    <strong>Supervisor View:</strong> You can only see users assigned to your facility (<%= user.facility_name || 'Main Plant' %>). 
    <a href="/work-orders" style="color: #0284c7; text-decoration: underline;">Back to Dashboard</a>
  </div>
  <% } %>

  <% if (user && user.role === 'admin') { %>
  <!-- Tabs -->
  <div class="tabs" style="display: flex; gap: var(--space-1); margin-bottom: var(--space-4); border-bottom: 1px solid var(--border-light);">
    <button class="tab-btn active" id="tab-users" onclick="showTab('users')" style="padding: var(--space-2) var(--space-4); border: none; border-bottom: 2px solid var(--primary); background: transparent; color: var(--primary); font-weight: 500; cursor: pointer;">
      Users
    </button>
    <button class="tab-btn" id="tab-invitations" onclick="showTab('invitations')" style="padding: var(--space-2) var(--space-4); border: none; border-bottom: 2px solid transparent; background: transparent; color: var(--text-secondary); font-weight: 500; cursor: pointer;">
      Invitations <span id="invitation-badge" style="display: none; background: var(--primary); color: white; padding: 2px 6px; border-radius: 10px; font-size: 12px; margin-left: 4px;">0</span>
    </button>
  </div>
  <% } %>

  <!-- Users List -->
  <div class="tab-content" id="users-tab">
    <div class="user-list" id="user-list">
      <div class="loading-skeleton">
        <div class="skeleton-item"></div>
        <div class="skeleton-item"></div>
      </div>
    </div>
  </div>

  <% if (user && user.role === 'admin') { %>
  <!-- Invitations List -->
  <div class="tab-content hidden" id="invitations-tab">
    <div class="invitations-list" id="invitations-list">
      <div class="loading-skeleton">
        <div class="skeleton-item"></div>
        <div class="skeleton-item"></div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<!-- Invite User Modal -->
<div class="modal hidden" id="invite-modal">
  <div class="modal-overlay" onclick="closeInviteModal()"></div>
  <div class="modal-content">
    <div class="modal-header">
      <h2>Invite User</h2>
      <button class="btn-close" onclick="closeInviteModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <form id="invite-form" class="modal-body">
      <div class="form-group">
        <label for="invite-email">Email Address *</label>
        <input type="email" id="invite-email" name="email" required placeholder="user@company.com">
        <small class="form-hint">Invitation will be sent to this email</small>
      </div>
      
      <div class="form-group">
        <label for="invite-role">Role *</label>
        <select id="invite-role" name="role" required>
          <option value="operator">Operator</option>
          <option value="supervisor">Supervisor</option>
          <option value="admin">Administrator</option>
        </select>
        <small class="form-hint">User will be assigned this role when they accept</small>
      </div>
      
      <div class="form-info" style="background: var(--primary-light); padding: var(--space-3); border-radius: var(--radius); margin-bottom: var(--space-3);">
        <div style="display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-2);">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" style="width: 20px; height: 20px;">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          <span style="font-weight: 600; color: var(--primary);">How it works</span>
        </div>
        <p style="margin: 0; font-size: var(--text-sm); color: var(--text-secondary);">
          An email invitation will be sent. The recipient can click the link to create their account. 
          The invitation expires in 7 days.
        </p>
      </div>
      
      <div class="form-actions">
        <button type="button" class="btn btn-secondary" onclick="closeInviteModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Send Invitation</button>
      </div>
    </form>
  </div>
</div>

<!-- Add/Edit User Modal -->
<div class="modal hidden" id="user-modal">
  <div class="modal-overlay" onclick="closeModal()"></div>
  <div class="modal-content modal-lg">
    <div class="modal-header">
      <h2 id="modal-title">Add User</h2>
      <button class="btn-close" onclick="closeModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <form id="user-form" class="modal-body">
      <input type="hidden" id="user-id" name="id">
      
      <div class="form-row">
        <div class="form-group">
          <label for="username">Username *</label>
          <input type="text" id="username" name="username" required placeholder="e.g., operator3">
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="e.g., user@company.com">
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="full_name">Full Name</label>
          <input type="text" id="full_name" name="full_name" placeholder="e.g., John Smith">
        </div>
        <div class="form-group">
          <label for="role">Role *</label>
          <select id="role" name="role" required>
            <option value="operator">Operator</option>
            <% if (user && user.role === 'admin') { %>
            <option value="supervisor">Supervisor</option>
            <option value="admin">Administrator</option>
            <% } %>
          </select>
          <% if (user && user.role === 'supervisor') { %>
          <small class="form-hint">Supervisors can only create operator accounts</small>
          <% } %>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="facility_id">Facility</label>
          <select id="facility_id" name="facility_id" <%= user && user.role === 'supervisor' ? 'disabled' : '' %>>
            <option value="">-- Select Facility --</option>
          </select>
          <% if (user && user.role === 'supervisor') { %>
          <small class="form-hint">Users are automatically assigned to your facility</small>
          <% } %>
        </div>
        <div class="form-group">
          <label for="is_active">Status</label>
          <select id="is_active" name="is_active">
            <option value="1">Active</option>
            <option value="0">Inactive</option>
          </select>
        </div>
      </div>
      
      <div class="form-group" id="password-group">
        <label for="password">Password *</label>
        <input type="password" id="password" name="password" placeholder="Min 6 characters">
        <small class="form-hint" id="password-hint">Required for new users</small>
      </div>
      
      <div class="form-actions">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save User</button>
      </div>
    </form>
  </div>
</div>

<script>
checkAuth();

let editingId = null;

// Load users on page load
document.addEventListener('DOMContentLoaded', () => {
  console.log('Users page loaded');
  loadUsers();
  loadFacilities();
  <% if (user && user.role === 'admin') { %>
  loadInvitations();
  <% } %>
  
  // Add button event listener
  const addBtn = document.getElementById('add-btn');
  if (addBtn) {
    console.log('Add button found, attaching listener');
    addBtn.addEventListener('click', (e) => {
      console.log('Add button clicked');
      e.preventDefault();
      e.stopPropagation();
      openModal();
    });
  } else {
    console.error('Add button not found!');
  }
  
  <% if (user && user.role === 'admin') { %>
  // Invite form submission
  const inviteForm = document.getElementById('invite-form');
  if (inviteForm) {
    inviteForm.addEventListener('submit', handleInviteSubmit);
  }
  <% } %>
});

// Form submission
document.getElementById('user-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  // Validation
  const username = document.getElementById('username').value.trim();
  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;
  const role = document.getElementById('role').value;
  
  if (!username) {
    showToast('Username is required', 'error');
    return;
  }
  if (!email) {
    showToast('Email is required', 'error');
    return;
  }
  if (!editingId && !password) {
    showToast('Password is required for new users', 'error');
    return;
  }
  if (password && password.length < 6) {
    showToast('Password must be at least 6 characters', 'error');
    return;
  }
  
  const formData = {
    username: username,
    email: email,
    full_name: document.getElementById('full_name').value.trim(),
    role: role,
    facility_id: document.getElementById('facility_id').value || null,
    is_active: document.getElementById('is_active').value === '1'
  };
  
  if (password) {
    formData.password = password;
  }
  
  console.log('[User Form] Submitting:', { editingId, formData });
  
  try {
    const url = editingId ? `/api/users/${editingId}` : '/api/users';
    const method = editingId ? 'PUT' : 'POST';
    
    const response = await fetch(url, {
      method: method,
      headers: getAuthHeaders(),
      body: JSON.stringify(formData)
    });
    
    const data = await response.json();
    console.log('[User Form] Response:', data);
    
    if (data.success) {
      showToast(editingId ? 'User updated' : 'User created', 'success');
      closeModal();
      loadUsers();
    } else {
      showToast(data.message || 'Failed to save', 'error');
    }
  } catch (error) {
    console.error('[User Form] Error:', error);
    showToast('Error saving user', 'error');
  }
});

async function loadUsers() {
  try {
    console.log('[Users] Loading users...');
    const response = await fetch('/api/users', {
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    console.log('[Users] API response:', data);
    
    if (data.success) {
      console.log('[Users] Loaded', data.data.users.length, 'users');
      renderUsers(data.data.users);
    } else {
      console.error('[Users] API error:', data.message);
      showToast(data.message || 'Failed to load users', 'error');
    }
  } catch (error) {
    console.error('[Users] Error loading users:', error);
    showToast('Failed to load users', 'error');
  }
}

async function loadFacilities() {
  try {
    const response = await fetch('/api/facilities', {
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      const select = document.getElementById('facility_id');
      // Keep the first option (placeholder)
      select.innerHTML = '<option value="">-- Select Facility --</option>';
      
      data.data.facilities.forEach(facility => {
        const option = document.createElement('option');
        option.value = facility.id;
        option.textContent = facility.name;
        select.appendChild(option);
      });
    }
  } catch (error) {
    console.error('Error loading facilities:', error);
  }
}

function renderUsers(users) {
  const container = document.getElementById('user-list');
  
  if (!users || users.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        <p>No users found</p>
        <button class="btn btn-primary" onclick="openModal()">Add First User</button>
      </div>
    `;
    return;
  }
  
  container.innerHTML = users.map(u => `
    <div class="user-card" data-id="${u.id}">
      <div class="user-header">
        <span class="user-role ${u.role}">${u.role}</span>
        <span class="user-status ${u.is_active ? 'active' : 'inactive'}">${u.is_active ? 'Active' : 'Inactive'}</span>
      </div>
      <h3 class="user-name">${u.full_name || u.username}</h3>
      <p class="user-email">${u.email}</p>
      <p class="user-username">@${u.username}</p>
      <p class="user-facility">${u.facility_name || 'No facility assigned'}</p>
      <div class="user-actions">
        <button class="btn-icon" onclick="editUser(${u.id}, '${escapeHtml(u.username)}', '${escapeHtml(u.email)}', '${escapeHtml(u.full_name || '')}', '${u.role}', ${u.facility_id || 'null'}, ${u.is_active})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
        <button class="btn-icon btn-danger" onclick="deleteUser(${u.id})" ${u.id === 1 ? 'disabled' : ''}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          </svg>
        </button>
      </div>
    </div>
  `).join('');
}

function openModal() {
  console.log('openModal() called');
  editingId = null;
  const modal = document.getElementById('user-modal');
  
  document.getElementById('modal-title').textContent = 'Add User';
  document.getElementById('user-form').reset();
  document.getElementById('user-id').value = '';
  document.getElementById('password').required = true;
  document.getElementById('password-hint').textContent = 'Required for new users';
  
  // For supervisors, auto-select their facility
  <% if (user && user.role === 'supervisor' && user.facility_id) { %>
  document.getElementById('facility_id').value = '<%= user.facility_id %>';
  <% } %>
  
  modal.classList.remove('hidden');
}

function editUser(id, username, email, fullName, role, facilityId, isActive) {
  const currentUserId = <%= user ? user.id : 'null' %>;
  const currentUserRole = '<%= user ? user.role : '' %>';
  
  editingId = id;
  document.getElementById('modal-title').textContent = 'Edit User';
  document.getElementById('user-id').value = id;
  document.getElementById('username').value = username;
  document.getElementById('email').value = email;
  document.getElementById('full_name').value = fullName;
  document.getElementById('role').value = role;
  document.getElementById('facility_id').value = facilityId || '';
  document.getElementById('is_active').value = isActive ? '1' : '0';
  document.getElementById('password').required = false;
  document.getElementById('password').value = '';
  document.getElementById('password-hint').textContent = 'Leave blank to keep current password';
  
  // Prevent editing your own role or active status
  if (id === currentUserId) {
    document.getElementById('role').disabled = true;
    document.getElementById('is_active').disabled = true;
    document.getElementById('password-hint').textContent = 'Leave blank to keep current password. Cannot modify your own role or status.';
  } else {
    document.getElementById('role').disabled = false;
    document.getElementById('is_active').disabled = false;
  }
  
  // For supervisors editing users, disable facility and role
  if (currentUserRole === 'supervisor') {
    document.getElementById('role').disabled = true;
    document.getElementById('facility_id').disabled = true;
  }
  
  document.getElementById('user-modal').classList.remove('hidden');
}

function closeModal() {
  document.getElementById('user-modal').classList.add('hidden');
  editingId = null;
  
  // Re-enable disabled fields for next time
  document.getElementById('role').disabled = false;
  document.getElementById('is_active').disabled = false;
  document.getElementById('facility_id').disabled = <%= user && user.role === 'supervisor' ? 'true' : 'false' %>;
}

async function deleteUser(id) {
  if (id === 1) {
    showToast('Cannot delete admin user', 'error');
    return;
  }
  
  if (!confirm('Are you sure you want to delete this user?')) return;
  
  try {
    const response = await fetch(`/api/users/${id}`, {
      method: 'DELETE',
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast('User deleted', 'success');
      loadUsers();
    } else {
      showToast(data.message || 'Failed to delete', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error deleting user', 'error');
  }
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML.replace(/"/g, '&quot;').replace(/'/g, "&#039;");
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}

<% if (user && user.role === 'admin') { %>
// Tab switching
function showTab(tab) {
  console.log('[Users] Switching to tab:', tab);
  
  // Update tab buttons
  document.getElementById('tab-users').classList.toggle('active', tab === 'users');
  document.getElementById('tab-users').style.borderBottomColor = tab === 'users' ? 'var(--primary)' : 'transparent';
  document.getElementById('tab-users').style.color = tab === 'users' ? 'var(--primary)' : 'var(--text-secondary)';
  
  document.getElementById('tab-invitations').classList.toggle('active', tab === 'invitations');
  document.getElementById('tab-invitations').style.borderBottomColor = tab === 'invitations' ? 'var(--primary)' : 'transparent';
  document.getElementById('tab-invitations').style.color = tab === 'invitations' ? 'var(--primary)' : 'var(--text-secondary)';
  
  // Show/hide tab content
  document.getElementById('users-tab').classList.toggle('hidden', tab !== 'users');
  document.getElementById('invitations-tab').classList.toggle('hidden', tab !== 'invitations');
}

// Invite modal functions
function openInviteModal() {
  console.log('[Invite] Opening invite modal');
  document.getElementById('invite-form').reset();
  document.getElementById('invite-modal').classList.remove('hidden');
}

function closeInviteModal() {
  document.getElementById('invite-modal').classList.add('hidden');
}

// Handle invite form submission
async function handleInviteSubmit(e) {
  e.preventDefault();
  
  const email = document.getElementById('invite-email').value.trim();
  const role = document.getElementById('invite-role').value;
  
  if (!email || !isValidEmail(email)) {
    showToast('Please enter a valid email address', 'error');
    return;
  }
  
  console.log('[Invite] Sending invitation to:', email, 'Role:', role);
  
  try {
    const response = await fetch('/api/invitations', {
      method: 'POST',
      headers: getAuthHeaders(),
      body: JSON.stringify({ email, role })
    });
    
    const data = await response.json();
    console.log('[Invite] Response:', data);
    
    if (data.success) {
      showToast('Invitation sent successfully!', 'success');
      closeInviteModal();
      loadInvitations();
      showTab('invitations');
    } else {
      showToast(data.message || 'Failed to send invitation', 'error');
    }
  } catch (error) {
    console.error('[Invite] Error:', error);
    showToast('Error sending invitation', 'error');
  }
}

// Load invitations
async function loadInvitations() {
  try {
    console.log('[Invitations] Loading...');
    const response = await fetch('/api/invitations', {
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    console.log('[Invitations] Loaded:', data);
    
    if (data.success) {
      renderInvitations(data.data.invitations);
      updateInvitationBadge(data.data.stats.pending_count);
    }
  } catch (error) {
    console.error('[Invitations] Error:', error);
  }
}

// Render invitations list
function renderInvitations(invitations) {
  const container = document.getElementById('invitations-list');
  
  if (!invitations || invitations.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="16 17 12 21 8 17"/>
          <line x1="12" y1="12" x2="12" y2="21"/>
        </svg>
        <p>No pending invitations</p>
        <button class="btn btn-primary" onclick="openInviteModal()">Invite First User</button>
      </div>
    `;
    return;
  }
  
  container.innerHTML = invitations.map(inv => {
    const expiresDate = new Date(inv.expires_at);
    const isExpired = expiresDate < new Date();
    const statusClass = isExpired ? 'expired' : inv.status;
    
    return `
      <div class="invitation-card ${statusClass}">
        <div class="invitation-header">
          <span class="invitation-email">${escapeHtml(inv.email)}</span>
          <span class="invitation-status ${statusClass}">${isExpired ? 'Expired' : inv.status}</span>
        </div>
        <div class="invitation-details">
          <p><strong>Role:</strong> ${inv.role}</p>
          <p><strong>Invited by:</strong> ${escapeHtml(inv.invited_by_name || 'Unknown')}</p>
          <p><strong>Expires:</strong> ${expiresDate.toLocaleDateString()}</p>
          ${inv.status === 'pending' && !isExpired ? `
            <div class="invitation-link" style="margin-top: 8px; padding: 8px; background: var(--bg-tertiary); border-radius: 4px; font-size: 12px; word-break: break-all;">
              <strong>Link:</strong> ${window.location.origin}/signup?token=${inv.token}
            </div>
          ` : ''}
        </div>
        ${inv.status === 'pending' && !isExpired ? `
          <div class="invitation-actions">
            <button class="btn btn-sm btn-secondary" onclick="copyInviteLink('${inv.token}')">Copy Link</button>
            <button class="btn btn-sm btn-secondary" onclick="resendInvitation(${inv.id})">Resend</button>
            <button class="btn btn-sm btn-danger" onclick="cancelInvitation(${inv.id})">Cancel</button>
          </div>
        ` : ''}
      </div>
    `;
  }).join('');
}

// Update invitation badge
function updateInvitationBadge(count) {
  const badge = document.getElementById('invitation-badge');
  if (count > 0) {
    badge.textContent = count;
    badge.style.display = 'inline';
  } else {
    badge.style.display = 'none';
  }
}

// Copy invitation link
function copyInviteLink(token) {
  const link = `${window.location.origin}/signup?token=${token}`;
  navigator.clipboard.writeText(link).then(() => {
    showToast('Link copied to clipboard!', 'success');
  }).catch(() => {
    showToast('Failed to copy link', 'error');
  });
}

// Cancel invitation
async function cancelInvitation(id) {
  if (!confirm('Are you sure you want to cancel this invitation?')) return;
  
  try {
    const response = await fetch(`/api/invitations/${id}`, {
      method: 'DELETE',
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast('Invitation cancelled', 'success');
      loadInvitations();
    } else {
      showToast(data.message || 'Failed to cancel', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error cancelling invitation', 'error');
  }
}

// Resend invitation
async function resendInvitation(id) {
  try {
    const response = await fetch(`/api/invitations/${id}/resend`, {
      method: 'POST',
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast('Invitation resent successfully!', 'success');
      loadInvitations();
    } else {
      showToast(data.message || 'Failed to resend', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error resending invitation', 'error');
  }
}

function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}
<% } %>
</script>

