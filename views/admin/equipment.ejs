<%- include('../partials/header', { title: title, user: user }) %>

<div class="page admin-page">
  <header class="page-header">
    <a href="/admin" class="btn-back" title="Back to Admin">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </a>
    <h1>Manage Equipment</h1>
    <div class="header-actions">
      <button class="btn-icon" id="add-btn" onclick="openModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Search Bar -->
  <div class="search-bar">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/>
      <path d="M21 21l-4.35-4.35"/>
    </svg>
    <input type="text" id="search-input" placeholder="Search equipment...">
  </div>

  <!-- Equipment List -->
  <div class="equipment-list" id="equipment-list">
    <div class="loading-skeleton">
      <div class="skeleton-item"></div>
      <div class="skeleton-item"></div>
    </div>
  </div>
</div>

<!-- Add/Edit Equipment Modal -->
<div class="modal hidden" id="equipment-modal">
  <div class="modal-overlay" onclick="closeModal()"></div>
  <div class="modal-content modal-lg">
    <div class="modal-header">
      <h2 id="modal-title">Add Equipment</h2>
      <button class="btn-close" onclick="closeModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <form id="equipment-form" class="modal-body">
      <input type="hidden" id="equipment-id" name="id">
      
      <div class="form-row">
        <div class="form-group">
          <label for="name">Equipment Name *</label>
          <input type="text" id="name" name="name" required placeholder="e.g., Centrifugal Pump A">
        </div>
        <div class="form-group">
          <label for="code">Equipment Code *</label>
          <input type="text" id="code" name="code" required placeholder="e.g., PUMP-001">
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="facility_id">Facility *</label>
          <select id="facility_id" name="facility_id" required>
            <option value="">Select Facility...</option>
          </select>
        </div>
        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category">
            <option value="">Select Category...</option>
            <option value="Pump">Pump</option>
            <option value="Motor">Motor</option>
            <option value="HVAC">HVAC</option>
            <option value="Compressor">Compressor</option>
            <option value="Conveyor">Conveyor</option>
            <option value="Generator">Generator</option>
            <option value="Vehicle">Vehicle</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="manufacturer">Manufacturer</label>
          <input type="text" id="manufacturer" name="manufacturer" placeholder="e.g., Grundfos">
        </div>
        <div class="form-group">
          <label for="model">Model</label>
          <input type="text" id="model" name="model" placeholder="e.g., CR 32-2">
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="serial_number">Serial Number</label>
          <input type="text" id="serial_number" name="serial_number" placeholder="Serial number">
        </div>
        <div class="form-group">
          <label for="location">Location</label>
          <input type="text" id="location" name="location" placeholder="e.g., Building A, Floor 2">
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="operational">Operational</option>
            <option value="maintenance">Under Maintenance</option>
            <option value="out_of_order">Out of Order</option>
            <option value="decommissioned">Decommissioned</option>
          </select>
        </div>
        <div class="form-group">
          <label for="criticality">Criticality</label>
          <select id="criticality" name="criticality">
            <option value="low">Low</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High</option>
            <option value="critical">Critical</option>
          </select>
        </div>
      </div>
      
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3" placeholder="Equipment description..."></textarea>
      </div>
      
      <div class="form-actions">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Equipment</button>
      </div>
    </form>
  </div>
</div>

<script>
checkAuth();

let editingId = null;
let facilities = [];

// Load equipment on page load
loadEquipment();
loadFacilities();

// Search
document.getElementById('search-input').addEventListener('input', debounce((e) => {
  const searchTerm = e.target.value;
  if (searchTerm.length > 2) {
    searchEquipment(searchTerm);
  } else if (searchTerm.length === 0) {
    loadEquipment();
  }
}, 300));

// Form submission
document.getElementById('equipment-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const formData = {
    name: document.getElementById('name').value,
    code: document.getElementById('code').value,
    facility_id: parseInt(document.getElementById('facility_id').value),
    category: document.getElementById('category').value,
    manufacturer: document.getElementById('manufacturer').value,
    model: document.getElementById('model').value,
    serial_number: document.getElementById('serial_number').value,
    location: document.getElementById('location').value,
    status: document.getElementById('status').value,
    criticality: document.getElementById('criticality').value,
    description: document.getElementById('description').value
  };
  
  try {
    const url = editingId ? `/api/equipment/${editingId}` : '/api/equipment';
    const method = editingId ? 'PUT' : 'POST';
    
    const response = await fetch(url, {
      method: method,
      headers: getAuthHeaders(),
      body: JSON.stringify(formData)
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast(editingId ? 'Equipment updated' : 'Equipment created', 'success');
      closeModal();
      loadEquipment();
    } else {
      showToast(data.message || 'Failed to save', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error saving equipment', 'error');
  }
});

async function loadFacilities() {
  try {
    const response = await fetch('/api/facilities', {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    if (data.success) {
      facilities = data.data.facilities;
      const select = document.getElementById('facility_id');
      select.innerHTML = '<option value="">Select Facility...</option>' + 
        facilities.map(f => `<option value="${f.id}">${f.name}</option>`).join('');
    }
  } catch (error) {
    console.error('Error loading facilities:', error);
  }
}

async function loadEquipment() {
  try {
    const response = await fetch('/api/equipment', {
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      renderEquipment(data.data.equipment);
    }
  } catch (error) {
    console.error('Error loading equipment:', error);
    showToast('Failed to load equipment', 'error');
  }
}

async function searchEquipment(searchTerm) {
  try {
    const response = await fetch(`/api/equipment/search?q=${encodeURIComponent(searchTerm)}`, {
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      renderEquipment(data.data.equipment);
    }
  } catch (error) {
    console.error('Error searching equipment:', error);
  }
}

function renderEquipment(equipment) {
  const container = document.getElementById('equipment-list');
  
  if (!equipment || equipment.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        <p>No equipment found</p>
        <button class="btn btn-primary" onclick="openModal()">Add First Equipment</button>
      </div>
    `;
    return;
  }
  
  container.innerHTML = equipment.map(eq => `
    <div class="equipment-card" data-id="${eq.id}">
      <div class="equipment-header">
        <span class="equipment-code">${eq.code}</span>
        <span class="equipment-status ${eq.status}">${formatStatus(eq.status)}</span>
      </div>
      <h3 class="equipment-name">${eq.name}</h3>
      <p class="equipment-facility">${eq.facility_name || ''} ${eq.category ? '• ' + eq.category : ''}</p>
      <div class="equipment-actions">
        <button class="btn-icon" onclick="editEquipment(${eq.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
        <button class="btn-icon btn-danger" onclick="deleteEquipment(${eq.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          </svg>
        </button>
      </div>
    </div>
  `).join('');
}

async function editEquipment(id) {
  try {
    const response = await fetch(`/api/equipment/${id}`, {
      headers: getAuthHeaders()
    });
    const data = await response.json();
    
    if (data.success && data.data.equipment) {
      const eq = data.data.equipment;
      editingId = id;
      document.getElementById('modal-title').textContent = 'Edit Equipment';
      document.getElementById('equipment-id').value = id;
      document.getElementById('name').value = eq.name;
      document.getElementById('code').value = eq.code;
      document.getElementById('facility_id').value = eq.facility_id;
      document.getElementById('category').value = eq.category || '';
      document.getElementById('manufacturer').value = eq.manufacturer || '';
      document.getElementById('model').value = eq.model || '';
      document.getElementById('serial_number').value = eq.serial_number || '';
      document.getElementById('location').value = eq.location || '';
      document.getElementById('status').value = eq.status;
      document.getElementById('criticality').value = eq.criticality;
      document.getElementById('description').value = eq.description || '';
      document.getElementById('equipment-modal').classList.remove('hidden');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error loading equipment', 'error');
  }
}

function openModal() {
  editingId = null;
  document.getElementById('modal-title').textContent = 'Add Equipment';
  document.getElementById('equipment-form').reset();
  document.getElementById('equipment-id').value = '';
  document.getElementById('equipment-modal').classList.remove('hidden');
}

function closeModal() {
  document.getElementById('equipment-modal').classList.add('hidden');
  editingId = null;
}

async function deleteEquipment(id) {
  if (!confirm('Are you sure you want to delete this equipment?')) return;
  
  try {
    const response = await fetch(`/api/equipment/${id}`, {
      method: 'DELETE',
      headers: getAuthHeaders()
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast('Equipment deleted', 'success');
      loadEquipment();
    } else {
      showToast(data.message || 'Failed to delete', 'error');
    }
  } catch (error) {
    console.error('Error:', error);
    showToast('Error deleting equipment', 'error');
  }
}

function formatStatus(status) {
  return status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

function debounce(func, wait) {
  let timeout;
  return function executedFunction(...args) {
    const later = () => {
      clearTimeout(timeout);
      func(...args);
    };
    clearTimeout(timeout);
    timeout = setTimeout(later, wait);
  };
}

function getAuthHeaders() {
  const token = localStorage.getItem('token');
  return {
    'Authorization': `Bearer ${token}`,
    'Content-Type': 'application/json'
  };
}

function checkAuth() {
  const token = localStorage.getItem('token');
  if (!token) {
    window.location.href = '/login';
  }
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}
</script>

<%- include('../partials/footer') %>
