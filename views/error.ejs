<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: #f8fafc;
    }
    .error-container {
      text-align: center;
      max-width: 400px;
    }
    .error-code {
      font-size: 120px;
      font-weight: 700;
      color: #e2e8f0;
      line-height: 1;
    }
    .error-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 24px;
      color: #ef4444;
    }
    h1 {
      font-size: 24px;
      color: #1e293b;
      margin-bottom: 12px;
    }
    p {
      font-size: 16px;
      color: #64748b;
      margin-bottom: 24px;
    }
    .btn {
      display: inline-block;
      padding: 12px 32px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 500;
    }
  </style>
</head>
<body>
  <div class="error-container">
    <div class="error-code"><%= statusCode %></div>
    <svg class="error-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <h1>Error <%= statusCode %></h1>
    <p><%= message %></p>
    <a href="/" class="btn">Go Home</a>
  </div>
</body>
</html>
