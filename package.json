{
  "name": "odm-cmms",
  "version": "2.0.0",
  "description": "Operator-Driven Maintenance Computerized Maintenance Management System",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "db:init": "node src/utils/init-db.js",
    "db:init-simple": "node src/utils/init-db-simple.js",
    "db:migrate:multitenant": "node database/migrations/run-multitenant-migration.js",
    "import:csv": "node src/utils/import-csv.js",
    "import:smp": "node src/utils/import-smp-csv.js",
    "import:smp": "node src/utils/import-smp.js",
    "import:smps": "node src/utils/batch-import-smps.js",
    "reset:all": "reset-and-rebuild.bat"
  },
  "keywords": ["cmms", "maintenance", "management", "api"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scriptsComments": {
    "start": "Production server",
    "dev": "Development with auto-reload"
  }
}
